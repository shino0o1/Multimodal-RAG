y="d5">1777461474</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="9月初"><data key="d0">9月初</data><data key="d1">时间</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-157bd3addbb38750d6dff95f3d5a9e7d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461474</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="image_e829e7045c7068717f3c220345760be2"><data key="d0">image_e829e7045c7068717f3c220345760be2</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">```json
{
  "detailed_description": "[{\"entity_name\": \"短额负蝗\", \"entity_type\": \"虫害\"}, {\"entit...</data><data key="d3">chunk-3cc56e56f38d55964222750bf971f471</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="三月青"><data key="d0">三月青</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;白菜的一种品种。</data><data key="d3">chunk-eb894f19e22eaf5521b51aa84906c1b0&lt;SEP&gt;chunk-26fa9146248963fad99265989a109245</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461174</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="三月青白锈病叶片症状"><data key="d0">三月青白锈病叶片症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了三月青（白菜品种）感染白锈病后的典型叶片症状，表现为叶片正面出现暗褐绿色转黄绿色的不规则病斑，伴随叶表皮隆起，这是十字花科蔬菜白锈病的重要诊断特征。</data><data key="d3">chunk-eb894f19e22eaf5521b51aa84906c1b0</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="三月青白锈病病叶背面疱斑"><data key="d0">三月青白锈病病叶背面疱斑</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了十字花科蔬菜三月青叶片背面感染白锈病的典型症状。病叶背面可见白色或乳白色隆起的疱斑，这些疱斑是病菌的孢子堆，成熟后会破裂并散出白色粉末状孢子囊，是白锈病的特征表现。</data><data key="d3">chunk-26fa9146248963fad99265989a109245</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="三至四龄"><data key="d0">三至四龄</data><data key="d1">生长期</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-4f81aa7efe24d8dc3a429c05163875d9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461456</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="三龄前"><data key="d0">三龄前</data><data key="d1">时间</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-0908a0340b9818d5c3d67ffd677f69df&lt;SEP&gt;chunk-4f81aa7efe24d8dc3a429c05163875d9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461414</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="三龄幼虫前"><data key="d0">三龄幼虫前</data><data key="d1">生长期</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-46edfbd3a10ec757b7c4b4f77709b9d3</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461386</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="不能开花"><data key="d0">不能开花</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-86fe0a0dce4f7819d35523a45e7fd62e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461464</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="丙森锌"><data key="d0">丙森锌</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-3e38741d2bfbf032bfe7da65cf5c9302&lt;SEP&gt;chunk-b3b74e94cd9e673214401f1d7e211970&lt;SEP&gt;chunk-b519def7c9178c12ba0037aaa6c70926&lt;SEP&gt;chunk-157bd3addbb38750d6dff95f3d5a9e7d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461367</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="丙森锌可湿性粉剂"><data key="d0">丙森锌可湿性粉剂</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-28f88298e7316c3aca7aa7d3f9c8e8ea&lt;SEP&gt;chunk-2d0a0e1a2ae281c246d32fd566f9339f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461206</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="中午前后"><data key="d0">中午前后</data><data key="d1">时间</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-75c79c36d93e57136b72ac0107291bc6</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461384</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="中华稻蝗"><data key="d0">中华稻蝗</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;直翅目蝗科昆虫&lt;SEP&gt;若虫体色可为灰绿色、绿色或浅绿色；一龄无翅芽；二龄头胸侧开始显现黑褐色纵纹；三龄头胸两侧黑褐色纵纹明显，沿背中线有淡色中带且微露翅芽；四龄翅芽呈三角形长度未达腹部第一节；末龄翅芽长度超过腹部第三节。</data><data key="d3">chunk-ca141699f53529c2e47d2d719892c294&lt;SEP&gt;chunk-619596f56e73bbdb8f2bab5ff716984c&lt;SEP&gt;chunk-4f81aa7efe24d8dc3a429c05163875d9&lt;SEP&gt;chunk-7ad50e2d4da052bc9fee4ea624a8528f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461438</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["取食叶片，造成缺刻", "取食作物叶片，造成缺刻，严重时全叶被吃光", "中华稻蝗成虫和若虫取食叶片后会造成叶片缺刻", "中华稻蝗严重时可导致整片叶子被吃光，只剩下叶脉", "中华稻蝗成虫和若虫取食叶片", "中华稻蝗若虫危害水稻的叶片", "中华稻蝗若虫危害玉米的叶片", "中华稻蝗若虫危害茭白的叶片", "叶缘和叶面出现明显缺刻", "严重时叶肉被食尽，仅残留叶脉", "取食白菜叶片", "取食大白菜叶片", "主要取食部位为叶片"], "防治要点": ["破坏越冬卵的生存环境", "保护青蛙、蟾蜍、麻雀、大寄生蝇等天敌有助于抑制中华稻蝗的发生", "在中华稻蝗三龄前若虫群集阶段可采取的防治措施", "中华稻蝗的防治药剂"], "发生时期": ["在浙江地区通常在5月中下旬孵化", "在浙江地区7、8月羽化为成虫", "在浙江地区9月中下旬为产卵盛期", "在广东地区，中华稻蝗的第一代成虫在6月上旬出现", "在广东地区，中华稻蝗的第二代成虫在9月中上旬出现", "越冬卵通常在翌年的3月下旬至清明前孵化"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-619596f56e73bbdb8f2bab5ff716984c", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-4f81aa7efe24d8dc3a429c05163875d9", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-7ad50e2d4da052bc9fee4ea624a8528f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "防治要点": [{"chunk": "chunk-4f81aa7efe24d8dc3a429c05163875d9", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-4f81aa7efe24d8dc3a429c05163875d9", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="中华稻蝗对白菜的危害"><data key="d0">中华稻蝗对白菜的危害</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了中华稻蝗对十字花科蔬菜（白菜）造成的叶片危害。中华稻蝗成虫及若虫取食叶片，导致叶片出现缺刻，严重时仅留叶脉。此信息对于构建蝗虫类害虫危害特征图谱具有重要意义。</data><data key="d3">chunk-7ad50e2d4da052bc9fee4ea624a8528f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="中华稻蝗成虫危害十字花科蔬菜叶片"><data key="d0">中华稻蝗成虫危害十字花科蔬菜叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示中华稻蝗成虫在植物叶片上，叶片有被取食的缺刻。中华稻蝗属于直翅目蝗科，主要危害十字花科蔬菜等多种植物叶片。防治方法包括农业防治、生物防治和药剂防治，如使用氟虫脲乳油、辛硫磷乳油等。</data><data key="d3">chunk-619596f56e73bbdb8f2bab5ff716984c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="中华稻蝗若虫危害叶片图"><data key="d0">中华稻蝗若虫危害叶片图</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示中华稻蝗若虫在一片叶片上，叶片有被取食的缺刻。中华稻蝗属直翅目蝗科，是多种禾本科植物及十字花科等蔬菜的重要害虫，若虫和成虫均可取食叶片。防治措施包括农业防治、生物防治（保护天敌）和化学防治（使用氟虫脲、辛硫磷等药剂）。</data><data key="d3">chunk-4f81aa7efe24d8dc3a429c05163875d9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="主脉"><data key="d0">主脉</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2f12138e59db2f07225a36a367d035a7&lt;SEP&gt;chunk-5225b33b17e8ce25a168f6df8d8215e5</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461177</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="乙基多杀菌素"><data key="d0">乙基多杀菌素</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-c41e49bf19f4a71064df3d77eebfb411</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461486</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="代森锰锌"><data key="d0">代森锰锌</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;发病初期可选用药剂</data><data key="d3">chunk-3511fba3b1d9eaeca88fc9aca1dc1364&lt;SEP&gt;chunk-3e38741d2bfbf032bfe7da65cf5c9302&lt;SEP&gt;chunk-0b5f294b1c97