4e2c085cbd981e991eb6f9a8e92&lt;SEP&gt;chunk-36a0d55340470c41badc3ab815a48b11&lt;SEP&gt;chunk-e4deaf546dd3ce6cf9f4d4298a30c16c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461478</data><data key="d6" /><data key="d7" /><data key="d8">{"防治要点": ["清除田间残株", "利用假死性", "N/A"], "危害症状": ["N/A", "取食叶片导致千疮百孔", "幼虫喜食心叶", "取食叶片导致孔洞、网状及扫把状残留"], "发生时期": ["N/A"]}</data><data key="d9">{"防治要点": [{"chunk": "chunk-36a0d55340470c41badc3ab815a48b11", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "危害症状": [{"chunk": "chunk-36a0d55340470c41badc3ab815a48b11", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-e4deaf546dd3ce6cf9f4d4298a30c16c", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-e4deaf546dd3ce6cf9f4d4298a30c16c", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="软腐病"><data key="d0">软腐病</data><data key="d1">病害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;大白菜主要病害，会导致组织腐烂及恶臭&lt;SEP&gt;一种常见的细菌性病害，后期可表现为干腐症状。&lt;SEP&gt;甘蓝的一种病害&lt;SEP&gt;由细菌引起的一种常见的作物病害。&lt;SEP&gt;萝卜常见病害，导致组织软化腐烂并散发恶臭。</data><data key="d3">chunk-2de1784a101a3d8331d829acf538c9e1&lt;SEP&gt;chunk-c60631811c47de4ce2c79aee52951117&lt;SEP&gt;chunk-6853819bd6c24f5f2236d760b9ce81b1&lt;SEP&gt;chunk-8d64d27c40d5e2c0a3a5de38821420bd&lt;SEP&gt;chunk-aa89e13f2be5973d8335d6cc12cf7a4e&lt;SEP&gt;chunk-602d37fbdad3894f3fd097dec446048d&lt;SEP&gt;chunk-6fad4f22632131c47ac7fa6e017c1365&lt;SEP&gt;chunk-c6a1c58572667dcaf6731aaf90b72d08&lt;SEP&gt;chunk-7607a348b8d39b8ae825c84727752791&lt;SEP&gt;chunk-89fd1a92fac060bd5bcd453db48be5bb&lt;SEP&gt;chunk-6a566dac6682579a8b7ab6c46552d839&lt;SEP&gt;chunk-e1a25ad91df4056b23309ce4d87d098e&lt;SEP&gt;chunk-cef0a38360a3e2500cb25e1f6f777a8f&lt;SEP&gt;chunk-b7d37dbe266253071f05692384eaf7ec&lt;SEP&gt;chunk-c3cc3c96f11412119dd352621bc75a4a&lt;SEP&gt;chunk-9de6c623c37e6db5374f7045b110ca10&lt;SEP&gt;chunk-75c79c36d93e57136b72ac0107291bc6&lt;SEP&gt;chunk-310884df7e9f7ec7abc03ff78374fddd&lt;SEP&gt;chunk-46edfbd3a10ec757b7c4b4f77709b9d3&lt;SEP&gt;chunk-9e4557a3ad0dc9e0886fbcbc5cafce0b&lt;SEP&gt;chunk-f78464a2c762f2ac52cce0271de908a9&lt;SEP&gt;chunk-561a951e4deb74888f3eb64e5e201ff8&lt;SEP&gt;chunk-072d30697d058f37fa4825ec390d9508&lt;SEP&gt;chunk-ce89c7a24c968edc3b8daaa4ee7e44ed&lt;SEP&gt;chunk-d5261c75c7e2eb3b9a74271f3ff4e048&lt;SEP&gt;chunk-e65169eeb2407bedfb7e356dc1bbf1f8&lt;SEP&gt;chunk-844030a4d8a6de0ccf527992172d7166&lt;SEP&gt;chunk-fd340e54e36fe920be68c4ac34586210&lt;SEP&gt;chunk-16950d1361b65e692bd4c9c79222ad0e&lt;SEP&gt;chunk-6c358d7727d47fb774fde79b593cdb64&lt;SEP&gt;chunk-d19d7e947c23393542da83f9bbf10b07&lt;SEP&gt;chunk-59c5bccd07c65bb2d4ee85c5819dd9d1&lt;SEP&gt;chunk-132e8f455d2d417f60b885555af0141d&lt;SEP&gt;chunk-3a78e3281e5a0bbc179d412851f35c67&lt;SEP&gt;chunk-7b829618261d91ae767ed1131698e3a8&lt;SEP&gt;chunk-3420d79a9e5621d0c5a78a59239be5b5&lt;SEP&gt;chunk-379c9a8e038b134bd47ee4e60ac579ca</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461169</data><data key="d6" /><data key="d7">烂葫芦</data><data key="d8">{"危害症状": ["稀泥状腐烂", "N/A", "塌倒溃烂", "湿腐症状", "组织软腐", "黏滑泥状", "整株溃烂", "萝卜软腐病发病初期根颈部出现的病斑。", "软腐病随病程进展，组织变软腐烂。", "软腐病组织变软腐烂后的特征。", "软腐病腐烂部位常伴随汁液渗出。", "软腐病腐烂部位呈黏滑的稀泥状。", "萝卜软腐病根颈部典型的腐烂症状。", "萝卜软腐病根颈腐烂症状之一。", "萝卜软腐病根颈腐烂症状的特征。", "萝卜软腐病主要危害萝卜。", "萝卜软腐病主要危害萝卜根部。", "软腐病发病初期根颈部出现油渍状褐色病斑。", "软腐病后期可向上蔓延致心叶受损。", "组织失水溃烂，伴随黄色黏稠物", "病害发生时产生的特殊气味", "表现为褐色腐烂。", "表现为叶柄基部组织软化呈黏滑状。", "软腐病主要危害小白菜心叶。", "软腐病主要危害叶柄基部组织。", "软腐病初期在叶柄基部与茎基部交界处出现的症状。", "软腐病导致植株叶片失去支撑力而下垂。", "软腐病病叶失水后呈薄纸状。", "软腐病导致组织分解变质。", "软腐病腐烂组织中充满的物质。", "软腐病腐烂组织散发的异味。", "软腐病在贮藏期持续发展造成的储存损失。", "软腐病在天气干燥时表现出的，病叶失水呈薄纸状，紧贴叶球，叶球外露。", "软腐病危害大白菜", "软腐病危害甘蓝", "软腐病危害萝卜", "软腐病危害花椰菜", "软腐病也可危害番茄", "软腐病也可危害辣椒", "软腐病也可危害马铃薯", "软腐病也可危害黄瓜", "软腐病也可危害芹菜", "半透明水渍状病斑", "腐烂萎蔫", "软腐病主要危害大白菜叶柄基部", "软腐病主要危害大白菜茎基部", "组织腐烂成灰褐色黏滑泥状", "病部初期症状", "叶球组织腐烂后的状态", "叶片失水干枯", "植株倒下", "甘蓝是软腐病的寄主", "软腐病主要危害甘蓝的结球部位，导致叶球组织腐烂", "最终导致植株外层叶片枯萎倒伏", "受害部位出现半透明水渍状病斑。", "后期组织腐烂并伴有恶臭黏稠物。", "叶球失水呈薄纸状。", "叶柄基部出现水渍状微黄色病斑。", "根茎组织腐烂充满黄色黏稠物，散发臭味。", "严重时可导致全株腐烂塌倒。", "大白菜易感软腐病。", "软腐病主要危害叶柄。", "软腐病主要危害根茎。", "软腐病主要危害叶球。", "软腐病导致大白菜心部腐烂的症状", "软腐病初期表现为半透明水渍状微黄色病斑", "组织坏死软化", "软腐病引起的气味", "组织呈灰褐色软化腐烂的症状", "叶片失去膨胀度而下垂", "整个植株腐烂的症状", "软腐病表现为内部组织软化", "软腐病导致组织色泽变暗", "软腐病主要危害叶柄基部", "软腐病主要危害根茎心髓", "软腐病初期在叶柄基部和茎基部出现的症状", "软腐病后期组织腐烂的症状", "软腐病对植株整体造成的危害症状", "表皮出现油渍状褐色病斑，组织软化腐烂，最终呈黑褐色稀泥状。", "表现为基部组织软化腐烂", "发病组织呈现黏滑稀泥状", "叶片表现为枯萎下垂并紧贴地面", "组织灰褐色软腐", "主要症状表现", "在茎部引起组织软腐及恶臭", "病部组织失水变干，呈褐色或黑褐色病斑，质地变硬。", "软腐病侵染叶球部位。"], "发病诱因": ["细菌侵入软腐病的途径。", "有利于软腐病发生的环境条件。", "病菌侵入的途径", "由菜青虫取食造成的机械损伤", "病原菌侵入的途径之一。"], "发生时期": ["贮藏期病害持续发展。", "软腐病多在包心期发生"], "别名": ["菜粉蝶的幼虫阶段。", "烂葫芦"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-8d64d27c40d5e2c0a3a5de38821420bd", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-aa89e13f2be5973d8335d6cc12cf7a4e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-6fad4f22632131c47ac7fa6e017c1365", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-7607a348b8d39b8ae825c84727752791", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-6a566dac6682579a8b7ab6c46552d839", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-e1a25ad91df4056b23309ce4d87d098e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-c3cc3c96f11412119dd352621bc75a4a", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-310884df7e9f7ec7abc03ff78374fddd", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-ce89c7a24c968edc3b8daaa4ee7e44ed", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-fd340e54e36fe920be68c4ac34586210", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-59c5bccd07c65bb2d4ee85c5819dd9d1", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-132e8f455d2d417f60b885555af0141d", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-3a78e3281e5a0bbc179d412851f35c67", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-379c9a8e038b134bd47ee4e60ac579ca", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发病诱因": [{"chunk": "chunk-aa89e13f2be5973d8335d6cc12cf7a4e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-c3