3.pdf</data><data key="d5">1777461282</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="溴氰虫酰胺可分散油悬浮剂"><data key="d0">溴氰虫酰胺可分散油悬浮剂</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;10%可分散油悬浮剂</data><data key="d3">chunk-75c79c36d93e57136b72ac0107291bc6&lt;SEP&gt;chunk-844030a4d8a6de0ccf527992172d7166&lt;SEP&gt;chunk-16950d1361b65e692bd4c9c79222ad0e&lt;SEP&gt;chunk-32ddbaf2dc6854d70cd0231ee3b7b30f&lt;SEP&gt;chunk-36a0d55340470c41badc3ab815a48b11&lt;SEP&gt;chunk-e4deaf546dd3ce6cf9f4d4298a30c16c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461379</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="灭幼脲1号"><data key="d0">灭幼脲1号</data><data key="d1">药剂</data><data key="d10" /><data key="d2">20%悬浮乳剂</data><data key="d3">chunk-039c414821a18ac99777ef473c4c3eeb&lt;SEP&gt;chunk-619596f56e73bbdb8f2bab5ff716984c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461442</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="灭幼脲1号悬浮乳剂"><data key="d0">灭幼脲1号悬浮乳剂</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-4f81aa7efe24d8dc3a429c05163875d9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461452</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="灰巴蜗牛"><data key="d0">灰巴蜗牛</data><data key="d1">虫害</data><data key="d10">image</data><data key="d2">图示为灰巴蜗牛，属柄眼目巴蜗牛科。该虫害主要危害十字花科、葫芦科、豆科及茄科等作物，成贝和幼贝通过齿舌刮食造成叶片孔洞或缺刻，甚至导致幼苗缺苗断垄，防治可选用四聚乙醛颗粒剂。&lt;SEP&gt;N/A&lt;SEP&gt;具有中等大小的圆球形贝壳，壳质稍厚坚固，颜色为黄褐色或琥珀色，带有生长线和螺纹；成贝和幼贝均具危害性。&lt;SEP&gt;贝壳中等大小，圆球形，壳质稍厚，黄褐色或琥珀色。&lt;SEP&gt;属腹足纲柄眼目巴蜗牛科的蜗牛种类，成贝贝壳中等大小，质厚坚固，圆球形，壳面黄褐色或琥珀色，有细致生长线。齿舌刮食植株。&lt;SEP&gt;腹足纲柄眼目巴蜗牛科害虫，贝壳呈圆球形，黄褐色或琥珀色。</data><data key="d3">chunk-a6d0c51243ca209ed10575700d7d6fcb&lt;SEP&gt;chunk-ae6ade12d6e6964fb85422f4cc485bee&lt;SEP&gt;chunk-b16cd651cdc5569a6a819323b4bebdf3&lt;SEP&gt;chunk-2183dd5d018c45af93c88653910c0ba1&lt;SEP&gt;chunk-dd1cedc8d65b907a2104d9a71428b3be&lt;SEP&gt;chunk-039c414821a18ac99777ef473c4c3eeb&lt;SEP&gt;chunk-64d7ba16672b09ea0136eba5fdbd5a11</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461198</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["N/A", "常造成缺苗断垄", "通过齿舌刮食行为危害十字花科等多种作物的叶片", "通过齿舌刮食行为危害十字花科等多种作物的茎部", "灰巴蜗牛在叶片表面取食，造成危害", "取食受害部位", "灰巴蜗牛以齿舌刮食白菜叶片。", "造成孔洞或缺刻。"], "发生时期": ["多发生于温暖多雨季节"], "防治要点": ["防治可使用农业物理防治手段", "防治可使用四聚乙醛", "防治可使用四聚·杀螺胺", "防治灰巴蜗牛可使用四聚乙醛", "防治灰巴蜗牛可使用四聚·杀螺胺"], "形态特征": ["成贝贝壳中等大小", "成贝贝壳质厚坚固", "N/A", "壳面有细致生长线"], "生活习性": ["灰巴蜗牛喜栖息的环境"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-ae6ade12d6e6964fb85422f4cc485bee", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-b16cd651cdc5569a6a819323b4bebdf3", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-a6d0c51243ca209ed10575700d7d6fcb", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-2183dd5d018c45af93c88653910c0ba1", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-ae6ade12d6e6964fb85422f4cc485bee", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "防治要点": [{"chunk": "chunk-ae6ade12d6e6964fb85422f4cc485bee", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-b16cd651cdc5569a6a819323b4bebdf3", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-b16cd651cdc5569a6a819323b4bebdf3", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-a6d0c51243ca209ed10575700d7d6fcb", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="灰巴蜗牛 (Bradybaena ravida"><data key="d0">灰巴蜗牛 (Bradybaena ravida</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图示为灰巴蜗牛，属腹足纲柄眼目巴蜗牛科。该害虫主要以齿舌刮食十字花科、葫芦科等多种作物的叶片和茎部，导致孔洞、缺刻甚至缺苗断垄。喜湿润环境，常在傍晚或阴雨天活动，农业防治可采用中耕排涝、人工诱捕，药剂防治常用四聚乙醛。</data><data key="d3">chunk-ae6ade12d6e6964fb85422f4cc485bee</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="灰巴蜗牛危害白菜状"><data key="d0">灰巴蜗牛危害白菜状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了灰巴蜗牛对白菜等十字花科蔬菜的危害状。灰巴蜗牛通过齿舌刮食叶片，形成孔洞和缺刻。防治需采取清除田间杂草、物理诱捕及在发生初盛期使用四聚乙醛颗粒剂等综合措施。</data><data key="d3">chunk-2183dd5d018c45af93c88653910c0ba1</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="灰巴蜗牛成贝"><data key="d0">灰巴蜗牛成贝</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">灰巴蜗牛（Bradybaena ravida）属于腹足纲柄眼目巴蜗牛科，主要危害蔬菜叶片。成贝呈圆球形，壳黄褐色。防治上需采取农业防治（清园、深翻）与化学防治（四聚乙醛、四聚·杀螺胺）相结合，并在傍晚施药效果最佳。</data><data key="d3">chunk-b16cd651cdc5569a6a819323b4bebdf3</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="灰葡萄孢菌"><data key="d0">灰葡萄孢菌</data><data key="d1">病原菌</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;Botrytis cinerea</data><data key="d3">chunk-dd4f11020dd7238ceae19b1bc2e12e6d&lt;SEP&gt;chunk-c31283d50d160b1f299e0a202450ac31</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461398</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="灰霉病"><data key="d0">灰霉病</data><data key="d1">病害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;主要危害十字花科蔬菜，如白菜、甘蓝、花椰菜等</data><data key="d3">chunk-2711af80087a36171089b13436581425&lt;SEP&gt;chunk-dd4f11020dd7238ceae19b1bc2e12e6d&lt;SEP&gt;chunk-026760796995a178eb1fdad1452f8328&lt;SEP&gt;chunk-c31283d50d160b1f299e0a202450ac31&lt;SEP&gt;chunk-e952c6ae5e41b5b7343b726c00747606</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461397</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["灰霉病侵害甘蓝", "灰霉病侵害白菜", "灰霉病发病初期症状", "灰霉病后期病部颜色", "灰霉病后期病部症状，可致叶球腐烂", "灰霉病病部表面产生的病征", "灰霉病病部表面形成的病征", "灰霉病在湿度大时发生的症状", "灰霉病病情扩展规律", "主要危害该作物", "主要危害白菜的部位", "主要危害白菜的部位，可致腐烂", "水渍状病斑", "灰色霉层", "主要危害部位", "灰霉病在叶片上表现为水渍状病斑", "病部扩大呈现褐色或淡红褐色腐烂", "N/A", "花椰菜灰霉病"], "发病诱因": ["引起灰霉病病部迅速扩大的环境条件", "灰霉病发生与高湿度环境密切相关"], "发生时期": ["在白菜的此生长期可发病"], "形态特征": ["N/A"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-dd4f11020dd7238ceae19b1bc2e12e6d", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-026760796995a178eb1fdad1452f8328", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-c31283d50d160b1f299e0a202450ac31", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-e952c6ae5e41b5b7343b726c00747606", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发病诱因": [{"chunk": "chunk-026760796995a178eb1fdad1452f8328", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-e952c6ae5e41b5b7343b726c00747606", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-026760796995a178eb1fdad1452f8328", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-e952c6ae5e41b5b7343b726c00747606", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="炭疽病"><data key="d0">炭疽病</data><data key="d1">病害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;由真菌引起的植物病害，表现为坏死斑点。&lt;SEP&gt;一种典型的真菌性病害&lt;SEP&gt;萝卜的一种常见病害，前期症状主要表现为叶脉或叶柄上出现病斑。</data><data key="d3">chunk-3511fba3b1d9eaeca88fc9aca1dc1364&lt;SEP&gt;chunk-b2571a6903393e420ef4698741a914b5&lt;SEP&gt;chunk-7db27298b6bc94a19de9bdb6c76b2710&lt;SEP&gt;chunk-65e7d10e9f2456c50b8dbadf28624a5c&lt;SEP&gt;chunk-338fab7f749dc818d827561a47088f1b&lt;SEP&gt;chunk-53ffdfc1690d5fc090735c408283391d&lt;SEP&gt;chunk-eeed8e4c5d0d1c051facb662f75d1e09&lt;SEP&gt;chunk-79b765b62eb3bc05922343d1d04cdc1e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461259</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["N/A", "白菜炭疽病在叶柄上的病斑；病害主要危害叶片、叶柄及花梗", "病害主要危害叶片、叶柄及花梗", "病害主要危害叶片部位", "病害主要危害叶柄部位", "呈条状，长圆形至纺锤形，凹陷较深，中间灰白色，边缘深褐色，病斑间可相互融合。", "病害侵染白菜导致叶片病变", "炭疽病主要危害部位", "萝卜炭疽病后期在叶柄表现出长圆形至纺锤形或梭形病斑", "萝卜炭疽病后期在叶脉及叶片表现出褐色病斑", "萝卜炭疽病危害萝卜", "萝卜炭疽病危害萝卜的叶片", "萝卜炭疽病危害萝卜的叶柄", "通常呈长圆形、纺锤形或梭形，伴随凹陷，颜色从褐色逐渐变为中心灰白色，后期易发生穿孔。", "病斑后期常发生的症状。", "早期症状之一", "炭疽病严重时病斑相连扩展形成大斑块。", "病害导致叶片萎蔫、发黄及枯死。", "病害在叶片部位产生危害。", "病害在叶柄部位产生危害。"], "发病诱因": ["高温高湿环境可诱发病害", "高温高湿利于病害流行。", "环境因素诱发病害流行", "有助于病害发生与蔓延", "在此温度范围下有助于病害发生与蔓延"], "防治要点": ["防治初期可用代森锰锌", "防治初期可用咪鲜胺", "防治初期可用苯醚甲环唑"], "发生时期": ["N/A"], "形态特征": ["萝卜叶片及叶脉受炭疽病侵害的早期表现。"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-b2571a6903393e420ef4698741a914b5", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-7db27298b6bc94a19de9bdb6c76b2710", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-65e7d10e9f2456c50b8dbadf28624a5c", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-338fab7f749dc818d827561a47088f1b", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-53ffdfc1690d5fc090735c408283391d", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-eeed8e4c5d0d1c051facb662f75d1e09", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-79b765b62eb3bc05922343d1d04cdc1e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发病诱因": [{"chunk": "chunk-7db27298b6bc94a19de9bdb6c76b2710", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-65e7d10e9f2456c50b8dbadf28624a5c", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-338fab7f749dc818d827561a47088f1b", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-eeed8e4c5d0d1c051facb662f75d1e09", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "防治要点": [{"chunk": "chunk-7db27298b6bc94a19de9bdb6c76b2710", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-53ffdfc1690d5fc090735c408283391d", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-eeed8e4c5d0d1c051facb662f75d1e09", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="烟粉虱"><data key="d0">烟粉虱</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-e1ffc4d7126b3916ef88c8c7f5b1a921&lt;SEP&gt;chunk-ca141699f53529c2e47d2d719892c294&lt;SEP&gt;chunk-af7dd67e1aecd6c6715c79478479c668&lt;SEP&gt;chunk-42b55ba8453375fed74e005cd3cc43ab</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461389</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["成虫和若虫在叶背群集吸食汁液，分泌蜜露", "导致萎缩、褪绿、变黄、萎蔫", "导致被害叶片萎缩", "N/A", "导致白茎出现", "导致颜色白化、无味、重量减轻"], "生活习性": ["成虫和若虫均以吸食植物汁液为危害方式", "分泌蜜露"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-af7dd67e1aecd6c6715c79478479c668", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-42b55ba8453375fed74e005cd3cc43ab", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-42b55ba8453375fed74e005cd3cc43ab", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="烟粉虱危害花椰菜引发煤污病"><data key="d0">烟粉虱危害花椰菜引发煤污病</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了花椰菜受烟粉虱危害后的典型症状。烟粉虱以成虫和若虫群集于叶背吸食汁液，导致叶片萎缩变黄，并因分泌蜜露污染叶片诱发煤污病，严重影响光合作用。</data><data key="d3">chunk-af7dd67e1aecd6c6715c79478479c668</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="烟粉虱成虫群集危害十字花科蔬菜叶片"><data key="d0">烟粉虱成虫群集危害十字花科蔬菜叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示烟粉虱成虫群集在十字花科蔬菜的叶片背面，吸食植物汁液。这种危害会导致叶片萎缩、褪绿、变黄，并可引起煤污病、传播病毒病。</data><data key="d3">chunk-42b55ba8453375fed74e005cd3cc43ab</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="烟草"><data key="d0">烟草</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-039c414821a18ac99777ef473c4c3eeb</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777459275</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="烯啶虫胺"><data key="d0">烯啶虫胺</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-1af2b19abb0b704d0d3c588002b68add</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461408</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="煤污病"><data key="d0">煤污病</data><data key="d1">病害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;由蜜露诱发&lt;SEP&gt;由蜜露污染引起的病害。</data><data key="d3">chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-e1ffc4d7126b3916ef88c8c7f5b1a921&lt;SEP&gt;chunk-ca141699f53529c2e47d2d719892c294&lt;SEP&gt;chunk-af7dd67e1aecd6c6715c79478479c668&lt;SEP&gt;chunk-bf35b6fe615bb837008bfcf5197afb12&lt;SEP&gt;chunk-9418342574b2792109b681e7c44601ba&lt;SEP&gt;chunk-1af2b19abb0b704d0d3c588002b68add&lt;SEP&gt;chunk-80aef901199e2ace7583bc4503b58d78&lt;SEP&gt;chunk-42b55ba8453375fed74e005cd3cc43ab&lt;SEP&gt;chunk-2dfd14c48b4b4598d0c8ffa221c1df81&lt;SEP&gt;chunk-bff12f56d0df62b0fd2dbb213026b0d6&lt;SEP&gt;chunk-16e53f221a8aaf862ba107b114abcab2&lt;SEP&gt;chunk-b468b01feae03bbeb095bda274f22463&lt;SEP&gt;chunk-27d0171243706f7c20a06c9a73190c96&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461389</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["桃蚜排泄的蜜露可诱发煤污病，污染蔬菜。", "污染蔬菜"], "生活习性": ["烟粉虱分泌蜜露引起"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-80aef901199e2ace7583bc4503b58d78", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-86fe0a0dce4f7819d35523a45e7fd62e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-42b55ba8453375fed74e005cd3cc43ab", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="猿叶甲"><data key="d0">猿叶甲</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-6853819bd6c24f5f2236d760b9ce81b1&lt;SEP&gt;chunk-2102c4977ee2662531b474addbf76d25&lt;SEP&gt;chunk-06c4679ebf4de0a8d8224fbb2924294f&lt;SEP&gt;chunk-b7d37dbe266253071f05692384eaf7ec&lt;SEP&gt;chunk-6c9c5c1a89394df08c4521777314cc90&lt;SEP&gt;chunk-3b4748e1b515b1d16d492a54