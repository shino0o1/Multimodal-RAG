node><node id="菌核病"><data key="d0">菌核病</data><data key="d1">病害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;由菌核病原菌引起的病害&lt;SEP&gt;莴苣常见的病害类型。&lt;SEP&gt;真菌性病害，主要引起植株腐烂和枯死。</data><data key="d3">chunk-2711af80087a36171089b13436581425&lt;SEP&gt;chunk-e124f728736920798021720adc02a59e&lt;SEP&gt;chunk-3a1f6f9f0807cdecb083d00e3ee7feba&lt;SEP&gt;chunk-fa4fa1ff156d1b25005e299d42ec2fce&lt;SEP&gt;chunk-c4cd38a417063b510b68314037e37d36&lt;SEP&gt;chunk-3432b8633ea0fc698665ef94d1ee6d37&lt;SEP&gt;chunk-624be2cf5f3968ab37387c2390070381&lt;SEP&gt;chunk-de1c9cadad9dd3d2754b4b1f782866a0&lt;SEP&gt;chunk-a21ba0d0d4ddb7ede46cade93c561764&lt;SEP&gt;chunk-61e246e90bcaaf9ad1308e02f330b201&lt;SEP&gt;chunk-c2c46152db5ff07cdb1d6f5561cce0dc&lt;SEP&gt;chunk-18ae905dc413db63df2e0fffe7cb0d9f&lt;SEP&gt;chunk-64dbbfe6815b715aaf473f142dcecc73</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461376</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["黑色、鼠粪状，病害典型特征", "棉絮状的病征组织", "该病害主要危害部位", "N/A", "受害部位主要集中在植株基部", "受害部位主要集中在叶球", "导致受害部位出现组织腐烂症状", "病害发生于叶球部位", "病害发生于茎基部", "小白菜菌核病早期症状", "小白菜菌核病病部症状", "小白菜菌核病后期可见白色或灰白色棉絮状菌丝", "小白菜菌核病后期症状", "甘蓝菌核病表现为病部组织腐烂。", "菌核病危害甘蓝。", "菌核病在病部组织初期的表现为水渍状淡褐色凹陷病斑。", "菌核病导致病部腐烂后密生白色棉絮状菌丝。", "菌核病主要危害小白菜的根颈及茎基部，表现出病理性腐烂和菌丝附着症状。", "产生典型的病害症状。", "菌核病侵害大白菜导致组织腐烂", "菌核病侵害大白菜", "危害部位包括茎基部", "危害部位包括叶片", "危害部位包括叶球", "在成株期表现明显危害特征"], "形态特征": ["病部密生的黑色鼠粪状菌核", "菌核病后期产生黑色鼠粪状菌核。", "白色或灰白色", "病部产生菌核。"], "发生时期": ["菌核病发生于成株期"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-e124f728736920798021720adc02a59e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-3a1f6f9f0807cdecb083d00e3ee7feba", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-c4cd38a417063b510b68314037e37d36", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-3432b8633ea0fc698665ef94d1ee6d37", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-624be2cf5f3968ab37387c2390070381", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-de1c9cadad9dd3d2754b4b1f782866a0", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-a21ba0d0d4ddb7ede46cade93c561764", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-61e246e90bcaaf9ad1308e02f330b201", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-c2c46152db5ff07cdb1d6f5561cce0dc", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-c4cd38a417063b510b68314037e37d36", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-de1c9cadad9dd3d2754b4b1f782866a0", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-a21ba0d0d4ddb7ede46cade93c561764", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-18ae905dc413db63df2e0fffe7cb0d9f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="菌核病病原菌"><data key="d0">菌核病病原菌</data><data key="d1">病原菌</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-61e246e90bcaaf9ad1308e02f330b201</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461462</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜根"><data key="d0">菜根</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-b7d37dbe266253071f05692384eaf7ec&lt;SEP&gt;chunk-75c79c36d93e57136b72ac0107291bc6&lt;SEP&gt;chunk-9e4557a3ad0dc9e0886fbcbc5cafce0b&lt;SEP&gt;chunk-f78464a2c762f2ac52cce0271de908a9&lt;SEP&gt;chunk-e65169eeb2407bedfb7e356dc1bbf1f8</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461349</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜粉蝶"><data key="d0">菜粉蝶</data><data key="d1">虫害</data><data key="d10" /><data key="d2">Entity：菜粉蝶。属于鳞翅目粉蝶科，是十字花科蔬菜的重要害虫。成虫又名白粉蝶、白蝴蝶或粉蝶，翅面呈乳白色或淡黄白色，前翅顶角具三角形黑斑，翅中下方有2个黑色圆斑，常栖息于十字花科植物叶片表面。其幼虫期称为菜青虫，通过危害作物造成虫害影响。</data><data key="d3">chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-eb8e40732cd0b5a7f534922a7ccb9a6e&lt;SEP&gt;chunk-602d37fbdad3894f3fd097dec446048d&lt;SEP&gt;chunk-c6a1c58572667dcaf6731aaf90b72d08&lt;SEP&gt;chunk-e28b536983c09a8a7efed8f351c99c0f&lt;SEP&gt;chunk-46edfbd3a10ec757b7c4b4f77709b9d3&lt;SEP&gt;chunk-849b03cd52bb68264d62993a59d36141&lt;SEP&gt;chunk-561a951e4deb74888f3eb64e5e201ff8&lt;SEP&gt;chunk-d5261c75c7e2eb3b9a74271f3ff4e048&lt;SEP&gt;chunk-79b786f538ba9110de2adfd6e57c7618&lt;SEP&gt;chunk-bff12f56d0df62b0fd2dbb213026b0d6&lt;SEP&gt;chunk-6c358d7727d47fb774fde79b593cdb64&lt;SEP&gt;chunk-d19d7e947c23393542da83f9bbf10b07&lt;SEP&gt;chunk-058bfcb505d4110825b3930b6eb972e2&lt;SEP&gt;chunk-25a870883e30ca4e4e260db153e16de6&lt;SEP&gt;chunk-749648f3569db2742acde22e0ccdc771&lt;SEP&gt;chunk-a5dd5082aa7c0708134d0e024eeb5f52&lt;SEP&gt;chunk-79e13eb4c78335551c4fba9ead91efa8&lt;SEP&gt;chunk-7b829618261d91ae767ed1131698e3a8&lt;SEP&gt;chunk-eb133807de2ff915d9cd628148148023</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461249</data><data key="d6" /><data key="d7">菜青虫&lt;SEP&gt;白粉蝶</data><data key="d8">{"别名": ["菜青虫", "白粉蝶", "菜粉蝶别称", "菜粉蝶幼虫的俗称", "菜粉蝶的幼虫阶段。"], "危害症状": ["叶片缺刻", "叶片孔洞", "整株死亡", "尤以十字花科蔬菜为害最重", "幼虫取食叶肉，二龄后蚕食叶片形成严重缺刻", "幼虫取食叶肉", "幼虫取食危害花球", "偏嗜作物", "N/A", "菜粉蝶幼虫严重危害甘蓝，导致叶片被大量取食，出现严重孔洞、缺刻，甚至仅剩下叶脉", "菜粉蝶幼虫取食甘蓝叶片", "菜粉蝶幼虫大量取食甘蓝叶片", "取食叶肉，造成孔洞、缺刻，严重时整株死亡", "偏嗜十字花科蔬菜，尤以厚叶类着卵量大", "偏嗜十字花科蔬菜", "菜粉蝶幼虫取食危害甘蓝叶片", "幼虫取食叶片导致孔洞，排泄物污染球茎并引发病害", "菜粉蝶危害后可能引发软腐病", "菜粉蝶危害后可能引发黑腐病", "幼虫期取食叶片，造成孔洞、缺刻", "菜粉蝶幼虫取食甘蓝叶片导致", "菜粉蝶幼虫取食甘蓝叶片，严重影响产量", "菜粉蝶幼虫取食叶片", "菜粉蝶危害可诱发软腐病", "菜粉蝶危害可诱发黑腐病", "食叶啃食叶肉", "菜粉蝶幼虫严重危害大白菜", "菜粉蝶幼虫取食叶片导致表皮残留及叶脉裸露", "啃食叶肉", "菜粉蝶幼虫取食小白菜叶片", "幼虫啃食叶片导致缺刻和穿孔", "幼虫取食叶片造成危害"], "防治要点": ["利用防虫网育苗，防止产卵", "在幼虫孵化盛期至三龄幼虫前进行"], "形态特征": ["越冬形态", "呈纺锤形，具有棱角，颜色多变，具有保护色", "菜粉蝶蛹的外观特征"], "生活习性": ["菜粉蝶的越冬形态", "菜粉蝶以蛹态在寄主残体、篱笆、树干或杂草间度过寒冬"]}</data><data key="d9">{"别名": [{"chunk": "", "file": "", "page": ""}, {"chunk": "chunk-561a951e4deb74888f3eb64e5e201ff8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-749648f3569db2742acde22e0ccdc771", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-7b829618261d91ae767ed1131698e3a8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "危害症状": [{"chunk": "chunk-602d37fbdad3894f3fd097dec446048d", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-c6a1c58572667dcaf6731aaf90b72d08", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-e28b536983c09a8a7efed8f351c99c0f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-46edfbd3a10ec757b7c4b4f77709b9d3", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-849b03cd52bb68264d62993a59d36141", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-d5261c75c7e2eb3b9a74271f3ff4e048", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-79b786f538ba9110de2adfd6e57c7618", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-6c358d7727d47fb774fde79b593cdb64", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-749648f3569db2742acde22e0ccdc771", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-a5dd5082aa7c0708134d0e024eeb5f52", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-eb133807de2ff915d9cd628148148023", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "防治要点": [{"chunk": "chunk-c6a1c58572667dcaf6731aaf90b72d08", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-46edfbd3a10ec757b7c4b4f77709b9d3", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-c6a1c58572667dcaf6731aaf90b72d08", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-d5261c75c7e2eb3b9a74271f3ff4e048", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-eb133807de2ff915d9cd628148148023", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-46edfbd3a10ec757b7c4b4f77709b9d3", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-849b03cd52bb68264d62993a59d36141", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="菜粉蝶前期蛹"><data key="d0">菜粉蝶前期蛹</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了十字花科蔬菜重要害虫菜粉蝶的蛹（前期）形态。该蛹呈纺锤形，青绿色，体背具3条纵脊，固定于叶片表面。菜粉蝶幼虫（菜青虫）主要危害甘蓝、白菜等蔬菜，该阶段是其生命周期的重要环节。</data><data key="d3">chunk-eb133807de2ff915d9cd628148148023</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜粉蝶卵"><data key="d0">菜粉蝶卵</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了菜粉蝶（鳞翅目粉蝶科）的卵期形态。菜粉蝶是十字花科蔬菜（如甘蓝、白菜等）的重要害虫，其卵呈枪弹形，初产淡黄色后变橙黄色，表面具纵横隆起线，多散产于叶片表面。</data><data key="d3">chunk-79b786f538ba9110de2adfd6e57c7618</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜粉蝶幼虫危害大白菜叶片症状"><data key="d0">菜粉蝶幼虫危害大白菜叶片症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了菜粉蝶（菜青虫）幼虫对大白菜的典型危害，表现为幼虫大量啃食叶肉，造成叶片出现大量孔洞、缺刻，最终仅剩下叶脉，属于严重的农业害虫取食症状。</data><data key="d3">chunk-749648f3569db2742acde22e0ccdc771</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜粉蝶幼虫危害小白菜"><data key="d0">菜粉蝶幼虫危害小白菜</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了菜粉蝶幼虫（菜青虫）取食小白菜叶片的典型危害症状。幼虫啃食造成叶片孔洞和缺刻，并伴有排泄物污染，属于十字花科蔬菜的主要虫害。</data><data key="d3">chunk-a5dd5082aa7c0708134d0e024eeb5f52</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜粉蝶幼虫危害状"><data key="d0">菜粉蝶幼虫危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示菜粉蝶（菜青虫）低龄幼虫在受害叶片上取食，叶片可见明显的孔洞和啃食痕迹。菜青虫是十字花科蔬菜的重要害虫，主要危害甘蓝、花椰菜等，造成叶片损伤，并可能引发软腐病、黑腐病。防治适期以一至二龄幼虫期为佳，可选用生物源杀虫剂如多杀霉素、苏云金杆菌等。</data><data key="d3">chunk-d19d7e947c23393542da83f9bbf10b07</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜粉蝶幼虫危害甘蓝"><data key="d0">菜粉蝶幼虫危害甘蓝</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甘蓝遭受菜粉蝶幼虫（菜青虫）严重危害后的形态。受害叶片布满孔洞、缺刻，部分仅剩叶脉。该虫害偏嗜十字花科蔬菜，取食伤口易诱发软腐病及黑腐病。</data><data key="d3">chunk-6c358d7727d47fb774fde79b593cdb64</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜粉蝶幼虫危害甘蓝症状"><data key="d0">菜粉蝶幼虫危害甘蓝症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示甘蓝受到菜粉蝶幼虫严重取食，叶片出现大量孔洞、缺刻，甚至仅剩下叶脉，属于典型的菜青虫危害特征。</data><data key="d3">chunk-e28b536983c09a8a7efed8f351c99c0f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜粉蝶幼虫危害花椰菜"><data key="d0">菜粉蝶幼虫危害花椰菜</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示菜粉蝶幼虫严重危害花椰菜，导致叶片被啃食殆尽，仅剩叶脉。上下文描述了菜青虫的危害症状、生活习性、发生时期及防治方法，并提及可能引发软腐病、黑腐病。</data><data key="d3">chunk-46edfbd3a10ec757b7c4b4f77709b9d3</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜粉蝶幼虫危害花椰菜花球"><data key="d0">菜粉蝶幼虫危害花椰菜花球</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片显示菜粉蝶幼虫危害花椰菜花球，导致花球受损、污染。菜粉蝶幼虫啃食花椰菜叶肉和叶片，排出粪便污染球茎，并可能引发软腐病和黑腐病。防治措施包括使用防虫网和幼虫期药剂防治。</data><data key="d3">chunk-c6a1c58572667dcaf6731aaf90b72d08</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜粉蝶成虫"><data key="d0">菜粉蝶成虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了菜粉蝶（鳞翅目粉蝶科）的成虫形态，该虫是十字花科蔬菜（如甘蓝、白菜等）的重要害虫。其幼虫俗称菜青虫，主要通过啃食叶片导致作物缺刻、整株死亡，并可能间接引发蔬菜软腐病和黑腐病。</data><data key="d3">chunk-602d37fbdad3894f3fd097dec446048d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜粉蝶成虫交尾"><data key="d0">菜粉蝶成虫交尾</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示菜粉蝶成虫在菜叶上进行交尾，并伴有散落的卵。菜粉蝶（又称菜青虫幼虫）是十字花科蔬菜的重要害虫，会啃食叶肉、蚕食叶片，严重时可导致植株死亡，并因粪便污染和伤口引发软腐病、黑腐病。</data><data key="d3">chunk-561a951e4deb74888f3eb64e5e201ff8</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜粉蝶蛹形态"><data key="d0">菜粉蝶蛹形态</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了菜粉蝶不同时期的蛹，呈纺锤形且具棱角，属于十字花科蔬菜主要害虫菜粉蝶的越冬形态。该虫以蛹在残枝落叶或树干上越冬，幼虫期对甘蓝、花椰菜、白菜等危害严重。</data><data key="d3">chunk-d5261c75c7e2eb3b9a74271f3ff4e048</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜粉蝶蛹形态及寄生特征"><data key="d0">菜粉蝶蛹形态及寄生特征</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了菜粉蝶（菜青虫成虫）的蛹期形态。该害虫主要危害甘蓝、花椰菜等十字花科蔬菜，幼虫取食叶片导致孔洞与缺刻，最终化蛹越冬，是十字花科蔬菜的重要害虫。</data><data key="d3">chunk-849b03cd52bb68264d62993a59d36141</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜粉蝶高龄幼虫及其危害状"><data key="d0">菜粉蝶高龄幼虫及其危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示菜粉蝶高龄幼虫及其在十字花科蔬菜叶片上造成的孔洞和缺刻，上下文详细描述了菜粉蝶（菜青虫）的形态特征、危害症状及其寄主范围，指出其可导致花椰菜球茎污染并引起软腐病、黑腐病。</data><data key="d3">chunk-7b829618261d91ae767ed1131698e3a8</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜苗"><data key="d0">菜苗</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-fa81a0bde62d00db67e3f78217464e36</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461416</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜苗根部"><data key="d0">菜苗根部</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-e65169eeb2407bedfb7e356dc1bbf1f8</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461409</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜薹"><data key="d0">菜薹</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2711af80087a36171089b13436581425&lt;SEP&gt;chunk-3e38741d2bfbf032bfe7da65cf5c9302&lt;SEP&gt;chunk-2102c4977ee2662531b474addbf76d25&lt;SEP&gt;chunk-2f12138e59db2f07225a36a367d035a7&lt;SEP&gt;chunk-2d0a0e1a2ae281c246d32fd566f9339f&lt;SEP&gt;chunk-b3b74e94cd9e673214401f1d7e211970&lt;SEP&gt;chunk-dc8f89ad08f02a366bb1855964931b0b&lt;SEP&gt;chunk-ea3ad9de087ca853f6d9c25a2d2681c9&lt;SEP&gt;chunk-157bd3addbb38750d6dff95f3d5a9e7d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461175</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜蚜"><data key="d0">菜蚜</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-bff12f56d0df62b0fd2dbb213026b0d6&lt;SEP&gt;chunk-16e53f221a8aaf862ba107b114abcab2&lt;SEP&gt;chunk-27d0171243706f7c20a06c9a73190c96&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461438</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["吸食汁液导致失水", "吸食汁液导致", "N/A", "危害嫩茎、花梗、嫩荚导致", "危害嫩茎、花梗、嫩荚导致，或种株不能结实", "严重时影响大白菜、甘蓝", "严重时不能结球", "群集吸食汁液", "吸食叶片汁液"], "生活习性": ["群集并吸食汁液", "分泌蜜露"], "形态特征": ["菜蚜的形态特征"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-27d0171243706f7c20a06c9a73190c96", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-86fe0a0dce4f7819d35523a45e7fd62e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-86fe0a0dce4f7819d35523a45e7fd62e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-86fe0a0dce4f7819d35523a45e7fd62e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="菜蚜成虫及其蜕皮"><data key="d0">菜蚜成虫及其蜕皮</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了菜蚜的形态特征，结合上下文，菜蚜（包括甘蓝蚜、萝卜蚜、桃蚜）是十字花科蔬菜的主要害虫，可危害多种作物，造成卷缩变形、生长不良、分泌蜜露诱发煤污病并传播病毒病。</data><data key="d3">chunk-86fe0a0dce4f7819d35523a45e7fd62e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜蛾科"><data key="d0">菜蛾科</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-371895d9884598c227a071fa676687e0&lt;SEP&gt;chunk-0a5a383f7804eaab55ca250a8c04eac7&lt;SEP&gt;chunk-bf5f3b0e979a7287d55994f336876320&lt;SEP&gt;chunk-18a956ecf95a9b8ddabc1b9fe91aa320&lt;SEP&gt;chunk-1fbfc726dd296f1ec43ce2aa9f0d0895&lt;SEP&gt;chunk-dee1c0cb2d3ac680561c4257ac355a14</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461228</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜螟"><data key="d0">菜螟</data><data key="d1">虫害</data><data key="d10" /><data key="d2">鳞翅目螟蛾科钻蛀性害虫，幼虫蛀食心叶及茎部。&lt;SEP&gt;N/A&lt;SEP&gt;钻蛀性害虫，一年发生3-9代&lt;SEP&gt;钻蛀性害虫</data><data key="d3">chunk-2de1784a101a3d8331d829acf538c9e1&lt;SEP&gt;chunk-c60631811c47de4ce2c79aee52951117&lt;SEP&gt;chunk-cdc75a846424d224be95bef5e748659b&lt;SEP&gt;chunk-89fd1a92fac060bd5bcd453db48be5bb&lt;SEP&gt;chunk-cef0a38360a3e2500cb25e1f6f777a8f&lt;SEP&gt;chunk-adaeb6ba455cbb00a27118e9da2ccaca&lt;SEP&gt;chunk-844030a4d8a6de0ccf527992172d7166&lt;SEP&gt;chunk-16950d1361b65e692bd4c9c79222ad0e&lt;SEP&gt;chunk-3420d79a9e5621d0c5a78a59239be5b5</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461275</data><data key="d6" /><data key="d7">菜心野螟&lt;SEP&gt;萝卜螟&lt;SEP&gt;甘蓝螟&lt;SEP&gt;钻心虫&lt;SEP&gt;白菜螟</data><data key="d8">{"别名": ["萝卜螟", "钻心虫", "白菜螟", "菜心野螟", "甘蓝螟", "N/A"], "防治要点": ["防虫网育苗", "春耕灭茬", "利用防虫网育苗防止产卵", "N/A", "药剂防治"], "危害症状": ["N/A", "蛀食心叶", "蛀食心叶及叶片", "蛀入茎髓", "主要危害十字花科蔬菜，尤以白菜受害较重", "主要危害十字花科蔬菜，尤以甘蓝受害较重", "主要危害十字花科蔬菜，尤以萝卜受害较重", "幼虫蛀食心叶导致心叶枯死", "菜螟幼虫主要危害方式", "菜螟啃食心叶后的症状", "严重危害后的后果", "菜螟幼虫严重危害萝卜", "菜螟幼虫排出的潮湿虫粪", "三龄菜螟幼虫食害心叶导致", "幼苗期受菜螟危害导致", "甘蓝和大白菜受菜螟危害后不能结球", "甘蓝和大白菜受菜螟危害后不能包心", "菜螟主要危害萝卜", "菜螟主要危害白菜", "菜螟主要危害甘蓝", "菜螟主要危害菠菜", "菜螟幼虫阶段危害植物的心叶", "菜螟幼虫阶段危害植物的叶片", "菜螟幼虫阶段危害植物的茎髓", "菜螟幼虫阶段危害植物的根部", "主要危害萝卜", "主要危害白菜", "主要危害甘蓝", "主要危害芥菜", "主要危害菠菜"], "形态特征": ["菜螟成虫体色特征"], "发生时期": ["菜螟幼虫危害期", "菜螟危害较重时期", "菜螟在长江中下游地区危害最重时期"]}</data><data key="d9">{"别名": [{"chunk": "", "file": "", "page": ""}, {"chunk": "chunk-89fd1a92fac060bd5bcd453db48be5bb", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "防治要点": [{"chunk": "chunk-cdc75a846424d224be95bef5e748659b", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-89fd1a92fac060bd5bcd453db48be5bb", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-844030a4d8a6de0ccf527992172d7166", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-16950d1361b65e692bd4c9c79222ad0e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-3420d79a9e5621d0c5a78a59239be5b5", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "危害症状": [{"chunk": "chunk-cdc75a846424d224be95bef5e748659b", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-89fd1a92fac060bd5bcd453db48be5bb", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-cef0a38360a3e2500cb25e1f6f777a8f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-adaeb6ba455cbb00a27118e9da2ccaca", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-844030a4d8a6de0ccf527992172d7166", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-16950d1361b65e692bd4c9c79222ad0e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-3420d79a9e5621d0c5a78a59239be5b5", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-cef0a38360a3e2500cb25e1f6f777a8f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-844030a4d8a6de0ccf527992172d7166", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="菜螟对萝卜心叶的危害"><data key="d0">菜螟对萝卜心叶的危害</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了鳞翅目螟蛾科害虫菜螟的幼虫对萝卜心叶的危害状。菜螟是一种钻蛀性害虫，幼虫通过蛀食作物生长点，造成心叶枯死及缺苗断垄，是十字花科蔬菜的重要威胁。</data><data key="d3">chunk-adaeb6ba455cbb00a27118e9da2ccaca</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜螟幼虫"><data key="d0">菜螟幼虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示菜螟幼虫在十字花科蔬菜叶片上。菜螟幼虫为淡黄绿色，背部有褐色背线，属于鳞翅目螟蛾科，是钻蛀性害虫，危害甘蓝、白菜等作物的心叶和叶片，并可传播软腐病。防治方法包括防虫网育苗和药剂喷施。</data><data key="d3">chunk-89fd1a92fac060bd5bcd453db48be5bb</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜螟幼虫危害芥菜图片"><data key="d0">菜螟幼虫危害芥菜图片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示菜螟幼虫对芥菜的危害症状，包括植株萎蔫、心叶及叶片被蛀食枯死。菜螟属鳞翅目螟蛾科，是一种钻蛀性害虫，主要危害十字花科植物的幼苗期，幼虫危害期为5-11月。防治方法包括使用防虫网、农业措施及多种化学药剂交替使用，施药时需喷到心叶。</data><data key="d3">chunk-cdc75a846424d224be95bef5e748659b</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜螟幼虫危害萝卜叶片"><data key="d0">菜螟幼虫危害萝卜叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示菜螟幼虫对萝卜叶片造成的危害症状，表现为叶片啃食和孔洞。菜螟属鳞翅目螟蛾科，是钻蛀性害虫，主要危害十字花科植物如萝卜，可导致植株生长受阻甚至死亡。其幼虫危害期为5-11月，防治方法包括农业防治和多种药剂喷施。</data><data key="d3">chunk-16950d1361b65e692bd4c9c79222ad0e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜螟幼虫危害萝卜心叶"><data key="d0">菜螟幼虫危害萝卜心叶</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示菜螟幼虫危害萝卜心叶的症状，包括蛀孔和虫粪。菜螟是鳞翅目螟蛾科的钻蛀性害虫，主要危害萝卜等十字花科蔬菜，其幼虫阶段在心叶、茎髓和根部钻蛀，并排出潮湿虫粪，秋季危害较重。</data><data key="d3">chunk-844030a4d8a6de0ccf527992172d7166</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜螟幼虫蛀食植物根部或茎髓的危害状"><data key="d0">菜螟幼虫蛀食植物根部或茎髓的危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示菜螟四至五龄幼虫蛀食十字花科蔬菜（如甘蓝）的根部或茎髓的危害状。可见幼虫在蛀孔中，孔外有潮湿虫粪和细丝。菜螟属鳞翅目螟蛾科，主要危害甘蓝、大白菜等作物，可导致植株死亡、不能结球包心，并传播软腐病。防治方法包括防虫网育苗和幼虫孵化盛期前的药剂防治。</data><data key="d3">chunk-3420d79a9e5621d0c5a78a59239be5b5</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜螟成虫"><data key="d0">菜螟成虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图示为十字花科蔬菜重要害虫菜螟的成虫。菜螟属鳞翅目螟蛾科，是一种钻蛀性害虫，主要危害甘蓝、白菜、萝卜等作物。成虫体色呈灰褐色或黄褐色，具有典型的小型蛾类特征，其幼虫期通过蛀食心叶或茎髓造成严重减产。</data><data key="d3">chunk-cef0a38360a3e2500cb25e1f6f777a8f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜青虫"><data key="d0">菜青虫</data><data key="d1">虫害</data><data key="d10" /><data key="d2">鳞翅目粉蝶科害虫，幼虫取食叶片，严重时仅剩叶脉。&lt;SEP&gt;N/A&lt;SEP&gt;菜粉蝶的幼虫，体青绿色，圆筒形。&lt;SEP&gt;菜粉蝶的幼虫，体青绿色，圆筒形，有细毛和黄斑</data><data key="d3">chunk-c60631811c47de4ce2c79aee52951117&lt;SEP&gt;chunk-6853819bd6c24f5f2236d760b9ce81b1&lt;SEP&gt;chunk-2102c4977ee2662531b474addbf76d25&lt;SEP&gt;chunk-06c4679ebf4de0a8d8224fbb2924294f&lt;SEP&gt;chunk-9de6c623c37e6db5374f7045b110ca10&lt;SEP&gt;chunk-561a951e4deb74888f3eb64e5e201ff8&lt;SEP&gt;chunk-6c9c5c1a89394df08c4521777314cc90&lt;SEP&gt;chunk-d19d7e947c23393542da83f9bbf10b07&lt;SEP&gt;chunk-3b4748e1b515b1d16d492a54b7db5d2c&lt;SEP&gt;chunk-79e13eb4c78335551c4fba9ead91efa8&lt;SEP&gt;chunk-3a78e3281e5a0bbc179d412851f35c67</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461186</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["菜青虫取食花椰菜球茎造成孔洞和残缺", "N/A", "菜青虫排泄物造成叶片粪便污染", "菜青虫危害甘蓝", "菜青虫取食甘蓝叶片", "取食造成伤口"], "发生时期": ["一至二龄幼虫期"], "形态特征": ["菜青虫形态呈长圆柱形", "N/A"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-9de6c623c37e6db5374f7045b110ca10", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-561a951e4deb74888f3eb64e5e201ff8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-d19d7e947c23393542da83f9bbf10b07", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-79e13eb4c78335551c4fba9ead91efa8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-3a78e3281e5a0bbc179d412851f35c67", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-d19d7e947c23393542da83f9bbf10b07", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-79e13eb4c78335551c4fba9ead91efa8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="菜青虫危害甘蓝叶片"><data key="d0">菜青虫危害甘蓝叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了菜青虫在甘蓝叶片上的取食危害。菜青虫幼虫取食叶片导致孔洞和缺刻，并留下粪便污染。结合上下文，菜青虫偏嗜甘蓝、花椰菜等十字花科蔬菜，严重时可致全株死亡并引发软腐病等次生灾害。</data><data key="d3">chunk-79e13eb4c78335551c4fba9ead91efa8</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菜青虫危害花椰菜及次生病害状"><data key="d0">菜青虫危害花椰菜及次生病害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了菜青虫取食花椰菜球茎造成的危害状，包括虫孔、缺刻及粪便污染，这些受损部位是软腐病和黑腐病病原菌入侵的媒介。</data><data key="d3">chunk-9de6c623c37e6db5374f7045b110ca10</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="菠菜"><data key="d0">菠菜</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-c60631811c47de4ce2c79aee52951117&lt;SEP&gt;chunk-089405484f7cef39ff9ff4354d1da054&lt;SEP&gt;chunk-64d7ba16672b09ea0136eba5fdbd5a11&lt;SEP&gt;chunk-ba83ee149a2e9cfe2bb3186d3d9ab242&lt;SEP&gt;chunk-89fd1a92fac060bd5bcd453db48be5bb&lt;SEP&gt;chunk-844030a4d8a6de0ccf527992172d7166&lt;SEP&gt;chunk-7847dba0e850b38d58d9919ba3f5cced&lt;SEP&gt;chunk-16950d1361b65e692bd4c9c79222ad0e&lt;SEP&gt;chunk-2547199e178a3bea51166c4da34b5890&lt;SEP&gt;chunk-3420d79a9e5621d0c5a78a59239be5b5</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461244</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜"><data key="d0">萝卜</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2711af80087a36171089b13436581425&lt;SEP&gt;chunk-3511fba3b1d9eaeca88fc9aca1dc1364&lt;SEP&gt;chunk-3e38741d2bfbf032bfe7da65cf5c9302&lt;SEP&gt;chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-c60631811c47de4ce2c79aee52951117&lt;SEP&gt;chunk-eb8e40732cd0b5a7f534922a7ccb9a6e&lt;SEP&gt;chunk-6853819bd6c24f5f2236d760b9ce81b1&lt;SEP&gt;chunk-38bab4e2c085cbd981e991eb6f9a8e92&lt;SEP&gt;chunk-2102c4977ee2662531b474addbf76d25&lt;SEP&gt;chunk-e1ffc4d7126b3916ef88c8c7f5b1a921&lt;SEP&gt;chunk-ce8ce757d0c4c5e0d3389af1fd809ffd&lt;SEP&gt;chunk-089405484f7cef39ff9ff4354d1da054&lt;SEP&gt;chunk-039c414821a18ac99777ef473c4c3eeb&lt;SEP&gt;chunk-371895d9884598c227a071fa676687e0&lt;SEP&gt;chunk-0b5f294b1c97f35cb02b8c5e97a080e9&lt;SEP&gt;chunk-681e040359f2c6112ca35860a588dd88&lt;SEP&gt;chunk-2f12138e59db2f07225a36a367d035a7&lt;SEP&gt;chunk-06c4679ebf4de0a8d8224fbb2924294f&lt;SEP&gt;chunk-8192d6faa31a6aed18c83a92fd0d4cf8&lt;SEP&gt;chunk-28f88298e7316c3aca7aa7d3f9c8e8ea&lt;SEP&gt;chunk-ef7c86c3b8fca183e497fd0fbf4641af&lt;SEP&gt;chunk-bcba7bdeba2b73eee2708a05dfc354f1&lt;SEP&gt;chunk-aa89e13f2be5973d8335d6cc12cf7a4e&lt;SEP&gt;chunk-ba83ee149a2e9cfe2bb3186d3d9ab242&lt;SEP&gt;chunk-602d37fbdad3894f3fd097dec446048d&lt;SEP&gt;chunk-eb63d9a76b5e16b54b440b97c0ede0f6&lt;SEP&gt;chunk-b2571a6903393e420ef4698741a914b5&lt;SEP&gt;chunk-c6a1c58572667dcaf6731aaf90b72d08&lt;SEP&gt;chunk-a2c2df663a5b98f657d14e99fafd7203&lt;SEP&gt;chunk-d6e6792e62bbd9174e8ddc2dce3c4772&lt;SEP&gt;chunk-e822b0b36bac4b88d32cca85f26cc962&lt;SEP&gt;chunk-89fd1a92fac060bd5bcd453db48be5bb&lt;SEP&gt;chunk-188d592ff3cff56c600d114b41953556&lt;SEP&gt;chunk-6a566dac6682579a8b7ab6c46552d839&lt;SEP&gt;chunk-1e49bf5ab12c0677321337f83c38fe0a&lt;SEP&gt;chunk-cef0a38360a3e2500cb25e1f6f777a8f&lt;SEP&gt;chunk-80be34d2e662ee0076c2d8809df4d115&lt;SEP&gt;chunk-e8205ad3103ca3b9c1fb9f98d9584a03&lt;SEP&gt;chunk-b7d37dbe266253071f05692384eaf7ec&lt;SEP&gt;chunk-2d0a0e1a2ae281c246d32fd566f9339f&lt;SEP&gt;chunk-adaeb6ba455cbb00a27118e9da2ccaca&lt;SEP&gt;chunk-eead98c903c9cde8f64b1d2c8dae581e&lt;SEP&gt;chunk-c18ce75a163d535e35233bd65ab46b64&lt;SEP&gt;chunk-9346c613ae16cd51d18c0d5cd2ac701d&lt;SEP&gt;chunk-b3b74e94cd9e673214401f1d7e211970&lt;SEP&gt;chunk-75c79c36d93e57136b72ac0107291bc6&lt;SEP&gt;chunk-46edfbd3a10ec757b7c4b4f77709b9d3&lt;SEP&gt;chunk-9e4557a3ad0dc9e0886fbcbc5cafce0b&lt;SEP&gt;chunk-849b03cd52bb68264d62993a59d36141&lt;SEP&gt;chunk-f78464a2c762f2ac52cce0271de908a9&lt;SEP&gt;chunk-bf76767393a4c9d7f894571646f86f0b&lt;SEP&gt;chunk-561a951e4deb74888f3eb64e5e201ff8&lt;SEP&gt;chunk-dc8f89ad08f02a366bb1855964931b0b&lt;SEP&gt;chunk-44d22c6da1c507c187f71b1b576524ac&lt;SEP&gt;chunk-9418342574b2792109b681e7c44601ba&lt;SEP&gt;chunk-072d30697d058f37fa4825ec390d9508&lt;SEP&gt;chunk-1af2b19abb0b704d0d3c588002b68add&lt;SEP&gt;chunk-e65169eeb2407bedfb7e356dc1bbf1f8&lt;SEP&gt;chunk-844030a4d8a6de0ccf527992172d7166&lt;SEP&gt;chunk-5fb6875781846fe98e977591bb4ff5d8&lt;SEP&gt;chunk-79b786f538ba9110de2adfd6e57c7618&lt;SEP&gt;chunk-c487d47e9d94b77bc6c6185d19a45849&lt;SEP&gt;chunk-42b55ba8453375fed74e005cd3cc43ab&lt;SEP&gt;chunk-3cc56e56f38d55964222750bf971f471&lt;SEP&gt;chunk-7847dba0e850b38d58d9919ba3f5cced&lt;SEP&gt;chunk-6c9c5c1a89394df08c4521777314cc90&lt;SEP&gt;chunk-a8c5a0279a56acd1c7da03467c22284e&lt;SEP&gt;chunk-26c3f4922827d7e185440701e7ced24a&lt;SEP&gt;chunk-bff12f56d0df62b0fd2dbb213026b0d6&lt;SEP&gt;chunk-ea9349cf234838116d54e1a5e31192ff&lt;SEP&gt;chunk-16950d1361b65e692bd4c9c79222ad0e&lt;SEP&gt;chunk-eaa13fa62c2f2a3e426c1cbdefca4345&lt;SEP&gt;chunk-16e53f221a8aaf862ba107b114abcab2&lt;SEP&gt;chunk-ea3ad9de087ca853f6d9c25a2d2681c9&lt;SEP&gt;chunk-d19d7e947c23393542da83f9bbf10b07&lt;SEP&gt;chunk-763e288cfcac968157d417d58b877557&lt;SEP&gt;chunk-27d0171243706f7c20a06c9a73190c96&lt;SEP&gt;chunk-058bfcb505d4110825b3930b6eb972e2&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e&lt;SEP&gt;chunk-59c5bccd07c65bb2d4ee85c5819dd9d1&lt;SEP&gt;chunk-4fab5ac32aa4dad18361b99b22fbb787&lt;SEP&gt;chunk-f5668c202430163cc5097604a98058ed&lt;SEP&gt;chunk-53ffdfc1690d5fc090735c408283391d&lt;SEP&gt;chunk-27f4d26b6bcac38bc856a64138d3baf7&lt;SEP&gt;chunk-25a870883e30ca4e4e260db153e16de6&lt;SEP&gt;chunk-8fcdba800e6f311738dd69c3bb11fcc6&lt;SEP&gt;chunk-2547199e178a3bea51166c4da34b5890&lt;SEP&gt;chunk-157bd3addbb38750d6dff95f3d5a9e7d&lt;SEP&gt;chunk-ef48529f2f981dcb2797307e782efe92&lt;SEP&gt;chunk-06d7e433fa06c5b25d419262c858c6bb&lt;SEP&gt;chunk-3b4748e1b515b1d16d492a54b7db5d2c&lt;SEP&gt;chunk-4f0db3eb8e47b1168869ce73699eacd2&lt;SEP&gt;chunk-eeed8e4c5d0d1c051facb662f75d1e09&lt;SEP&gt;chunk-7b829618261d91ae767ed1131698e3a8&lt;SEP&gt;chunk-1b21560a97097ef8c782850de81e35aa&lt;SEP&gt;chunk-3420d79a9e5621d0c5a78a59239be5b5&lt;SEP&gt;chunk-45612c9b15be60c04ace7e86ca47be4c&lt;SEP&gt;chunk-c41e49bf19f4a71064df3d77eebfb411</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461167</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜根结线虫病症状"><data key="d0">萝卜根结线虫病症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了萝卜根结线虫病的典型症状，表现为萝卜侧根和须根出现褐色瘤状根结，严重影响萝卜根系健康及正常生长。</data><data key="d3">chunk-9346c613ae16cd51d18c0d5cd2ac701d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜根结线虫病症状图"><data key="d0">萝卜根结线虫病症状图</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了萝卜根结线虫病的典型症状，表现为须根和侧根上产生的瘤状根结。该病害主要影响萝卜的地下部，导致根系畸形，严重时影响地上植株生长，防治措施包括轮作、翻耕晒田及淹水处理。</data><data key="d3">chunk-ef7c86c3b8fca183e497fd0fbf4641af</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜炭疽病后期症状"><data key="d0">萝卜炭疽病后期症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了萝卜炭疽病后期的典型症状，主要表现为叶柄和叶片上出现凹陷的纺锤形或梭形褐色病斑，病斑中心呈灰白色且易发生穿孔。该病害主要通过病残体或种子传播，高温高湿环境易诱发。</data><data key="d3">chunk-53ffdfc1690d5fc090735c408283391d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜炭疽病早期症状"><data key="d0">萝卜炭疽病早期症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了萝卜炭疽病的早期症状，主要表现为叶脉和叶柄上的褐色、梭形凹陷病斑。该病害在高湿高温环境下易发，需通过轮作、种子处理及喷施多菌灵、代森锰锌等药剂进行防治。</data><data key="d3">chunk-eeed8e4c5d0d1c051facb662f75d1e09</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜猿叶甲危害状"><data key="d0">萝卜猿叶甲危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了萝卜受小猿叶甲或大猿叶甲幼虫危害后的症状。受害萝卜根部可见明显黑斑、蛀痕及隧道，严重时导致腐烂。该害虫隶属鞘翅目叶甲科，主要通过幼虫在土中蛀食菜根，且易传播软腐病。</data><data key="d3">chunk-b7d37dbe266253071f05692384eaf7ec</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜病毒病症状"><data key="d0">萝卜病毒病症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了萝卜感染病毒病后的典型症状，表现为叶片出现深浅绿相间的花叶斑驳、叶片皱缩及沿叶脉的耳状突起。病毒病主要通过蚜虫传播，在十字花科蔬菜上普遍发生，严重影响植株生长。</data><data key="d3">chunk-7847dba0e850b38d58d9919ba3f5cced</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜病毒病症状图"><data key="d0">萝卜病毒病症状图</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示萝卜病毒病症状，叶片花叶斑驳、叶绿素不均、皱缩，沿叶脉有耳状突起。该病由蚜虫传播，幼苗期易感，春、秋季为发病盛期。防治方法包括农业管理和使用盐酸吗啉呱、氨基寡糖素等药剂。</data><data key="d3">chunk-ba83ee149a2e9cfe2bb3186d3d9ab242</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜缺硼症状"><data key="d0">萝卜缺硼症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了萝卜缺硼导致的典型症状：肉质根内部组织水渍状坏死，并伴随中心裂开形成孔洞，属十字花科蔬菜生理性缺素病害。</data><data key="d3">chunk-27f4d26b6bcac38bc856a64138d3baf7</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜蚜"><data key="d0">萝卜蚜</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;又称菜缢管蚜</data><data key="d3">chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-bf35b6fe615bb837008bfcf5197afb12&lt;SEP&gt;chunk-9418342574b2792109b681e7c44601ba&lt;SEP&gt;chunk-1af2b19abb0b704d0d3c588002b68add&lt;SEP&gt;chunk-bff12f56d0df62b0fd2dbb213026b0d6&lt;SEP&gt;chunk-16e53f221a8aaf862ba107b114abcab2&lt;SEP&gt;chunk-27d0171243706f7c20a06c9a73190c96&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e&lt;SEP&gt;chunk-2547199e178a3bea51166c4da34b5890</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461400</data><data key="d6" /><data key="d7">菜缢管蚜</data><data key="d8">{"别名": ["菜缢管蚜"], "危害症状": ["萝卜蚜危害芥菜", "N/A", "萝卜蚜主要危害萝卜", "萝卜蚜主要危害白菜", "主要危害"], "发生时期": ["N/A"]}</data><data key="d9">{"别名": [{"chunk": "", "file": "", "page": ""}, {"chunk": "chunk-2547199e178a3bea51166c4da34b5890", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "危害症状": [{"chunk": "chunk-9418342574b2792109b681e7c44601ba", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-bff12f56d0df62b0fd2dbb213026b0d6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-16e53f221a8aaf862ba107b114abcab2", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-27d0171243706f7c20a06c9a73190c96", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-86fe0a0dce4f7819d35523a45e7fd62e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-2547199e178a3bea51166c4da34b5890", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-2547199e178a3bea51166c4da34b5890", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="萝卜蚜危害芥菜叶片"><data key="d0">萝卜蚜危害芥菜叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示芥菜叶片和茎部遭受萝卜蚜虫严重侵害，叶片上聚集大量蚜虫，部分叶片有穿孔和变色。上下文补充了蚜虫（如萝卜蚜）导致植株生长不良、畸形、诱发煤污病和传播病毒病的危害症状。同时提供了蚜虫的发生时期、生活习性、农业防治、物理防治及多种药剂防治方法。此外，上下文还提及黄曲条跳甲对十字花科蔬菜的危害及形态特征。</data><data key="d3">chunk-9418342574b2792109b681e7c44601ba</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜蚜成虫"><data key="d0">萝卜蚜成虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了萝卜蚜的成虫形态，结合上下文可知萝卜蚜是菜蚜的一种，主要危害萝卜、白菜等十字花科蔬菜的幼苗、嫩叶等部位。其危害症状包括吸食汁液导致叶片卷缩变形、植株生长不良，分泌蜜露可诱发煤污病，并传播多种蔬菜病毒病。</data><data key="d3">chunk-16e53f221a8aaf862ba107b114abcab2</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜蚜若虫群集危害叶片"><data key="d0">萝卜蚜若虫群集危害叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示萝卜蚜若虫群集在作物叶片上，吸食汁液，造成叶片卷缩和植株生长不良，并分泌蜜露诱发煤污病，传播病毒病，严重影响十字花科蔬菜的生长和结实。</data><data key="d3">chunk-bff12f56d0df62b0fd2dbb213026b0d6</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜软腐病"><data key="d0">萝卜软腐病</data><data key="d1">病害</data><data key="d10" /><data key="d2">一种细菌性软腐病变，主要危害萝卜的根部、短茎、叶柄和叶片，导致组织软化腐烂并伴有臭味。</data><data key="d3">chunk-06d7e433fa06c5b25d419262c858c6bb</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461474</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["典型症状表现为油渍状褐色病斑", "典型症状表现为组织软化腐烂呈黏滑的稀泥状", "常伴有难闻臭味", "是危害萝卜的病害", "危害部位包括短茎", "危害部位包括萝卜根部", "危害部位包括叶柄", "危害部位包括叶片"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-06d7e433fa06c5b25d419262c858c6bb", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="萝卜软腐病发病症状"><data key="d0">萝卜软腐病发病症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了萝卜感染软腐病后的严重症状。受害植株的根部、短茎及叶柄基部组织出现褐色油渍状病斑，并伴随严重的软腐和黏滑稀泥状崩解，这是软腐病在十字花科作物上的典型病征。</data><data key="d3">chunk-06d7e433fa06c5b25d419262c858c6bb</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜软腐病根颈腐烂症状"><data key="d0">萝卜软腐病根颈腐烂症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示了萝卜软腐病的典型症状，病害主要发生在萝卜根颈部，表现为油渍状褐色病斑及组织软腐。该病通过伤口侵染，在高温高湿及排水不良环境下易流行，是十字花科蔬菜的主要病害之一。</data><data key="d3">chunk-aa89e13f2be5973d8335d6cc12cf7a4e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜软腐病肉质根腐烂症状"><data key="d0">萝卜软腐病肉质根腐烂症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了萝卜肉质根感染软腐病后的典型病症，表现为肉质根部黑褐色软腐、组织黏滑。该病由多种病原菌引起，常从根部伤口侵入，导致组织腐烂并散发臭味，严重影响萝卜的品质与产量。</data><data key="d3">chunk-59c5bccd07c65bb2d4ee85c5819dd9d1</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜霜霉病"><data key="d0">萝卜霜霉病</data><data key="d1">病害</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-28f88298e7316c3aca7aa7d3f9c8e8ea</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461203</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["在叶片背面或叶面形成", "不规则，可能出现在叶片上", "叶片受损导致", "圆形至多角形褪绿黄斑", "叶脉变黑", "叶片内部变褐", "N/A"], "发生时期": ["春秋两季"], "发病诱因": ["N/A"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-28f88298e7316c3aca7aa7d3f9c8e8ea", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-28f88298e7316c3aca7aa7d3f9c8e8ea", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发病诱因": [{"chunk": "chunk-28f88298e7316c3aca7aa7d3f9c8e8ea", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="萝卜霜霉病病叶背面霉层"><data key="d0">萝卜霜霉病病叶背面霉层</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了萝卜叶片感染霜霉病后的典型症状，叶片背面出现白色霉层，并伴有穿孔和黄褐色病斑，是霜霉菌侵染所致，主要发生在春秋两季。</data><data key="d3">chunk-28f88298e7316c3aca7aa7d3f9c8e8ea</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜霜霉病症状图"><data key="d0">萝卜霜霉病症状图</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图展示了萝卜霜霉病在叶片上的初期典型症状，主要表现为圆形或多角形的褪绿黄斑，由霜霉菌侵染引起，多发于春秋季温暖高湿环境。</data><data key="d3">chunk-a2c2df663a5b98f657d14e99fafd7203</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜黑腐病肉质根内部病变"><data key="d0">萝卜黑腐病肉质根内部病变</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了萝卜感染黑腐病后的典型内部症状。病原菌为野油菜黄单胞菌野油菜致病变种，导致肉质根内部维管束发黑、髓部腐烂并干腐空心，常在高温多雨条件下发生，易与软腐病复合侵染。</data><data key="d3">chunk-072d30697d058f37fa4825ec390d9508</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="萝卜黑腐病肉质根空心"><data key="d0">萝卜黑腐病肉质根空心</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片显示萝卜黑腐病的肉质根出现空心症状。黑腐病由野油菜黄单胞菌野油菜致病变种引起，主要危害萝卜等十字花科蔬菜，在近成熟期易发病。该病导致肉质根内部维管束变黑、髓部腐烂，最终形成空心。防治方法包括种子消毒、合理轮作和药剂喷洒。</data><data key="d3">chunk-6c9c5c1a89394df08c4521777314cc90</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="营养缺乏性生理病害"><data key="d0">营养缺乏性生理病害</data><data key="d1">病害</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-3804e6899c46d9421cdbc913901d17a2</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461465</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="葫芦"><data key="d0">葫芦</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-dd1cedc8d65b907a2104d9a71428b3be</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461486</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="葫芦科"><data key="d0">葫芦科</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-a6d0c51243ca209ed10575700d7d6fcb</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461250</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="蓟马"><data key="d0">蓟马</data><data key="d1">虫害</data><data key="d10" /><data key="d2">锉吸式口器害虫</data><data key="d3">chunk-27af44d21900dfe9b3475d240189015b</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461484</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["叶片表面出现的密集斑点", "由蓟马排泄物形成的黑色斑迹", "通过锉吸式口器取食造成损伤"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-27af44d21900dfe9b3475d240189015b", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="蓟马类害虫叶片危害状"><data key="d0">蓟马类害虫叶片危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了蔬菜叶片受蓟马类害虫（如棕榈蓟马）侵害后的典型症状。害虫利用锉吸式口器破坏叶片组织，导致叶面出现斑驳的褪绿斑点及黑色排泄物，严重时可造成叶片皱缩枯萎。</data><data key="d3">chunk-27af44d21900dfe9b3475d240189015b</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="蔬菜"><data key="d0">蔬菜</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-7a5b263454d8b182750b31dbe14dcdab&lt;SEP&gt;chunk-1c5a12d22cf1665308291c146f152537</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461472</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="蔬菜病毒病"><data key="d0">蔬菜病毒病</data><data key="d1">病害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;由萝卜蚜传播</data><data key="d3">chunk-bff12f56d0df62b0fd2dbb213026b0d6&lt;SEP&gt;chunk-16e53f221a8aaf862ba107b114abcab2&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461438</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="薄壁菌门"><data key="d0">薄壁菌门</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-3b4748e1b515b1d16d492a54b7db5d2c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461482</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="虫伤口"><data key="d0">虫伤口</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-3a78e3281e5a0bbc179d412851f35c67</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461483</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="虫螨腈"><data key="d0">虫螨腈</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-f9ebb1ddbe117603cd2ffff1b870e9ae</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461426</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="虫酰肼"><data key="d0">虫酰肼</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-e52bb62e077d4db1eb6c925ac4a0565e&lt;SEP&gt;chunk-f9ebb1ddbe117603cd2ffff1b870e9ae</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461389</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="虫酰肼悬浮剂"><data key="d0">虫酰肼悬浮剂</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;用于低龄幼虫防治。</data><data key="d3">chunk-ce8ce757d0c4c5e0d3389af1fd809ffd&lt;SEP&gt;chunk-114bf6ecc915ce50383e97cbb0199cc4&lt;SEP&gt;chunk-c487d47e9d94b77bc6c6185d19a45849</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461325</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="虱螨脲"><data key="d0">虱螨脲</data><data key="d1">药剂</data><data key="d10" /><data key="d2">5%乳油&lt;SEP&gt;N/A</data><data key="d3">chunk-2de1784a101a3d8331d829acf538c9e1&lt;SEP&gt;chunk-cdc75a846424d224be95bef5e748659b&lt;SEP&gt;chunk-f9ebb1ddbe117603cd2ffff1b870e9ae</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461281</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="虱螨脲乳油"><data key="d0">虱螨脲乳油</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-844030a4d8a6de0ccf527992172d7166&lt;SEP&gt;chunk-16950d1361b65e692bd4c9c79222ad0e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461410</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="蚜科"><data key="d0">蚜科</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-80aef901199e2ace7583bc4503b58d78</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461415</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="蚜虫"><data key="d0">蚜虫</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;病毒病的主要传播媒介</data><data key="d3">chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-2f12138e59db2f07225a36a367d035a7&lt;SEP&gt;chunk-06c4679ebf4de0a8d8224fbb2924294f&lt;SEP&gt;chunk-dc8f89ad08f02a366bb1855964931b0b&lt;SEP&gt;chunk-bf35b6fe615bb837008bfcf5197afb12&lt;SEP&gt;chunk-9418342574b2792109b681e7c44601ba&lt;SEP&gt;chunk-7847dba0e850b38d58d9919ba3f5cced&lt;SEP&gt;chunk-6c9c5c1a89394df08c4521777314cc90&lt;SEP&gt;chunk-26c3f4922827d7e185440701e7ced24a&lt;SEP&gt;chunk-ea9349cf234838116d54e1a5e31192ff&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e&lt;SEP&gt;chunk-2547199e178a3bea51166c4da34b5890&lt;SEP&gt;chunk-3b4748e1b515b1d16d492a54b7db5d2c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461178</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["生长不良", "N/A", "蚜虫取食部位"], "发病诱因": ["高温干旱环境有利于繁殖"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-bf35b6fe615bb837008bfcf5197afb12", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发病诱因": [{"chunk": "chunk-26c3f4922827d7e185440701e7ced24a", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="蛞蝓"><data key="d0">蛞蝓</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;又称水蜒蚰、蜒蚰、鼻涕虫，软体动物&lt;SEP&gt;又称鼻涕虫，体表暗灰色，柔软无壳。&lt;SEP&gt;体表裸露，柔软无壳，颜色多为暗灰色或黄白色，头部前端具有2对触角</data><data key="d3">chunk-a770031934dc8ae2cad68c63e907465e&lt;SEP&gt;chunk-64d7ba16672b09ea0136eba5fdbd5a11&lt;SEP&gt;chunk-b0bc9c961a2342cc54041938ca465560&lt;SEP&gt;chunk-09fc3feaf326d3fa098b21ff07275159</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461269</data><data key="d6" /><data key="d7">鼻涕虫</data><data key="d8">{"别名": ["鼻涕虫"], "危害症状": ["导致孔洞、缺刻或缺苗断垄", "常危害十字花科蔬菜", "N/A", "蛞蝓在甘蓝叶片上取食形成孔洞。", "造成叶片出现不规则孔洞和缺刻。"], "发生时期": ["田间大量活动危害期"], "生活习性": ["喜阴暗潮湿环境。"]}</data><data key="d9">{"别名": [{"chunk": "", "file": "", "page": ""}], "危害症状": [{"chunk": "chunk-b0bc9c961a2342cc54041938ca465560", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-09fc3feaf326d3fa098b21ff07275159", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-b0bc9c961a2342cc54041938ca465560", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-09fc3feaf326d3fa098b21ff07275159", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="蛞蝓危害甘蓝"><data key="d0">蛞蝓危害甘蓝</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了软体动物蛞蝓（俗称鼻涕虫）正在取食甘蓝叶片。蛞蝓属腹足纲柄眼目，常在夜间活动，利用齿舌刮食蔬菜的幼芽和叶片，导致叶片出现孔洞与缺刻，严重影响作物产量与品质。</data><data key="d3">chunk-09fc3feaf326d3fa098b21ff07275159</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="蛞蝓科"><data key="d0">蛞蝓科</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-64d7ba16672b09ea0136eba5fdbd5a11&lt;SEP&gt;chunk-b0bc9c961a2342cc54041938ca465560</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461269</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="蛞蝓（鼻涕虫"><data key="d0">蛞蝓（鼻涕虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示的是软体动物蛞蝓。蛞蝓属于腹足纲柄眼目蛞蝓科，是多种蔬菜及经济作物的害虫。其喜阴暗潮湿，通过齿舌刮食叶片造成孔洞及缺刻，严重影响作物产量。防治需结合农业防治、诱捕及四聚乙醛等化学药剂。</data><data key="d3">chunk-b0bc9c961a2342cc54041938ca465560</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="蛴螬"><data key="d0">蛴螬</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2102c4977ee2662531b474addbf76d25</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777459254</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="蛹"><data key="d0">蛹</data><data key="d1">生长期</data><data key="d10" /><data key="d2">菜粉蝶生命周期阶段，呈棕褐色，纺锤形&lt;SEP&gt;N/A&lt;SEP&gt;斜纹夜蛾发育过程中的变态阶段&lt;SEP&gt;呈黄褐色，在土壤中越冬；土温升至10°C以上时羽化。</data><data key="d3">chunk-c6a1c58572667dcaf6731aaf90b72d08&lt;SEP&gt;chunk-53e6356230579174bc1646371ab0629d&lt;SEP&gt;chunk-849b03cd52bb68264d62993a59d36141&lt;SEP&gt;chunk-25a870883e30ca4e4e260db153e16de6&lt;SEP&gt;chunk-7a5b263454d8b182750b31dbe14dcdab</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461264</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="蛹期"><data key="d0">蛹期</data><data key="d1">生长期</data><data key="d10" /><data key="d2">甜菜夜蛾的发育阶段之一</data><data key="d3">chunk-0062a028e9dff340fab151943ea14834</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461351</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="蝗科"><data key="d0">蝗科</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-ca141699f53529c2e47d2d719892c294&lt;SEP&gt;chunk-039c414821a18ac99777ef473c4c3eeb&lt;SEP&gt;chunk-5fb6875781846fe98e977591bb4ff5d8&lt;SEP&gt;chunk-3cc56e56f38d55964222750bf971f471&lt;SEP&gt;chunk-a8c5a0279a56acd1c7da03467c22284e&lt;SEP&gt;chunk-619596f56e73bbdb8f2bab5ff716984c&lt;SEP&gt;chunk-4f81aa7efe24d8dc3a429c05163875d9&lt;SEP&gt;chunk-7ad50e2d4da052bc9fee4ea624a8528f&lt;SEP&gt;chunk-45612c9b15be60c04ace7e86ca47be4c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461413</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="蝼蛄"><data key="d0">蝼蛄</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2102c4977ee2662531b474addbf76d25</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777459253</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="螟蛾科"><data key="d0">螟蛾科</data><data key