b7b30f&lt;SEP&gt;chunk-36a0d55340470c41badc3ab815a48b11&lt;SEP&gt;chunk-e4deaf546dd3ce6cf9f4d4298a30c16c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461469</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斑驳花叶"><data key="d0">斑驳花叶</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-7847dba0e850b38d58d9919ba3f5cced&lt;SEP&gt;chunk-ea9349cf234838116d54e1a5e31192ff</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461430</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾"><data key="d0">斜纹夜蛾</data><data key="d1">虫害</data><data key="d10" /><data key="d2">Entity：斜纹夜蛾。系鳞翅目夜蛾科害虫，属于间歇性发生的暴食性、杂食性害虫，是十字花科蔬菜的主要虫害之一。该害虫具有昼伏夜出的习性，成虫具有强趋光性和趋化性，以蛹越冬。幼虫呈圆柱形，具有群集性；低龄幼虫啃食叶肉，三龄后取食叶片导致孔洞，具有极强的暴食危害特征。</data><data key="d3">chunk-2de1784a101a3d8331d829acf538c9e1&lt;SEP&gt;chunk-ce8ce757d0c4c5e0d3389af1fd809ffd&lt;SEP&gt;chunk-06c4679ebf4de0a8d8224fbb2924294f&lt;SEP&gt;chunk-815e4f7cee9742bc3e2e8fee86eeecdc&lt;SEP&gt;chunk-bc770219318b1a31007357bc8ad819d6&lt;SEP&gt;chunk-5a2a424d35c8371bfe822398161732dd&lt;SEP&gt;chunk-7a3d5184847473b74b07721739a5bfbe&lt;SEP&gt;chunk-114bf6ecc915ce50383e97cbb0199cc4&lt;SEP&gt;chunk-973dce971af31474ddd43e6e00b147f7&lt;SEP&gt;chunk-5225b33b17e8ce25a168f6df8d8215e5&lt;SEP&gt;chunk-366808974c0fcabd60213a8af86f98c2&lt;SEP&gt;chunk-70ea7481e3c4e08532f67a9abecde5f9&lt;SEP&gt;chunk-e52bb62e077d4db1eb6c925ac4a0565e&lt;SEP&gt;chunk-43efc3959ca8fe33258e06a2eb799ab5&lt;SEP&gt;chunk-0908a0340b9818d5c3d67ffd677f69df&lt;SEP&gt;chunk-22ec2d63c5447f009f8e14f909cb3d39&lt;SEP&gt;chunk-f9ebb1ddbe117603cd2ffff1b870e9ae&lt;SEP&gt;chunk-6c9c5c1a89394df08c4521777314cc90&lt;SEP&gt;chunk-bff12f56d0df62b0fd2dbb213026b0d6&lt;SEP&gt;chunk-9c20ba1706cc7ac7726050c507d30f50&lt;SEP&gt;chunk-6502c650bcc919b4a37d340e72611559&lt;SEP&gt;chunk-7a5b263454d8b182750b31dbe14dcdab&lt;SEP&gt;chunk-3b4748e1b515b1d16d492a54b7db5d2c&lt;SEP&gt;chunk-fa54432d372186232c5c9c4f49b861e9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461193</data><data key="d6" /><data key="d7">黑头虫&lt;SEP&gt;莲纹夜盗蛾&lt;SEP&gt;莲纹夜蛾&lt;SEP&gt;花虫</data><data key="d8">{"别名": ["花虫", "莲纹夜蛾", "莲纹夜盗蛾", "黑头虫", "斜纹夜蛾的别名"], "危害症状": ["叶片呈现半透明的纸状斑或天窗状受害区", "取食白菜叶片", "取食甘蓝叶片", "主要在叶片背面危害", "形成半透明的“窗纱状”斑点", "N/A", "斜纹夜蛾幼虫排泄粪便污染蔬菜，导致组织腐烂", "斜纹夜蛾幼虫危害叶片，在叶片上形成孔洞、缺刻或秃尖", "斜纹夜蛾幼虫危害嫩茎", "幼虫啃食叶肉残留表皮，形成半透明的斑状痕迹。", "斜纹夜蛾取食白菜叶片导致叶肉缺失。", "斜纹夜蛾取食甘蓝叶片。", "斜纹夜蛾主要在作物叶片上进行取食危害。", "幼虫取食叶片。", "虫害啃食后形成的孔洞状缺损", "叶肉被取食后残留叶脉的网状结构", "斜纹夜蛾通过取食叶片对甘蓝造成危害", "半透明纸状", "斜纹夜蛾幼虫啃食白菜叶片，造成叶片出现大量不规则的孔洞和严重残缺。", "斜纹夜蛾幼虫取食植物叶片。", "斜纹夜蛾取食花椰菜叶片", "斜纹夜蛾幼虫取食叶片导致孔洞或残缺", "初孵幼虫集中取食叶片表皮和叶肉形成", "斜纹夜蛾寄生并危害大白菜", "斜纹夜蛾主要危害部位为叶片", "斜纹夜蛾低龄幼虫啃食叶肉，残留表皮，形成半透明纸状危害症状。", "斜纹夜蛾低龄幼虫啃食叶肉，残留表皮，形成“天窗”状危害症状。", "斜纹夜蛾危害白菜。", "斜纹夜蛾危害甘蓝。", "斜纹夜蛾低龄幼虫通过取食行为危害叶片。", "斜纹夜蛾低龄幼虫啃食叶肉。", "斜纹夜蛾低龄幼虫造成表皮残留。", "主要危害", "取食叶片导致孔洞和缺刻", "大龄幼虫取食叶片形成的损害", "叶片边缘被啃食后的缺损", "幼虫取食叶片造成伤害", "斜纹夜蛾取食十字花科蔬菜叶片组织", "取食导致叶片产生孔洞、缺刻", "幼虫阶段危害大白菜叶片与嫩茎"], "发病诱因": ["有利于斜纹夜蛾发生。", "喜高温干旱环境"], "形态特征": ["馒头状，块产，表面覆盖有灰黄色或棕黄色的疏松绒毛", "头部黑褐色，背线、亚背线及气门下线呈灰黄色或橙色，从中胸至第九腹节有近似三角形的黑斑。", "体表呈深褐色，长纺锤形，具有明显的节状腹部特征", "体长呈圆筒形，深褐色至黑褐色，表面有光泽，腹部有节状结构"], "防治要点": ["灯光诱杀", "防虫网覆盖", "诱杀成虫"], "生活习性": ["初孵幼虫具有群集危害的特点", "斜纹夜蛾低龄幼虫具有群集取食习性。", "N/A"]}</data><data key="d9">{"别名": [{"chunk": "", "file": "", "page": ""}, {"chunk": "chunk-2de1784a101a3d8331d829acf538c9e1", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "危害症状": [{"chunk": "chunk-815e4f7cee9742bc3e2e8fee86eeecdc", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-bc770219318b1a31007357bc8ad819d6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-5a2a424d35c8371bfe822398161732dd", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-7a3d5184847473b74b07721739a5bfbe", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-114bf6ecc915ce50383e97cbb0199cc4", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-973dce971af31474ddd43e6e00b147f7", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-5225b33b17e8ce25a168f6df8d8215e5", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-366808974c0fcabd60213a8af86f98c2", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-70ea7481e3c4e08532f67a9abecde5f9", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-e52bb62e077d4db1eb6c925ac4a0565e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-43efc3959ca8fe33258e06a2eb799ab5", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-0908a0340b9818d5c3d67ffd677f69df", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-22ec2d63c5447f009f8e14f909cb3d39", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-f9ebb1ddbe117603cd2ffff1b870e9ae", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-9c20ba1706cc7ac7726050c507d30f50", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-6502c650bcc919b4a37d340e72611559", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-7a5b263454d8b182750b31dbe14dcdab", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-fa54432d372186232c5c9c4f49b861e9", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发病诱因": [{"chunk": "chunk-114bf6ecc915ce50383e97cbb0199cc4", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-e52bb62e077d4db1eb6c925ac4a0565e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-366808974c0fcabd60213a8af86f98c2", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-22ec2d63c5447f009f8e14f909cb3d39", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-7a5b263454d8b182750b31dbe14dcdab", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-fa54432d372186232c5c9c4f49b861e9", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "防治要点": [{"chunk": "chunk-e52bb62e077d4db1eb6c925ac4a0565e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-f9ebb1ddbe117603cd2ffff1b870e9ae", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-43efc3959ca8fe33258e06a2eb799ab5", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-0908a0340b9818d5c3d67ffd677f69df", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-22ec2d63c5447f009f8e14f909cb3d39", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="斜纹夜蛾低龄幼虫危害状"><data key="d0">斜纹夜蛾低龄幼虫危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了斜纹夜蛾低龄幼虫在蔬菜叶片上的群集危害状。斜纹夜蛾属鳞翅目夜蛾科，其低龄幼虫有群集取食叶肉、残留叶片表皮形成“天窗”状斑点的典型特征。</data><data key="d3">chunk-0908a0340b9818d5c3d67ffd677f69df</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾初孵幼虫危害蔬菜叶片"><data key="d0">斜纹夜蛾初孵幼虫危害蔬菜叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了斜纹夜蛾初孵幼虫在蔬菜叶片上的群集危害状。初孵幼虫具有群集性，取食叶片组织导致叶面出现斑驳的受害痕迹，是斜纹夜蛾生命周期中早期的典型危害阶段。</data><data key="d3">chunk-43efc3959ca8fe33258e06a2eb799ab5</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾初孵幼虫群集危害叶片"><data key="d0">斜纹夜蛾初孵幼虫群集危害叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了斜纹夜蛾（鳞翅目夜蛾科）初孵幼虫在蔬菜叶片背面的群集取食症状，表现为叶肉被啃食后的半透明纸状斑点（“天窗”），这是斜纹夜蛾幼虫期典型的危害特征。</data><data key="d3">chunk-815e4f7cee9742bc3e2e8fee86eeecdc</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾危害甘蓝"><data key="d0">斜纹夜蛾危害甘蓝</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了斜纹夜蛾对十字花科作物甘蓝的严重危害。斜纹夜蛾幼虫取食甘蓝叶片，造成叶片大量孔洞、缺刻，形成网状结构。该害虫具有强趋光性和趋化性，喜在植株叶片背面产卵，低龄幼虫群集取食，严重影响叶片光合作用与植株发育。</data><data key="d3">chunk-973dce971af31474ddd43e6e00b147f7</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾危害花椰菜"><data key="d0">斜纹夜蛾危害花椰菜</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了十字花科蔬菜花椰菜受斜纹夜蛾幼虫危害后的症状。幼虫通过取食叶片导致叶肉残缺、枯萎，严重影响作物生长。防治建议在卵孵高峰至低龄幼虫期施用虫酰肼、氯虫苯甲酰胺等药剂，或配合灯光诱杀与物理防虫。</data><data key="d3">chunk-e52bb62e077d4db1eb6c925ac4a0565e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾卵块"><data key="d0">斜纹夜蛾卵块</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了斜纹夜蛾的卵块形态，其特征为馒头状块产，表面覆盖灰黄色绒毛。斜纹夜蛾属于鳞翅目夜蛾科，是一种危害白菜、甘蓝等多种作物的暴食性害虫。</data><data key="d3">chunk-366808974c0fcabd60213a8af86f98c2</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾对十字花科蔬菜叶片的危害"><data key="d0">斜纹夜蛾对十字花科蔬菜叶片的危害</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了十字花科蔬菜叶片受斜纹夜蛾低龄幼虫危害后的典型症状。叶片表面因幼虫取食形成了多个不规则的孔洞和缺刻，属于虫害发生初期的典型外部形态表现。</data><data key="d3">chunk-6502c650bcc919b4a37d340e72611559</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾幼虫危害十字花科蔬菜叶片"><data key="d0">斜纹夜蛾幼虫危害十字花科蔬菜叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示斜纹夜蛾幼虫在十字花科蔬菜叶片上取食，造成孔洞。上下文描述其为十字花科蔬菜重要害虫，幼虫四龄后进入暴食期，主要危害叶片、嫩茎，导致叶片残缺、污染腐烂。</data><data key="d3">chunk-5a2a424d35c8371bfe822398161732dd</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾幼虫危害状"><data key="d0">斜纹夜蛾幼虫危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图示为斜纹夜蛾幼虫及其在蔬菜叶片上的危害状。斜纹夜蛾属鳞翅目夜蛾科，是杂食性暴食害虫，主要以幼虫啃食白菜、甘蓝等作物的叶片和嫩茎，严重时可将叶片吃光仅留主脉。</data><data key="d3">chunk-22ec2d63c5447f009f8e14f909cb3d39</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾幼虫危害症状"><data key="d0">斜纹夜蛾幼虫危害症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">斜纹夜蛾（鳞翅目夜蛾科）的低龄幼虫在蔬菜叶片背面集群取食，啃食叶肉，仅留表皮与叶脉，形成特征性的半透明斑块，是该虫害发生初期的典型危害症状。</data><data key="d3">chunk-bc770219318b1a31007357bc8ad819d6</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾幼虫危害白菜"><data key="d0">斜纹夜蛾幼虫危害白菜</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示斜纹夜蛾幼虫在白菜叶片上取食，造成叶片受损。结合上下文，斜纹夜蛾属鳞翅目夜蛾科，主要在夏秋季发生。防治方法包括在卵孵高峰至低龄幼虫盛发期施用虫酰肼、氟虫脲等多种农药，并可使用黑光灯、糖醋液、性诱剂诱杀成虫。</data><data key="d3">chunk-f9ebb1ddbe117603cd2ffff1b870e9ae</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾幼虫危害白菜叶片图"><data key="d0">斜纹夜蛾幼虫危害白菜叶片图</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片显示斜纹夜蛾幼虫对白菜叶片造成严重危害，叶片几乎被吃光。结合上下文，斜纹夜蛾属鳞翅目夜蛾科害虫，主要在夏秋季发生，通过物理、生物及化学药剂等多重措施进行防治。</data><data key="d3">chunk-114bf6ecc915ce50383e97cbb0199cc4</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾幼虫危害白菜的叶片症状"><data key="d0">斜纹夜蛾幼虫危害白菜的叶片症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示斜纹夜蛾幼虫严重危害白菜叶片，造成叶面出现大量不规则孔洞和残缺。结合上下文，斜纹夜蛾幼虫昼伏夜出，常在夏秋季大发生。</data><data key="d3">chunk-70ea7481e3c4e08532f67a9abecde5f9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾幼虫及其危害状"><data key="d0">斜纹夜蛾幼虫及其危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了斜纹夜蛾幼虫在蔬菜叶片上的危害特征。斜纹夜蛾幼虫为杂食性暴食害虫，三龄前群集取食叶肉，仅留表皮，在叶片上形成典型的半透明“天窗”状受害症状。</data><data key="d3">chunk-7a3d5184847473b74b07721739a5bfbe</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾成虫"><data key="d0">斜纹夜蛾成虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示斜纹夜蛾成虫，该虫属鳞翅目夜蛾科，是重要的暴食性、杂食性害虫。其幼虫危害多种作物，如白菜、甘蓝、芋、莲藕和豆类，主要咬食叶片、花蕾、花及果实，导致植物受损甚至死亡。</data><data key="d3">chunk-5225b33b17e8ce25a168f6df8d8215e5</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="斜纹夜蛾蛹"><data key="d0">斜纹夜蛾蛹</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了斜纹夜蛾的蛹态。斜纹夜蛾幼虫在蔬菜上危害严重，会导致叶片缺刻、孔洞乃至被食光。图中显示的蛹为鳞翅目害虫生命周期的重要阶段，是防治决策中识别种群发育进度及预测发生危害的关键指标。</data><data key="d3">chunk-7a5b263454d8b182750b31dbe14dcdab</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="新梢"><data key="d0">新梢</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-16e53f221a8aaf862ba107b114abcab2&lt;SEP&gt;chunk-27d0171243706f7c20a06c9a73190c96&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461443</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="旋花科植物"><data key="d0">旋花科植物</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-4f81aa7efe24d8dc3a429c05163875d9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461447</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="早晨"><data key="d0">早晨</data><data key="d1">时间</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-75c79c36d93e57136b72ac0107291bc6</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461384</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="春季"><data key="d0">春季</data><data key="d1">时间</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-188d592ff3cff56c600d114b41953556&lt;SEP&gt;chunk-75c79c36d93e57136b72ac0107291bc6&lt;SEP&gt;chunk-ca8792ea559d74a7290ea6ef526fb64f&lt;SEP&gt;chunk-eaa13fa62c2f2a3e426c1cbdefca4345&lt;SEP&gt;chunk-763e288cfcac968157d417d58b877557&lt;SEP&gt;chunk-8fcdba800e6f311738dd69c3bb11fcc6&lt;SEP&gt;chunk-157bd3addbb38750d6dff95f3d5a9e7d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461296</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="春季4-6月"><data key="d0">春季4-6月</data><data key="d1">时间</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-dc8f89ad08f02a366bb1855964931b0b</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461391</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="春秋两季"><data key="d0">春秋两季</data><data key="d1">时间</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-a2c2df663a5b98f657d14e99fafd7203&lt;SEP&gt;chunk-b468b01feae03bbeb095bda274f22463&lt;SEP&gt;chunk-b519def7c9178c12ba0037aaa6c70926&lt;SEP&gt;chunk-32ddbaf2dc6854d70cd0231ee3b7b30f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461265</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="春秋季"><data key="d0">春秋季</data><data key="d1">时间</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-75c79c36d93e57136b72ac0107291bc6</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461382</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="春雷·氧氯铜"><data key="d0">春雷·氧氯铜</data><data key="d1">药剂</data>