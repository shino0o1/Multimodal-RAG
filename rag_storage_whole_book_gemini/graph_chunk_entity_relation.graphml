6da1c507c187f71b1b576524ac&lt;SEP&gt;chunk-c4cd38a417063b510b68314037e37d36&lt;SEP&gt;chunk-9d28819c3c65f9923e36642ce9a3523a&lt;SEP&gt;chunk-65e7d10e9f2456c50b8dbadf28624a5c&lt;SEP&gt;chunk-ad92b8e85bbcae6b658a4192d32c4bf3&lt;SEP&gt;chunk-026760796995a178eb1fdad1452f8328&lt;SEP&gt;chunk-1af2b19abb0b704d0d3c588002b68add&lt;SEP&gt;chunk-d14744286afe2dc35a5324b596629f4a&lt;SEP&gt;chunk-e65169eeb2407bedfb7e356dc1bbf1f8&lt;SEP&gt;chunk-844030a4d8a6de0ccf527992172d7166&lt;SEP&gt;chunk-5fb6875781846fe98e977591bb4ff5d8&lt;SEP&gt;chunk-79b786f538ba9110de2adfd6e57c7618&lt;SEP&gt;chunk-0908a0340b9818d5c3d67ffd677f69df&lt;SEP&gt;chunk-c487d47e9d94b77bc6c6185d19a45849&lt;SEP&gt;chunk-bc9b6417cac748ed25b95faf0a0e98f7&lt;SEP&gt;chunk-22ec2d63c5447f009f8e14f909cb3d39&lt;SEP&gt;chunk-3cc56e56f38d55964222750bf971f471&lt;SEP&gt;chunk-f9ebb1ddbe117603cd2ffff1b870e9ae&lt;SEP&gt;chunk-a8c5a0279a56acd1c7da03467c22284e&lt;SEP&gt;chunk-bff12f56d0df62b0fd2dbb213026b0d6&lt;SEP&gt;chunk-16950d1361b65e692bd4c9c79222ad0e&lt;SEP&gt;chunk-eaa13fa62c2f2a3e426c1cbdefca4345&lt;SEP&gt;chunk-16e53f221a8aaf862ba107b114abcab2&lt;SEP&gt;chunk-ea3ad9de087ca853f6d9c25a2d2681c9&lt;SEP&gt;chunk-d19d7e947c23393542da83f9bbf10b07&lt;SEP&gt;chunk-338fab7f749dc818d827561a47088f1b&lt;SEP&gt;chunk-763e288cfcac968157d417d58b877557&lt;SEP&gt;chunk-b64d931a1bdfddeeb19bd5ec9fcbfae8&lt;SEP&gt;chunk-27d0171243706f7c20a06c9a73190c96&lt;SEP&gt;chunk-0ed5436bf3fb965fbbc7838cf37929b3&lt;SEP&gt;chunk-058bfcb505d4110825b3930b6eb972e2&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e&lt;SEP&gt;chunk-dee1c0cb2d3ac680561c4257ac355a14&lt;SEP&gt;chunk-4fab5ac32aa4dad18361b99b22fbb787&lt;SEP&gt;chunk-f5668c202430163cc5097604a98058ed&lt;SEP&gt;chunk-7ad50e2d4da052bc9fee4ea624a8528f&lt;SEP&gt;chunk-25a870883e30ca4e4e260db153e16de6&lt;SEP&gt;chunk-8fcdba800e6f311738dd69c3bb11fcc6&lt;SEP&gt;chunk-32ddbaf2dc6854d70cd0231ee3b7b30f&lt;SEP&gt;chunk-2547199e178a3bea51166c4da34b5890&lt;SEP&gt;chunk-36f6674cb148459751e16cae91330c2a&lt;SEP&gt;chunk-3b4748e1b515b1d16d492a54b7db5d2c&lt;SEP&gt;chunk-4f0db3eb8e47b1168869ce73699eacd2&lt;SEP&gt;chunk-7b829618261d91ae767ed1131698e3a8&lt;SEP&gt;chunk-1b21560a97097ef8c782850de81e35aa&lt;SEP&gt;chunk-79b765b62eb3bc05922343d1d04cdc1e&lt;SEP&gt;chunk-45612c9b15be60c04ace7e86ca47be4c&lt;SEP&gt;chunk-5713aed0d0a400cd226ef28e0c1fd823&lt;SEP&gt;chunk-c41e49bf19f4a71064df3d77eebfb411&lt;SEP&gt;chunk-dd1cedc8d65b907a2104d9a71428b3be</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461167</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白菜根肿病"><data key="d0">白菜根肿病</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了白菜根肿病的典型危害症状，病株根部形成肿瘤。该病由芸薹根肿菌引起，主要危害十字花科蔬菜，通过土壤传播，导致病株生长矮小、萎蔫，严重时造成植株腐烂及死亡。</data><data key="d3">chunk-36f6674cb148459751e16cae91330c2a</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白菜根肿病肿瘤"><data key="d0">白菜根肿病肿瘤</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了白菜根肿病的典型危害症状，病原为芸薹根肿菌。表现为根部形成不规则的肿瘤状膨大，导致植株地上部生长矮小，是十字花科蔬菜生产中的毁灭性病害。</data><data key="d3">chunk-a7e0d5451f4240ce6759c07058e2a43a</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白菜根肿病苗期症状"><data key="d0">白菜根肿病苗期症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了白菜苗期遭受根肿病侵染的典型症状。病原菌芸薹根肿菌侵染白菜根部后，产生畸形膨大的肿瘤，影响根系发育，进而导致地上部生长迟缓、萎蔫，严重时整株枯死。</data><data key="d3">chunk-6df8b3d8e37b5acf17dde5acff612916</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白菜灰霉病病叶图片"><data key="d0">白菜灰霉病病叶图片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示白菜叶片感染灰霉病的典型症状，病部呈褐色腐烂状。白菜灰霉病是十字花科蔬菜常见病害，在苗期和成株期均可发生，病部初期呈水渍状，后转为褐色或淡红褐色腐烂，表面产生灰色霉层，并形成黑色菌核。</data><data key="d3">chunk-026760796995a178eb1fdad1452f8328</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白菜炭疽病"><data key="d0">白菜炭疽病</data><data key="d1">病害</data><data key="d10">image</data><data key="d2">该图为白菜炭疽病在叶片及叶柄上的危害症状。炭疽病属于十字花科蔬菜常见病害，典型症状为叶脉及叶柄处出现凹陷的纺锤形深褐色病斑，严重时可导致叶片枯死。防治需结合种子处理、轮作及发病初期药剂喷施（如代森锰锌、咪鲜胺等）。&lt;SEP&gt;N/A</data><data key="d3">chunk-3f0f7765f756333466fa2628944fb928</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461357</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["严重时会导致叶片黄化", "N/A", "白菜炭疽病主要危害叶片", "白菜炭疽病主要危害叶柄"], "发病诱因": ["N/A", "高温高湿利于病害流行"], "防治要点": ["播种前可用多菌灵进行种子处理", "发病初期可选用代森锰锌防治", "发病初期可选用咪鲜胺防治"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-3f0f7765f756333466fa2628944fb928", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发病诱因": [{"chunk": "chunk-3f0f7765f756333466fa2628944fb928", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "防治要点": [{"chunk": "chunk-3f0f7765f756333466fa2628944fb928", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="白菜炭疽病前期症状"><data key="d0">白菜炭疽病前期症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图示为白菜炭疽病发病前期症状，主要侵害叶片和叶柄，表现为水渍状小斑点。该病由病原菌通过种子或病残体传播，在高温高湿条件下流行。防治需采取轮作、种子消毒及发病初期喷施代森锰锌或咪鲜胺等药剂。</data><data key="d3">chunk-7db27298b6bc94a19de9bdb6c76b2710</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白菜炭疽病叶柄危害症状"><data key="d0">白菜炭疽病叶柄危害症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示了白菜受炭疽病侵害的症状，表现为叶柄上出现严重的深褐色凹陷条状病斑，这是十字花科蔬菜炭疽病的典型危害特征。</data><data key="d3">chunk-65e7d10e9f2456c50b8dbadf28624a5c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白菜炭疽病叶柄症状"><data key="d0">白菜炭疽病叶柄症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">本图展示了白菜炭疽病在叶柄上的典型危害症状，表现为长圆形、深褐色边缘、中间灰白且凹陷的病斑，这是十字花科蔬菜炭疽病识别的重要形态特征。</data><data key="d3">chunk-b2571a6903393e420ef4698741a914b5</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白菜炭疽病病斑融合症状"><data key="d0">白菜炭疽病病斑融合症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">展示了白菜炭疽病严重受害后的典型症状，表现为叶片上病斑相互融合形成大块不规则斑块，导致叶片早枯，是该病害诊断的重要特征。</data><data key="d3">chunk-79b765b62eb3bc05922343d1d04cdc1e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白菜炭疽病症状"><data key="d0">白菜炭疽病症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图展示了白菜炭疽病的典型症状：叶片上产生大量灰白色水渍状病斑，伴有中心穿孔，属于十字花科蔬菜炭疽病的急性期表现。</data><data key="d3">chunk-338fab7f749dc818d827561a47088f1b</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白菜类植物"><data key="d0">白菜类植物</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-ba83ee149a2e9cfe2bb3186d3d9ab242</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461242</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白菜黑斑病叶片症状图"><data key="d0">白菜黑斑病叶片症状图</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图显示白菜黑斑病的严重发病症状。叶片上可见近圆形灰褐色病斑，周围有黄色晕圈，中间有同心轮纹，且部分叶片枯死。上下文指出黑斑病由芸薹链格孢引起，主要危害十字花科蔬菜，春秋两季高湿易发，可采取轮作、种子处理及药剂防治。</data><data key="d3">chunk-8fcdba800e6f311738dd69c3bb11fcc6</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白菜黑斑病症状图"><data key="d0">白菜黑斑病症状图</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示白菜叶片感染黑斑病的典型症状，表现为近圆形灰褐色斑点并伴有同心轮纹。黑斑病是十字花科蔬菜的常见病害，主要危害叶片，由芸薹链格孢引起，春秋季和成株期至采收期易发，可用代森锰锌、咪鲜胺、苯醚甲环唑等多种杀菌剂防治。</data><data key="d3">chunk-763e288cfcac968157d417d58b877557</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白锈病"><data key="d0">白锈病</data><data key="d1">病害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;由病菌孢子堆(疱斑)引起的病害，影响叶片、花器及茎部。&lt;SEP&gt;一种由病原菌引起的植物病害，表现为叶片黄绿色斑点及叶背疱状孢子堆。</data><data key="d3">chunk-089405484f7cef39ff9ff4354d1da054&lt;SEP&gt;chunk-eb894f19e22eaf5521b51aa84906c1b0&lt;SEP&gt;chunk-1253e4088f4e8d0960f2a2d0bb84f70d&lt;SEP&gt;chunk-26fa9146248963fad99265989a109245&lt;SEP&gt;chunk-634971419f68bfb00f83f83d9668f2fc&lt;SEP&gt;chunk-075bb3ace2dfb45f097400200194fa09</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461173</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["发病初期在叶片正面形成的病变斑块。", "叶片表面隆起的疱状结构。", "白锈病主要危害白菜。", "三月青易感白锈病。", "叶背产生白色疱斑，成熟后破裂散出白色粉末状孢子囊。", "白锈病危害小白菜。", "病菌的孢子堆，初期表面光滑，成熟后表皮破裂，散出白色粉末状孢子囊。", "白锈病主要危害三月青。", "N/A", "叶背可见乳白色疱斑(孢子堆)，随病情发展疱斑表皮破裂，散出白色粉末状物", "病害严重时导致叶片枯黄", "白锈病主要危害小白菜", "白锈病主要危害植株叶片", "表现为隆起的白色或乳白色疱斑，又称孢子堆，成熟后表皮破裂散出白色粉末状孢子囊。"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-eb894f19e22eaf5521b51aa84906c1b0", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-1253e4088f4e8d0960f2a2d0bb84f70d", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-26fa9146248963fad99265989a109245", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-634971419f68bfb00f83f83d9668f2fc", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-075bb3ace2dfb45f097400200194fa09", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="白锈病病原菌"><data key="d0">白锈病病原菌</data><data key="d1">病原菌</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-26fa9146248963fad99265989a109245</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461317</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白锈菌"><data key="d0">白锈菌</data><data key="d1">病原菌</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-075bb3ace2dfb45f097400200194fa09</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461482</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="百合"><data key="d0">百合</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-64d7ba16672b09ea0136eba5fdbd5a11</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777459293</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="盐酸吗啉呱"><data key="d0">盐酸吗啉呱</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2102c4977ee2662531b474addbf76d25&lt;SEP&gt;chunk-ba83ee149a2e9cfe2bb3186d3d9ab242&lt;SEP&gt;chunk-ea9349cf234838116d54e1a5e31192ff</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461244</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="盐酸吗啉呱可湿性粉剂"><data key="d0">盐酸吗啉呱可湿性粉剂</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2f12138e59db2f07225a36a367d035a7</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461179</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="直翅目"><data key="d0">直翅目</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-ca141699f53529c2e47d2d719892c294&lt;SEP&gt;chunk-039c414821a18ac99777ef473c4c3eeb&lt;SEP&gt;chunk-5fb6875781846fe98e977591bb4ff5d8&lt;SEP&gt;chunk-3cc56e56f38d55964222750bf971f471&lt;SEP&gt;chunk-a8c5a0279a56acd1c7da03467c22284e&lt;SEP&gt;chunk-619596f56e73bbdb8f2bab5ff716984c&lt;SEP&gt;chunk-4f81aa7efe24d8dc3a429c05163875d9&lt;SEP&gt;chunk-7ad50e2d4da052bc9fee4ea624a8528f&lt;SEP&gt;chunk-45612c9b15be60c04ace7e86ca47be4c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461412</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="短茎"><data key="d0">短茎</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-06d7e433fa06c5b25d419262c858c6bb</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461475</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="短额负蝗"><data key="d0">短额负蝗</data><data key="d1">虫害</data><data key="d10" /><data key="d2">属直翅目蝗科，别名中华负蝗、尖头蚱蜢，以卵越冬。&lt;SEP&gt;成虫体色有绿色或褐色，头尖削，头额前冲，体表有浅黄色瘤状突起&lt;SEP&gt;一种危害十字花科蔬菜的直翅目昆虫。&lt;SEP&gt;N/A</data><data key="d3">chunk-039c414821a18ac99777ef473c4c3eeb&lt;SEP&gt;chunk-5fb6875781846fe98e977591bb4ff5d8&lt;SEP&gt;chunk-3cc56e56f38d55964222750bf971f471&lt;SEP&gt;chunk-a8c5a0279a56acd1c7da03467c22284e&lt;SEP&gt;chunk-45612c9b15be60c04ace7e86ca47be4c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461412</data><data key="d6" /><data key="d7">中华负蝗&lt;SEP&gt;尖头蚱蜢</data><data key="d8">{"别名": ["中华负蝗", "尖头蚱蜢"], "危害症状": ["取食叶片导致", "取食叶片", "N/A", "取食造成缺刻", "危害作物叶片", "主要危害部位", "叶片被取食后形成的边缘缺损症状。", "取食叶片导致缺刻。"], "形态特征": ["短额负蝗若虫的体色", "翅芽由发育不全过渡到发育健全", "短额负蝗成虫与若虫的口器类型"], "生活习性": ["喜群集在田埂、地边、渠旁取食杂草嫩叶", "短额负蝗若虫的习性", "以卵在沟边土壤中越冬", "初孵若虫在田埂、地头集中"], "发生时期": ["短额负蝗卵的孵化盛期"], "防治要点": ["利用初孵若虫集中习性进行", "物理铲除杂草破坏越冬环境"]}</data><data key="d9">{"别名": [{"chunk": "", "file": "", "page": ""}, {"chunk": "chunk-039c414821a18ac99777ef473c4c3eeb", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "危害症状": [{"chunk": "chunk-5fb6875781846fe98e977591bb4ff5d8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-3cc56e56f38d55964222750bf971f471", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-a8c5a0279a56acd1c7da03467c22284e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-45612c9b15be60c04ace7e86ca47be4c", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-5fb6875781846fe98e977591bb4ff5d8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-5fb6875781846fe98e977591bb4ff5d8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-5fb6875781846fe98e977591bb4ff5d8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "防治要点": [{"chunk": "chunk-5fb6875781846fe98e977591bb4ff5d8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="短额负蝗危害十字花科植物叶片缺刻"><data key="d0">短额负蝗危害十字花科植物叶片缺刻</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示短额负蝗（若虫和成虫）在十字花科植物叶片上取食，造成叶片出现大量缺刻状损伤。该害虫属于直翅目蝗科，主要危害多种蔬菜，尤其是十字花科植物。</data><data key="d3">chunk-45612c9b15be60c04ace7e86ca47be4c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="短额负蝗成虫在叶片上"><data key="d0">短额负蝗成虫在叶片上</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了绿色的短额负蝗成虫在蔬菜叶片上的形态。短额负蝗属直翅目蝗科，别名中华负蝗、尖头蚱蜢，主要危害多种蔬菜、水稻等作物，成虫和若虫取食叶片，造成缺刻，并可传播细菌性软腐病。其特征是头尖削，体色绿色，与环境融为一体。</data><data key="d3">chunk-a8c5a0279a56acd1c7da03467c22284e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="短额负蝗若虫（蝗蛹"><data key="d0">短额负蝗若虫（蝗蛹</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图示为短额负蝗若虫（蝗蛹），属直翅目蝗科。其体色草绿色，主要危害白菜、甘蓝等十字花科蔬菜，造成叶片缺刻或残缺。防治应抓好初孵若虫在田埂、渠旁集中取食的时期进行喷药治理或铲除杂草。</data><data key="d3">chunk-5fb6875781846fe98e977591bb4ff5d8</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="石块下"><data key="d0">石块下</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-36a0d55340470c41badc3ab815a48b11</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461480</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="硫酸铜钙"><data key="d0">硫酸铜钙</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2711af80087a36171089b13436581425&lt;SEP&gt;chunk-06c4679ebf4de0a8d8224fbb2924294f&lt;SEP&gt;chunk-6c9c5c1a89394df08c4521777314cc90&lt;SEP&gt;chunk-3b4748e1b515b1d16d492a54b7db5d2c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461196</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="硼肥"><data key="d0">硼肥</data><data key="d1">药剂</data><data key="d10" /><data key="d2">用于补充硼元素的肥料&lt;SEP&gt;N/A</data><data key="d3">chunk-371895d9884598c227a071fa676687e0&lt;SEP&gt;chunk-80be34d2e662ee0076c2d8809df4d115&lt;SEP&gt;chunk-60cb92949480597cbb7128e491470f18</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461341</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="磷肥"><data key="d0">磷肥</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-80be34d2e662ee0076c2d8809df4d115</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461338</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="禾本科植物"><data key="d0">禾本科植物</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-4f81aa7efe24d8dc3a429c05163875d9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461446</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="秋季"><data key="d0">秋季</data><data key="d1">时间</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-188d592ff3cff56c600d114b