10" /><data key="d2">N/A</data><data key="d3">chunk-4f81aa7efe24d8dc3a429c05163875d9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461449</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="黄单胞菌"><data key="d0">黄单胞菌</data><data key="d1">病原菌</data><data key="d10" /><data key="d2">Xanthomonas campestris pv. campestris</data><data key="d3">chunk-5713aed0d0a400cd226ef28e0c1fd823</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461486</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="黄单胞菌属"><data key="d0">黄单胞菌属</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-6c9c5c1a89394df08c4521777314cc90&lt;SEP&gt;chunk-3b4748e1b515b1d16d492a54b7db5d2c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461431</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="黄守瓜"><data key="d0">黄守瓜</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-e1ffc4d7126b3916ef88c8c7f5b1a921&lt;SEP&gt;chunk-ca141699f53529c2e47d2d719892c294&lt;SEP&gt;chunk-9d28819c3c65f9923e36642ce9a3523a&lt;SEP&gt;chunk-ef48529f2f981dcb2797307e782efe92</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461402</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["取食导致叶片出现穿孔、缺刻及残缺", "成虫取食叶片导致穿孔、缺刻", "取食行为造成的典型症状", "严重危害后果", "黄守瓜严重危害萝卜叶片", "黄守瓜通过取食导致叶片出现孔洞与残缺"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-9d28819c3c65f9923e36642ce9a3523a", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-ef48529f2f981dcb2797307e782efe92", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="黄守瓜危害萝卜叶片"><data key="d0">黄守瓜危害萝卜叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了害虫黄守瓜对十字花科作物萝卜叶片的严重取食危害，叶片表现为严重的孔洞与机械损伤。</data><data key="d3">chunk-ef48529f2f981dcb2797307e782efe92</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="黄守瓜成虫叶片危害状"><data key="d0">黄守瓜成虫叶片危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了黄守瓜成虫在十字花科蔬菜叶片上的取食危害，表现为叶片穿孔、缺刻等典型食叶性害虫受害症状。</data><data key="d3">chunk-9d28819c3c65f9923e36642ce9a3523a</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="黄曲条跳甲"><data key="d0">黄曲条跳甲</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;鞘翅目叶甲科害虫，俗称狗虱虫、跳虱，成虫具趋光、趋黄、趋绿性。&lt;SEP&gt;成虫体黑色有光泽，前胸背板及鞘翅上有许多刻点，排成纵行，鞘翅中央有一黄色曲条，后足腿节膨大。&lt;SEP&gt;一种鞘翅目叶甲科害虫&lt;SEP&gt;俗称狗虱虫、跳虱</data><data key="d3">chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-6853819bd6c24f5f2236d760b9ce81b1&lt;SEP&gt;chunk-38bab4e2c085cbd981e991eb6f9a8e92&lt;SEP&gt;chunk-2102c4977ee2662531b474addbf76d25&lt;SEP&gt;chunk-06c4679ebf4de0a8d8224fbb2924294f&lt;SEP&gt;chunk-e8205ad3103ca3b9c1fb9f98d9584a03&lt;SEP&gt;chunk-eead98c903c9cde8f64b1d2c8dae581e&lt;SEP&gt;chunk-c18ce75a163d535e35233bd65ab46b64&lt;SEP&gt;chunk-75c79c36d93e57136b72ac0107291bc6&lt;SEP&gt;chunk-9e4557a3ad0dc9e0886fbcbc5cafce0b&lt;SEP&gt;chunk-f78464a2c762f2ac52cce0271de908a9&lt;SEP&gt;chunk-9418342574b2792109b681e7c44601ba&lt;SEP&gt;chunk-1af2b19abb0b704d0d3c588002b68add&lt;SEP&gt;chunk-e65169eeb2407bedfb7e356dc1bbf1f8&lt;SEP&gt;chunk-6c9c5c1a89394df08c4521777314cc90&lt;SEP&gt;chunk-3b4748e1b515b1d16d492a54b7db5d2c&lt;SEP&gt;chunk-3a78e3281e5a0bbc179d412851f35c67</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461188</data><data key="d6" /><data key="d7">跳甲&lt;SEP&gt;狗虱虫&lt;SEP&gt;跳虱</data><data key="d8">{"别名": ["跳甲", "狗虱虫", "跳虱", "N/A"], "危害症状": ["萝卜表皮出现的黑褐色斑点", "受害后组织的坏死与腐烂现象", "黄曲条跳甲幼虫蛀食萝卜", "幼虫主要危害部位为肉质根", "黄曲条跳甲成虫咬食叶片后留下的孔洞", "黄曲条跳甲成虫咬食萝卜叶片", "黄曲条跳甲成虫取食叶片", "黄曲条跳甲成虫咬食后形成的典型症状", "严重危害时叶片仅剩叶脉", "黄曲条跳甲成虫取食萝卜", "黄曲条跳甲主要危害部位", "幼苗期受害后造成的症状", "植株受害后表现出的症状", "萝卜受害后出现的症状", "成虫阶段危害，叶片有小椭圆形孔洞，幼苗期导致整株死亡或缺苗断垄", "成虫咬食，形成小椭圆形孔洞，严重时仅剩叶脉", "幼苗期成虫吃光", "幼虫主要危害，剥食根皮或蛀入根内形成隧道", "幼虫危害导致出现黑斑并腐烂", "主害代(第五、六代)发生时期，危害重于春季", "N/A", "针对根部组织进行剥食或蛀食", "危害十字花科蔬菜", "成虫在幼苗期危害子叶", "成虫危害幼苗子叶导致", "成虫危害幼苗导致", "出现许多小椭圆形孔洞", "成虫严重危害叶片后", "生活在土中危害菜根", "幼虫危害菜根", "蛀入根内形成许多隧道", "幼虫危害根部导致", "幼虫危害菜苗根部导致", "幼虫危害萝卜后", "成虫主要行为", "成虫主要取食部位", "成虫在幼苗期危害", "幼虫主要取食部位", "幼虫危害", "取食造成伤口"], "生活习性": ["N/A"], "形态特征": ["N/A", "体黑色有光泽", "前胸背板及鞘翅有许多刻点", "鞘翅中央有一黄色曲条", "后足腿节膨大", "稍呈长圆筒形", "头部淡褐色", "胸腹部淡黄白色", "尾部稍细", "初产时淡黄色", "后变乳白色", "头部隐于前胸下面", "腹末有一对叉状突起"], "发生时期": ["越冬成虫开始活动", "越冬成虫开始产卵", "主害代(第一、二代)发生时期", "成虫在春秋季活动活跃", "成虫在夏季活动活跃", "成虫中午前后活动活跃", "成虫早晨和傍晚活动活跃"]}</data><data key="d9">{"别名": [{"chunk": "", "file": "", "page": ""}, {"chunk": "chunk-9e4557a3ad0dc9e0886fbcbc5cafce0b", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "危害症状": [{"chunk": "chunk-e8205ad3103ca3b9c1fb9f98d9584a03", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-eead98c903c9cde8f64b1d2c8dae581e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-c18ce75a163d535e35233bd65ab46b64", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-75c79c36d93e57136b72ac0107291bc6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-9e4557a3ad0dc9e0886fbcbc5cafce0b", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-f78464a2c762f2ac52cce0271de908a9", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-9418342574b2792109b681e7c44601ba", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-1af2b19abb0b704d0d3c588002b68add", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-e65169eeb2407bedfb7e356dc1bbf1f8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-3a78e3281e5a0bbc179d412851f35c67", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-75c79c36d93e57136b72ac0107291bc6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-75c79c36d93e57136b72ac0107291bc6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-e65169eeb2407bedfb7e356dc1bbf1f8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-75c79c36d93e57136b72ac0107291bc6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="黄曲条跳甲幼虫"><data key="d0">黄曲条跳甲幼虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示的是黄曲条跳甲幼虫，一种危害十字花科蔬菜的鞘翅目叶甲科害虫。幼虫主要在土中危害菜根，导致作物凋萎枯死，并可传播软腐病。其防治方法包括农业防治、土壤药剂处理及生长期叶面喷施等。</data><data key="d3">chunk-f78464a2c762f2ac52cce0271de908a9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="黄曲条跳甲幼虫对萝卜的危害症状"><data key="d0">黄曲条跳甲幼虫对萝卜的危害症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了黄曲条跳甲幼虫对萝卜肉质根的危害。幼虫蛀食根部形成隧道，并在表皮留下明显黑斑，最终导致受害部位变黑、腐烂，影响植株正常生长。</data><data key="d3">chunk-e8205ad3103ca3b9c1fb9f98d9584a03</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="黄曲条跳甲成虫危害白菜叶片"><data key="d0">黄曲条跳甲成虫危害白菜叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示白菜叶片遭受黄曲条跳甲成虫危害，叶片上布满椭圆形孔洞。黄曲条跳甲属鞘翅目叶甲科害虫，主要危害十字花科蔬菜，可传播软腐病。成虫和幼虫均可危害，其防治方法包括农业防治、土壤处理和叶面喷施多种药剂。</data><data key="d3">chunk-75c79c36d93e57136b72ac0107291bc6</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="黄曲条跳甲成虫危害萝卜叶片"><data key="d0">黄曲条跳甲成虫危害萝卜叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示黄曲条跳甲成虫对萝卜叶片的典型危害症状，叶片上布满不规则的孔洞和被啃食的痕迹。黄曲条跳甲属鞘翅目叶甲科害虫，主要危害十字花科蔬菜，成虫食叶，造成叶肉缺失，严重影响作物生长。此图可用于识别黄曲条跳甲的危害特征。</data><data key="d3">chunk-c18ce75a163d535e35233bd65ab46b64</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="黄曲条跳甲成虫危害萝卜叶片症状"><data key="d0">黄曲条跳甲成虫危害萝卜叶片症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示黄曲条跳甲成虫危害萝卜叶片的症状，可见叶片上布满小椭圆形孔洞。黄曲条跳甲属鞘翅目叶甲科，主要危害十字花科蔬菜，以成虫食叶为主，造成缺苗断垄，严重时仅剩叶脉。</data><data key="d3">chunk-eead98c903c9cde8f64b1d2c8dae581e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="黄曲条跳甲成虫图像"><data key="d0">黄曲条跳甲成虫图像</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图像展示了黄曲条跳甲成虫。黄曲条跳甲属于鞘翅目叶甲科害虫，主要危害十字花科蔬菜、茄果类、瓜类、豆类及绿叶菜类蔬菜。成虫食叶造成叶片孔洞和幼苗死亡，幼虫危害菜根导致植株凋萎枯死，并可传播软腐病。</data><data key="d3">chunk-e65169eeb2407bedfb7e356dc1bbf1f8</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="黄瓜"><data key="d0">黄瓜</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2711af80087a36171089b13436581425&lt;SEP&gt;chunk-6853819bd6c24f5f2236d760b9ce81b1&lt;SEP&gt;chunk-6a566dac6682579a8b7ab6c46552d839</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461310</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="黑光灯"><data key="d0">黑光灯</data><data key="d1">药剂</data><data key="d10" /><data key="d2">物理诱杀工具&lt;SEP&gt;诱杀成虫。</data><data key="d3">chunk-114bf6ecc915ce50383e97cbb0199cc4&lt;SEP&gt;chunk-f9ebb1ddbe117603cd2ffff1b870e9ae</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461327</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="黑斑病"><data key="d0">黑斑病</data><data key="d1">病害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;由芸薹链格孢引起的病害，常见于十字花科蔬菜。&lt;SEP&gt;一种十字花科蔬菜常见的真菌性病害&lt;SEP&gt;十字花科蔬菜常见病害，亦称黑霉病。&lt;SEP&gt;初期产生近圆形灰褐色病斑，周围伴有黄色晕圈，中间呈现明显的同心轮纹，潮湿条件下病部长出黑色霉状物，严重时导致叶片穿孔或枯死。发生规律：通过种子或病残体进行初侵染。&lt;SEP&gt;十字花科蔬菜的常见病害，由芸薹链格孢引起，主要危害白菜等作物，导致出现近圆形灰褐色斑、同心轮纹等症状。</data><data key="d3">chunk-3511fba3b1d9eaeca88fc9aca1dc1364&lt;SEP&gt;chunk-0b5f294b1c97f35cb02b8c5e97a080e9&lt;SEP&gt;chunk-b2f5833221f84317eb94ba9755b8a06b&lt;SEP&gt;chunk-eaa13fa62c2f2a3e426c1cbdefca4345&lt;SEP&gt;chunk-763e288cfcac968157d417d58b877557&lt;SEP&gt;chunk-8fcdba800e6f311738dd69c3bb11fcc6</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461421</data><data key="d6" /><data key="d7">黑霉病</data><data key="d8">{"别名": ["黑霉病", "N/A", "黑斑病的别称"], "发病诱因": ["易于黑斑病流行"], "危害症状": ["主要危害叶片", "N/A", "出现于白菜叶片上", "出现于近圆形灰褐色斑中间", "在潮湿气候条件下病部可长出", "黑斑病严重时引起", "病斑周围产生", "主要危害作物", "主要危害部位", "黑斑病主要危害部位"], "发生时期": ["8月中下旬至11月"], "防治要点": ["防治黑斑病", "用于种子处理防治黑斑病"]}</data><data key="d9">{"别名": [{"chunk": "", "file": "", "page": ""}, {"chunk": "chunk-eaa13fa62c2f2a3e426c1cbdefca4345", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-763e288cfcac968157d417d58b877557", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发病诱因": [{"chunk": "chunk-b2f5833221f84317eb94ba9755b8a06b", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "危害症状": [{"chunk": "chunk-b2f5833221f84317eb94ba9755b8a06b", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-eaa13fa62c2f2a3e426c1cbdefca4345", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-763e288cfcac968157d417d58b877557", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-8fcdba800e6f311738dd69c3bb11fcc6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-8fcdba800e6f311738dd69c3bb11fcc6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "防治要点": [{"chunk": "chunk-8fcdba800e6f311738dd69c3bb11fcc6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="黑腐病"><data key="d0">黑腐病</data><data key="d1">病害</data><data key="d10" /><data key="d2">由野油菜黄单胞菌引起的细菌性病害。&lt;SEP&gt;N/A&lt;SEP&gt;十字花科蔬菜常见细菌性病害&lt;SEP&gt;主要危害十字花科蔬菜的病害&lt;SEP&gt;常见的细菌性病害</data><data key="d3">chunk-2711af80087a36171089b13436581425&lt;SEP&gt;chunk-c60631811c47de4ce2c79aee52951117&lt;SEP&gt;chunk-0b5f294b1c97f35cb02b8c5e97a080e9&lt;SEP&gt;chunk-06c4679ebf4de0a8d8224fbb2924294f&lt;SEP&gt;chunk-602d37fbdad3894f3fd097dec446048d&lt;SEP&gt;chunk-c6a1c58572667dcaf6731aaf90b72d08&lt;SEP&gt;chunk-6a566dac6682579a8b7ab6c46552d839&lt;SEP&gt;chunk-9de6c623c37e6db5374f7045b110ca10&lt;SEP&gt;chunk-46edfbd3a10ec757b7c4b4f77709b9d3&lt;SEP&gt;chunk-11c7ba1acb88a6dd394244a5be34557e&lt;SEP&gt;chunk-e6025ee82f5cd704cdad4f40096c55dc&lt;SEP&gt;chunk-561a951e4deb74888f3eb64e5e201ff8&lt;SEP&gt;chunk-072d30697d058f37fa4825ec390d9508&lt;SEP&gt;chunk-d5261c75c7e2eb3b9a74271f3ff4e048&lt;SEP&gt;chunk-6c9c5c1a89394df08c4521777314cc90&lt;SEP&gt;chunk-6c358d7727d47fb774fde79b593cdb64&lt;SEP&gt;chunk-d19d7e947c23393542da83f9bbf10b07&lt;SEP&gt;chunk-5daed8d494fa727d409bd53e85d83c50&lt;SEP&gt;chunk-3f372dacdfcadb29be98d37273f433fd&lt;SEP&gt;chunk-17ab0a21718627faacbccb7c8da47bef&lt;SEP&gt;chunk-3b4748e1b515b1d16d492a54b7db5d2c&lt;SEP&gt;chunk-7b829618261d91ae767ed1131698e3a8&lt;SEP&gt;chunk-5713aed0d0a400cd226ef28e0c1fd823</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461182</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["N/A", "主要危害部位", "从叶缘向内扩展，形成V字形的黄褐色至灰褐色叶斑，病斑外围组织呈淡黄色，病斑内叶脉变黑褐色。", "黑腐病危害小白菜叶片", "黑腐病在叶片上形成的典型V形病斑", "黑腐病导致叶片内部叶脉变色", "黑腐病严重时的最终结果", "黑腐病危害小白菜", "黑腐病主要危害小白菜的叶片", "主要症状表现为维管束变黑", "主要症状表现为髓部腐烂", "严重时出现的症状", "病部潮湿时有黏质感", "导致萝卜肉质根内部维管束变黑、髓部腐烂，严重时组织干腐、形成空心", "导致内部维管束变黑、髓部腐烂，严重时组织干腐、形成空心", "萝卜黑腐病表现为肉质根内部维管束变黑色", "萝卜黑腐病表现为肉质根髓部腐烂", "萝卜黑腐病表现为肉质根内部组织干腐", "萝卜黑腐病导致肉质根形成空心", "萝卜黑腐病肉质根外部症状不明显", "黑腐病病部潮湿时有黏质感", "黑腐病危害萝卜", "黑腐病会导致甘蓝叶片出现V形病斑及枯死", "病害主要危害部位", "从叶缘向内扩展，病斑外围组织呈淡黄色，病斑内叶脉呈现灰褐色或黑褐色", "病害发生在叶片部位", "V形或不规则黄褐色病斑", "病斑呈现V字形向内扩展，伴有淡黄色晕圈"], "发病诱因": ["由菜青虫取食造成的机械损伤", "有利于病菌侵入与病害发生", "病原菌侵入植株的途径之一", "病原菌侵入植株的途径之一，如气孔、水孔", "黑腐病适宜发生的环境条件", "利于病菌侵入，促进发病", "高温多雨天气利于黑腐病发病", "露水天气利于黑腐病发病", "大雾天气利于黑腐病发病", "地势低洼的田块易发黑腐病", "排水不良的田块易发黑腐病", "N/A", "高温多雨季节流行", "利于黑腐病发生的发病诱因"], "发生时期": ["N/A"], "防治要点": ["黑腐病防治方法包括种子消毒", "黑腐病防治方法包括与非十字花科作物实行2～3年轮作", "黑腐病防治方法包括高畦栽培", "黑腐病防治方法包括雨后及时开沟排水", "黑腐病防治方法包括收获后清除病残体", "黑腐病防治方法包括防治小菜蛾", "黑腐病防治方法包括防治菜青虫", "黑腐病防治方法包括防治甜菜夜蛾", "黑腐病防治方法包括防治斜纹夜蛾", "黑腐病防治方法包括防治蚜虫", "黑腐病防治方法包括防治猿叶甲", "黑腐病防治方法包括防治黄曲条跳甲", "黑腐病可使用噻菌铜悬浮剂防治", "黑腐病可使用春雷·氧氯铜可湿性粉剂防治", "黑腐病可使用硫酸铜钙防治"], "别名": ["菜粉蝶的幼虫阶段。"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-06c4679ebf4de0a8d8224fbb2924294f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-11c7ba1acb88a6dd394244a5be34557e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-e6025ee82f5cd704cdad4f40096c55dc", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-072d30697d058f37fa4825ec390d9508", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-6c9c5c1a89394df08c4521777314cc90", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-5daed8d494fa727d409bd53e85d83c50", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-3f372dacdfcadb29be98d37273f433fd", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-17ab0a21718627faacbccb7c8da47bef", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-3b4748e1b515b1d16d492a54b7db5d2c", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-5713aed0d0a400cd226ef28e0c1fd823", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发病诱因": [{"chunk": "chunk-9de6c623c37e6db5374f7045b110ca10", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-11c7ba1acb88a6dd394244a5be34557e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-e6025ee82f5cd704cdad4f40096c55dc", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-072d30697d058f37fa4825ec390d9508", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-6c9c5c1a89394df08c4521777314cc90", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-3f372dacdfcadb29be98d37273f433fd", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-17ab0a21718627faacbccb7c8da47bef", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-11c7ba1acb88a6dd394244a5be34557e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-5daed8d494fa727d409bd53e85d83c50", "f