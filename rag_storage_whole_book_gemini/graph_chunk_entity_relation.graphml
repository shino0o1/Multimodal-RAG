ey="d8">{}</data><data key="d9">{}</data></node><node id="桃蚜"><data key="d0">桃蚜</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;桃蚜若虫体型微小，颜色多为黄绿色或深褐色，具有吸食植物汁液的口器，常群集于叶片背面或嫩茎部位，吸食十字花科蔬菜叶片汁液，造成叶片营养不良与卷缩；其分泌的蜜露污染蔬菜并诱发煤污病。&lt;SEP&gt;一种常见的蚜虫，常在叶片背面群集危害。</data><data key="d3">chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-bf35b6fe615bb837008bfcf5197afb12&lt;SEP&gt;chunk-9418342574b2792109b681e7c44601ba&lt;SEP&gt;chunk-1af2b19abb0b704d0d3c588002b68add&lt;SEP&gt;chunk-b07d04b001293577bf3357edee85b534&lt;SEP&gt;chunk-80aef901199e2ace7583bc4503b58d78&lt;SEP&gt;chunk-bff12f56d0df62b0fd2dbb213026b0d6&lt;SEP&gt;chunk-16e53f221a8aaf862ba107b114abcab2&lt;SEP&gt;chunk-b468b01feae03bbeb095bda274f22463&lt;SEP&gt;chunk-27d0171243706f7c20a06c9a73190c96&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e&lt;SEP&gt;chunk-2547199e178a3bea51166c4da34b5890</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461399</data><data key="d6" /><data key="d7" /><data key="d8">{"形态特征": ["N/A"], "生活习性": ["N/A"], "危害症状": ["吸食植物汁液，导致叶片萎缩和生长受阻", "桃蚜通过吸食汁液致使叶片卷缩", "桃蚜通过吸食汁液致使植株萎缩", "桃蚜群集于叶片危害大白菜，导致叶片萎缩、变形。", "桃蚜在叶片背面群集危害。", "N/A"], "别名": ["N/A"], "发生时期": ["5-6月", "10-11月"]}</data><data key="d9">{"形态特征": [{"chunk": "chunk-b07d04b001293577bf3357edee85b534", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-b07d04b001293577bf3357edee85b534", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "危害症状": [{"chunk": "chunk-b07d04b001293577bf3357edee85b534", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-80aef901199e2ace7583bc4503b58d78", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-b468b01feae03bbeb095bda274f22463", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-2547199e178a3bea51166c4da34b5890", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "别名": [{"chunk": "chunk-2547199e178a3bea51166c4da34b5890", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-2547199e178a3bea51166c4da34b5890", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="桃蚜危害大白菜叶片"><data key="d0">桃蚜危害大白菜叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示大白菜叶片受到桃蚜侵害，表现为叶片萎缩变形、被蜜露污染以及潜在的煤污病迹象。桃蚜是十字花科蔬菜的主要害虫，通过吸食汁液和传播病毒病导致植株生长不良。</data><data key="d3">chunk-b468b01feae03bbeb095bda274f22463</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="桃蚜成虫与若虫群体"><data key="d0">桃蚜成虫与若虫群体</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了桃蚜的成虫和若虫群集危害十字花科蔬菜叶片的典型症状。桃蚜作为重要的蔬菜害虫，通过吸食汁液造成叶片卷缩、萎缩，并可传播多种蔬菜病毒病。</data><data key="d3">chunk-b07d04b001293577bf3357edee85b534</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="桃蚜若虫"><data key="d0">桃蚜若虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">桃蚜是十字花科蔬菜的主要害虫，图片展示了桃蚜若虫形态。该虫通过吸食汁液导致植物发育畸形、萎缩甚至枯死，其分泌的蜜露易诱发煤污病，并能传播多种病毒病。</data><data key="d3">chunk-80aef901199e2ace7583bc4503b58d78</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="棉花"><data key="d0">棉花</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-039c414821a18ac99777ef473c4c3eeb</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777459276</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="棕榈蓟马"><data key="d0">棕榈蓟马</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;蓟马类害虫的一种&lt;SEP&gt;以锉吸式口器取食白菜心叶和嫩叶</data><data key="d3">chunk-e1ffc4d7126b3916ef88c8c7f5b1a921&lt;SEP&gt;chunk-ca141699f53529c2e47d2d719892c294&lt;SEP&gt;chunk-565c0e054586b465c48b31b170716d5b&lt;SEP&gt;chunk-d14744286afe2dc35a5324b596629f4a&lt;SEP&gt;chunk-3900bd5e92dc3ff477d7f0fabbfd0903&lt;SEP&gt;chunk-fa7d45e646da9c39534669c3a730863e&lt;SEP&gt;chunk-27af44d21900dfe9b3475d240189015b</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461387</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["受害部位出现褐色点状或片状枯斑", "叶片黄化", "叶片皱缩", "严重时导致植株凋萎", "棕榈蓟马通过锉吸式口器取食甘蓝", "N/A", "病理性形变", "以锉吸式口器取食", "取食作物叶片导致叶片出现受害痕迹", "危害症状表现为取食点引发的生理损伤", "成虫以锉吸式口器取食作物叶片"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-565c0e054586b465c48b31b170716d5b", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-d14744286afe2dc35a5324b596629f4a", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-3900bd5e92dc3ff477d7f0fabbfd0903", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-fa7d45e646da9c39534669c3a730863e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="棕榈蓟马危害叶片"><data key="d0">棕榈蓟马危害叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示了棕榈蓟马成虫在蔬菜叶片上的取食危害状，属于锉吸式口器造成的典型损伤，是该害虫在寄主叶片上活动的直接证据。</data><data key="d3">chunk-3900bd5e92dc3ff477d7f0fabbfd0903</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="棕榈蓟马危害甘蓝"><data key="d0">棕榈蓟马危害甘蓝</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甘蓝受棕榈蓟马危害后的典型症状。成虫和若虫通过锉吸式口器取食心叶，导致甘蓝叶片皱缩卷曲、黄化、干枯，严重影响植株生长。</data><data key="d3">chunk-fa7d45e646da9c39534669c3a730863e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="棕榈蓟马危害白菜症状"><data key="d0">棕榈蓟马危害白菜症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了棕榈蓟马对白菜造成的危害，表现为白菜叶片出现皱缩、卷曲的典型症状，这是由其锉吸式口器取食造成的。</data><data key="d3">chunk-d14744286afe2dc35a5324b596629f4a</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</dat