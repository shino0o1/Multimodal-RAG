&lt;SEP&gt;chunk-eaa13fa62c2f2a3e426c1cbdefca4345&lt;SEP&gt;chunk-6c358d7727d47fb774fde79b593cdb64&lt;SEP&gt;chunk-ea3ad9de087ca853f6d9c25a2d2681c9&lt;SEP&gt;chunk-b64d931a1bdfddeeb19bd5ec9fcbfae8&lt;SEP&gt;chunk-27f4d26b6bcac38bc856a64138d3baf7&lt;SEP&gt;chunk-508961555c467e211aad7fa4b893e675&lt;SEP&gt;chunk-075bb3ace2dfb45f097400200194fa09&lt;SEP&gt;chunk-e4deaf546dd3ce6cf9f4d4298a30c16c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461226</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="十字花科植物"><data key="d0">十字花科植物</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-bc9b6417cac748ed25b95faf0a0e98f7&lt;SEP&gt;chunk-4f81aa7efe24d8dc3a429c05163875d9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461418</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="十字花科蔬菜"><data key="d0">十字花科蔬菜</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">小菜蛾的主要寄主类别&lt;SEP&gt;N/A</data><data key="d3">chunk-a6d0c51243ca209ed10575700d7d6fcb&lt;SEP&gt;chunk-bf5f3b0e979a7287d55994f336876320&lt;SEP&gt;chunk-bc770219318b1a31007357bc8ad819d6&lt;SEP&gt;chunk-18a956ecf95a9b8ddabc1b9fe91aa320&lt;SEP&gt;chunk-75c79c36d93e57136b72ac0107291bc6&lt;SEP&gt;chunk-026760796995a178eb1fdad1452f8328&lt;SEP&gt;chunk-91fb27c7119bdb8a5271e5ea86d39c2b&lt;SEP&gt;chunk-42b55ba8453375fed74e005cd3cc43ab&lt;SEP&gt;chunk-aff554a7fea2b0174a3638024d446a56&lt;SEP&gt;chunk-26c3f4922827d7e185440701e7ced24a&lt;SEP&gt;chunk-b9e2160f338aa7aa8806102dd36fea49&lt;SEP&gt;chunk-763e288cfcac968157d417d58b877557&lt;SEP&gt;chunk-18ae905dc413db63df2e0fffe7cb0d9f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461249</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="十字花科蔬菜害虫大龄幼虫"><data key="d0">十字花科蔬菜害虫大龄幼虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了危害十字花科蔬菜的大龄幼虫，该虫在四龄后进入暴食期，主要取食叶片和嫩茎，造成叶片孔洞、缺刻，严重时仅留主脉呈扫帚状，且排泄物会引起组织腐烂。</data><data key="d3">chunk-aff554a7fea2b0174a3638024d446a56</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="十字花科蔬菜灰霉病叶片症状"><data key="d0">十字花科蔬菜灰霉病叶片症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了十字花科蔬菜（如甘蓝）感染灰霉病的症状，表现为叶片局部呈水渍状腐烂、变褐。结合上下文，灰霉病主要危害十字花科蔬菜苗期及成株期，病部易生灰色霉层及黑色菌核。</data><data key="d3">chunk-dd4f11020dd7238ceae19b1bc2e12e6d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="十字花科蔬菜病毒病"><data key="d0">十字花科蔬菜病毒病</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了十字花科蔬菜（如大白菜）遭受病毒病危害的症状，表现为典型的叶片花叶斑驳、皱缩畸形。该病害主要通过蚜虫传播，在幼苗期高温干旱条件下易发生，严重影响植株生长及结球。</data><data key="d3">chunk-26c3f4922827d7e185440701e7ced24a</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="十字花科蔬菜病毒病叶片皱缩与斑驳症状"><data key="d0">十字花科蔬菜病毒病叶片皱缩与斑驳症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示十字花科蔬菜（可能为萝卜）感染病毒病的叶片症状，包括皱缩、叶绿素不均及斑驳花叶。该病主要危害幼苗期作物，由蚜虫传播，可使用多种药剂进行防治。</data><data key="d3">chunk-ea9349cf234838116d54e1a5e31192ff</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="十字花科蔬菜菌核病症状图"><data key="d0">十字花科蔬菜菌核病症状图</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了十字花科蔬菜（如甘蓝）受菌核病侵害的典型症状，表现为叶球组织腐烂、霉层覆盖以及产生黑色鼠粪状菌核，是该病害在成株期的典型危害特征。</data><data key="d3">chunk-c4cd38a417063b510b68314037e37d36</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="十字花科蔬菜跳甲危害状"><data key="d0">十字花科蔬菜跳甲危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示十字花科蔬菜叶片遭受跳甲危害，呈现大量圆形孔洞和不规则缺刻，叶片千疮百孔。上下文详细描述了跳甲的形态特征、生活习性、危害高峰期、越冬地点及多种防治药剂和方法。</data><data key="d3">chunk-36a0d55340470c41badc3ab815a48b11</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="十字花科蔬菜跳甲危害状_叶片千疮百孔"><data key="d0">十字花科蔬菜跳甲危害状_叶片千疮百孔</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示十字花科蔬菜叶片被跳甲严重危害，呈现大量圆孔、千疮百孔及网状、扫把状叶脉。该害虫成虫和幼虫均食叶片，群聚危害，并污染叶片。防治药剂包括敌百虫、辛硫磷等。</data><data key="d3">chunk-e4deaf546dd3ce6cf9f4d4298a30c16c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="十字花科蔬菜黑腐病叶部症状"><data key="d0">十字花科蔬菜黑腐病叶部症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了十字花科蔬菜（如白菜、甘蓝）叶片的黑腐病症状，表现为从叶缘向内扩展的V形黄褐色病斑，具有明显的淡黄色晕圈，是该病害在成株期叶片上的典型危害特征。</data><data key="d3">chunk-5713aed0d0a400cd226ef28e0c1fd823</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="印楝素"><data key="d0">印楝素</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-eb8e40732cd0b5a7f534922a7ccb9a6e&lt;SEP&gt;chunk-9418342574b2792109b681e7c44601ba&lt;SEP&gt;chunk-1af2b19abb0b704d0d3c588002b68add&lt;SEP&gt;chunk-c41e49bf19f4a71064df3d77eebfb411</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461403</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="卵"><data key="d0">卵</data><data key="d1">生长期</data><data key="d10" /><data key="d2">菜粉蝶生命周期的阶段之一&lt;SEP&gt;N/A</data><data key="d3">chunk-c6a1c58572667dcaf6731aaf90b72d08&lt;SEP&gt;chunk-53e6356230579174bc1646371ab0629d&lt;SEP&gt;chunk-79b786f538ba9110de2adfd6e57c7618</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461264</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="卵孵盛期"><data key="d0">卵孵盛期</data><data key="d1">生长期</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-f750ab36b2f3c4736f4d211c305b36aa</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461478</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="卵孵高峰期"><data key="d0">卵孵高峰期</data><data key="d1">生长期</data><data key="d10" /><data key="d2">防治的关键时期。</data><data key="d3">chunk-114bf6ecc915ce50383e97cbb0199cc4</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461328</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="叶"><data key="d0">叶</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-dd1cedc8d65b907a2104d9a71428b3be</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461488</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="叶柄"><data key="d0">叶柄</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-3511fba3b1d9eaeca88fc9aca1dc1364&lt;SEP&gt;chunk-6853819bd6c24f5f2236d760b9ce81b1&lt;SEP&gt;chunk-b2571a6903393e420ef4698741a914b5&lt;SEP&gt;chunk-7607a348b8d39b8ae825c84727752791&lt;SEP&gt;chunk-80be34d2e662ee0076c2d8809df4d115&lt;SEP&gt;chunk-53e6356230579174bc1646371ab0629d&lt;SEP&gt;chunk-3f0f7765f756333466fa2628944fb928&lt;SEP&gt;chunk-7db27298b6bc94a19de9bdb6c76b2710&lt;SEP&gt;chunk-310884df7e9f7ec7abc03ff78374fddd&lt;SEP&gt;chunk-01866903c222f0a86217a8be58eb9aca&lt;SEP&gt;chunk-fa4fa1ff156d1b25005e299d42ec2fce&lt;SEP&gt;chunk-65e7d10e9f2456c50b8dbadf28624a5c&lt;SEP&gt;chunk-53c5eb4f63fef104b52ef1aa30f38af6&lt;SEP&gt;chunk-3432b8633ea0fc698665ef94d1ee6d37&lt;SEP&gt;chunk-a21ba0d0d4ddb7ede46cade93c561764&lt;SEP&gt;chunk-eaa13fa62c2f2a3e426c1cbdefca4345&lt;SEP&gt;chunk-763e288cfcac968157d417d58b877557&lt;SEP&gt;chunk-61e246e90bcaaf9ad1308e02f330b201&lt;SEP&gt;chunk-53ffdfc1690d5fc090735c408283391d&lt;SEP&gt;chunk-06d7e433fa06c5b25d419262c858c6bb&lt;SEP&gt;chunk-eeed8e4c5d0d1c051facb662f75d1e09&lt;SEP&gt;chunk-79b765b62eb3bc05922343d1d04cdc1e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461259</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="叶柄基部"><data key="d0">叶柄基部</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-6fad4f22632131c47ac7fa6e017c1365&lt;SEP&gt;chunk-6a566dac6682579a8b7ab6c46552d839&lt;SEP&gt;chunk-e1a25ad91df4056b23309ce4d87d098e&lt;SEP&gt;chunk-310884df7e9f7ec7abc03ff78374fddd&lt;SEP&gt;chunk-ce89c7a24c968edc3b8daaa4ee7e44ed&lt;SEP&gt;chunk-fd340e54e36fe920be68c4ac34586210</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461257</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="叶正面"><data key="d0">叶正面</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-157bd3addbb38750d6dff95f3d5a9e7d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461472</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="叶片"><data key="d0">叶片</data><data key="d1">部位</data><data key="d10" /><data key="d2">Entity：叶片。
叶片是植物进行光合作用的主要器官，也是小白菜、甘蓝等多种植物的重要器官或营养器官。
同时，叶片是多种害虫（如菜粉蝶、蓟马）的主要附着、活动、取食和产卵部位，常被害虫取食造成危害，表现为被食成圆孔或仅残余叶脉。此外，叶片也是黑斑病、白菜灰霉病等病害的主要危害部位。</data><data key="d3">chunk-3511fba3b1d9eaeca88fc9aca1dc1364&lt;SEP&gt;chunk-3e38741d2bfbf032bfe7da65cf5c9302&lt;SEP&gt;chunk-c60631811c47de4ce2c79aee52951117&lt;SEP&gt;chunk-38bab4e2c085cbd981e991eb6f9a8e92&lt;SEP&gt;chunk-2102c4977ee2662531b474addbf76d25&lt;SEP&gt;chunk-e1ffc4d7126b3916ef88c8c7f5b1a921&lt;SEP&gt;chunk-ca141699f53529c2e47d2d719892c294&lt;SEP&gt;chunk-ce8ce757d0c4c5e0d3389af1fd809ffd&lt;SEP&gt;chunk-089405484f7cef39ff9ff4354d1da054&lt;SEP&gt;chunk-039c414821a18ac99777ef473c4c3eeb&lt;SEP&gt;chunk-0f80ba997fa22a606c08224fef24a3e1&lt;SEP&gt;chunk-64d7ba16672b09ea0136eba5fdbd5a11&lt;SEP&gt;chunk-0b5f294b1c97f35cb02b8c5e97a080e9&lt;SEP&gt;chunk-681e040359f2c6112ca35860a588dd88&lt;SEP&gt;chunk-eb894f19e22eaf5521b51aa84906c1b0&lt;SEP&gt;chunk-2f12138e59db2f07225a36a367d035a7&lt;SEP&gt;chunk-06c4679ebf4de0a8d8224fbb2924294f&lt;SEP&gt;chunk-ae6ade12d6e6964fb85422f4cc485bee&lt;SEP&gt;chunk-8192d6faa31a6aed18c83a92fd0d4cf8&lt;SEP&gt;chunk-28f88298e7316c3aca7aa7d3f9c8e8ea&lt;SEP&gt;chunk-b16cd651cdc5569a6a819323b4bebdf3&lt;SEP&gt;chunk-0a5a383f7804eaab55ca250a8c04eac7&lt;SEP&gt;chunk-bcba7bdeba2b73eee2708a05dfc354f1&lt;SEP&gt;chunk-ba83ee149a2e9cfe2bb3186d3d9ab242&lt;SEP&gt;chunk-602d37fbdad3894f3fd097dec446048d&lt;SEP&gt;chunk-a6d0c51243ca209ed10575700d7d6fcb&lt;SEP&gt;chunk-6fad4f22632131c47ac7fa6e017c1365&lt;SEP&gt;chunk-eb63d9a76b5e16b54b440b97c0ede0f6&lt;SEP&gt;chunk-b2571a6903393e420ef4698741a914b5&lt;SEP&gt;chunk-1253e4088f4e8d0960f2a2d0bb84f70d&lt;SEP&gt;chunk-2183dd5d018c45af93c88653910c0ba1&lt;SEP&gt;chunk-c6a1c58572667dcaf6731aaf90b72d08&lt;SEP&gt;chunk-08be44a18d80d033d6d8c6eb79a3a64f&lt;SEP&gt;chunk-a2c2df663a5b98f657d14e99fafd7203&lt;SEP&gt;chunk-815e4f7cee9742bc3e2e8fee86eeecdc&lt;SEP&gt;chunk-ff618f26eaddc530ed912c48956812ad&lt;SEP&gt;chunk-e28b536983c09a8a7efed8f351c99c0f&lt;SEP&gt;chunk-d6e6792e62bbd9174e8ddc2dce3c4772&lt;SEP&gt;chunk-09fc3feaf326d3fa098b2