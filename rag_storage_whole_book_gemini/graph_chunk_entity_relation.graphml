="d9">{}</data></node><node id="甘蓝夜蛾"><data key="d0">甘蓝夜蛾</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2102c4977ee2662531b474addbf76d25</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777459254</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝类植物"><data key="d0">甘蓝类植物</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-ba83ee149a2e9cfe2bb3186d3d9ab242</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461243</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝菌核病"><data key="d0">甘蓝菌核病</data><data key="d1">病害</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-fa9f2148c0668a3696cc0a4cffb727ff&lt;SEP&gt;chunk-18ae905dc413db63df2e0fffe7cb0d9f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461419</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["病害导致植物组织出现的湿腐状病变。", "甘蓝菌核病引起水渍状淡褐色凹陷病斑", "N/A", "甘蓝菌核病危害甘蓝", "甘蓝菌核病可导致甘蓝叶球腐烂", "甘蓝菌核病主要危害甘蓝的茎基部", "甘蓝菌核病主要危害甘蓝的叶片"], "形态特征": ["黑色、形状各异的菌核，是甘蓝菌核病的典型病征。", "甘蓝菌核病伴随病部出现白色棉絮状菌丝", "甘蓝菌核病伴随病部出现黑色鼠粪状菌核"], "发生时期": ["甘蓝菌核病在成株期发病"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-fa9f2148c0668a3696cc0a4cffb727ff", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-18ae905dc413db63df2e0fffe7cb0d9f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-fa9f2148c0668a3696cc0a4cffb727ff", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-18ae905dc413db63df2e0fffe7cb0d9f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-18ae905dc413db63df2e0fffe7cb0d9f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="甘蓝菌核病叶球腐烂伴随灰白色菌丝"><data key="d0">甘蓝菌核病叶球腐烂伴随灰白色菌丝</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示甘蓝受菌核病危害，主要症状表现为叶球和茎基部组织腐烂，并覆盖有大量灰白色棉絮状菌丝。此为十字花科蔬菜菌核病的典型后期症状。</data><data key="d3">chunk-624be2cf5f3968ab37387c2390070381</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝菌核病大田发病状"><data key="d0">甘蓝菌核病大田发病状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甘蓝受菌核病侵害后的典型大田发病症状，植株表现为严重的萎蔫与腐烂，属于十字花科蔬菜重要病害之一。</data><data key="d3">chunk-3a1f6f9f0807cdecb083d00e3ee7feba</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝菌核病成株期症状"><data key="d0">甘蓝菌核病成株期症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示甘蓝感染菌核病，呈现成株期病害症状，包括叶片及叶球基部的腐烂和变色。</data><data key="d3">chunk-18ae905dc413db63df2e0fffe7cb0d9f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝菌核病菌核危害状"><data key="d0">甘蓝菌核病菌核危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甘蓝感染菌核病后的典型症状。受害部位（叶球）发生腐烂，表面形成明显的黑色菌核，此为核盘菌侵染甘蓝后的关键形态特征，用于诊断甘蓝菌核病。</data><data key="d3">chunk-fa9f2148c0668a3696cc0a4cffb727ff</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝蓟马危害状"><data key="d0">甘蓝蓟马危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甘蓝受棕榈蓟马危害后的典型症状。棕榈蓟马通过锉吸式口器取食甘蓝叶片，导致叶片呈现褪绿、黄化、褐斑及干枯皱缩等现象，严重影响植株光合作用及发育。</data><data key="d3">chunk-565c0e054586b465c48b31b170716d5b</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝蚜"><data key="d0">甘蓝蚜</data><data key="d1">虫害</data><data key="d10">image</data><data key="d2">该图片展示了甘蓝蚜的若虫和成虫形态。结合上下文，甘蓝蚜属于菜蚜，主要危害甘蓝、花椰菜等十字花科蔬菜，通过吸食叶片汁液导致叶片失水、营养不良、卷缩变形，甚至植株枯死。其分泌的蜜露可诱发煤污病，并能传播多种蔬菜病毒病。&lt;SEP&gt;主要危害大白菜叶片，导致叶片皱缩、变形、萎蔫，并诱发煤污病。&lt;SEP&gt;N/A</data><data key="d3">chunk-27d0171243706f7c20a06c9a73190c96&lt;SEP&gt;chunk-bf35b6fe615bb837008bfcf5197afb12&lt;SEP&gt;chunk-9418342574b2792109b681e7c44601ba&lt;SEP&gt;chunk-1af2b19abb0b704d0d3c588002b68add&lt;SEP&gt;chunk-2dfd14c48b4b4598d0c8ffa221c1df81&lt;SEP&gt;chunk-bff12f56d0df62b0fd2dbb213026b0d6&lt;SEP&gt;chunk-16e53f221a8aaf862ba107b114abcab2&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e&lt;SEP&gt;chunk-2547199e178a3bea51166c4da34b5890&lt;SEP&gt;chunk-2732eb6195df6f6255819cca0b42029f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461400</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["甘蓝蚜危害萝卜，导致叶片受损、植株萎蔫等。", "严重时导致结球受阻。", "危害留种植株嫩茎。", "寄生于大白菜叶片，影响植株结球。", "导致叶片皱缩、变形、萎蔫。", "N/A", "甘蓝蚜主要危害甘蓝", "甘蓝蚜主要危害花椰菜", "主要危害"], "发生时期": ["4月下旬至7月初", "N/A"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-1af2b19abb0b704d0d3c588002b68add", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-2dfd14c48b4b4598d0c8ffa221c1df81", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-bff12f56d0df62b0fd2dbb213026b0d6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-16e53f221a8aaf862ba107b114abcab2", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-27d0171243706f7c20a06c9a73190c96", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-86fe0a0dce4f7819d35523a45e7fd62e", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-2547199e178a3bea51166c4da34b5890", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-2547199e178a3bea51166c4da34b5890", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="甘蓝蚜危害大白菜"><data key="d0">甘蓝蚜危害大白菜</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甘蓝蚜对大白菜的危害症状。甘蓝蚜群集于叶片吸食汁液，引起叶片皱缩变形、植株生长不良，分泌的蜜露诱发煤污病，污染蔬菜并影响其正常结球。</data><data key="d3">chunk-2dfd14c48b4b4598d0c8ffa221c1df81</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝蚜危害萝卜"><data key="d0">甘蓝蚜危害萝卜</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示萝卜叶片受损，根据标注为甘蓝蚜危害。甘蓝蚜主要危害十字花科蔬菜，导致植株变形、生长不良、分泌蜜露诱发煤污病，并传播病毒病。上下文提供了蚜虫的生活习性、发生时期及多种农业、物理、化学防治方法，还提及了黄曲条跳甲的危害作物与形态特征。</data><data key="d3">chunk-1af2b19abb0b704d0d3c588002b68add</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝蚜萝卜蚜桃蚜危害对象形态特征比较表"><data key="d0">甘蓝蚜萝卜蚜桃蚜危害对象形态特征比较表</data><data key="d1">多模态元素</data><data key="d10">table</data><data key="d2">该表对比了甘蓝蚜、萝卜蚜、桃蚜三种菜蚜的危害对象、发生时期及形态特征，对理解十字花科蔬菜蚜虫识别与防治具重要意义。</data><data key="d3">chunk-2547199e178a3bea51166c4da34b5890</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝软腐病"><data key="d0">甘蓝软腐病</data><data key="d1">病害</data><data key="d10" /><data key="d2">软腐病在甘蓝上的特指表现。</data><data key="d3">chunk-6a566dac6682579a8b7ab6c46552d839</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461313</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["甘蓝软腐病引起的症状。"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-6a566dac6682579a8b7ab6c46552d839", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="甘蓝软腐病危害症状"><data key="d0">甘蓝软腐病危害症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甘蓝结球期受软腐病侵害的典型症状，表现为叶球基部及叶片组织腐烂成黏滑的灰褐色泥状，并散发恶臭，严重影响植株生长。</data><data key="d3">chunk-c3cc3c96f11412119dd352621bc75a4a</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝软腐病干腐症状"><data key="d0">甘蓝软腐病干腐症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了甘蓝软腐病在后期呈现的干腐症状，病部组织失水变干，与早期的黏滑软腐不同，是十字花科蔬菜软腐病的重要识别特征之一。</data><data key="d3">chunk-379c9a8e038b134bd47ee4e60ac579ca</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝软腐病湿腐症状"><data key="d0">甘蓝软腐病湿腐症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甘蓝患软腐病后的典型湿腐症状，表现为叶球内部组织呈稀泥状软腐，病部发生腐烂并伴有恶臭。该病害主要在甘蓝结球期发生，是十字花科蔬菜的重要病害。</data><data key="d3">chunk-8d64d27c40d5e2c0a3a5de38821420bd</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝软腐病病茎剖面症状"><data key="d0">甘蓝软腐病病茎剖面症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甘蓝软腐病发病后的病茎剖面特征。该病主要在结球期发生，病原菌通过伤口侵入，导致茎部组织呈现灰褐色软腐、黏滑稀泥状并伴有恶臭。害虫取食造成的伤口是诱发该病的重要因素。</data><data key="d3">chunk-3a78e3281e5a0bbc179d412851f35c67</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝黑斑病叶片症状图"><data key="d0">甘蓝黑斑病叶片症状图</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了甘蓝叶片感染黑斑病的症状，可见近圆形灰褐色斑点。黑斑病是十字花科蔬菜的常见病害，由芸薹链格孢引起，主要危害叶片，严重时可致叶片穿孔或枯死。该病多发于春秋两季的成株期至采收期。</data><data key="d3">chunk-eaa13fa62c2f2a3e426c1cbdefca4345</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蓝黑腐病"><data key="d0">甘蓝黑腐病</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甘蓝黑腐病的典型症状：叶片边缘出现V形黄褐色枯死病斑，外围伴有黄色晕圈，叶脉褐变。该病害主要危害十字花科蔬菜，在苗期至成株期均可发生，由病菌侵染维管束导致植株枯死。</data><data key="d3">chunk-5daed8d494fa727d409bd53e85d83c50</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘蔗"><data key="d0">甘蔗</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-039c414821a18ac99777ef473c4c3eeb</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777459278</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甘薯"><data key="d0">甘薯</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-039c414821a18ac99777ef473c4c3eeb</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777459276</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甜椒"><data key="d0">甜椒</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-53e6356230579174bc1646371ab0629d&lt;SEP&gt;chunk-91fb27c7119bdb8a5271e5ea86d39c2b&lt;SEP&gt;chunk-fa81a0bde62d00db67e3f78217464e36&lt;SEP&gt;chunk-6c09e84d110894b31d0ca1a2351c3eae&lt;SEP&gt;chunk-f750ab36b2f3c4736f4d211c305b36aa</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461346</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甜菜夜蛾"><data key="d0">甜菜夜蛾</data><data key="d1">虫害</data><data key="d10" /><data key="d2">Entity: 甜菜夜蛾。甜菜夜蛾是鳞翅目夜蛾科的一种杂食性害虫。其成虫具有趋光性和趋化性。幼虫体色多变，初孵幼虫具有群集性，并具有畏光性和假死性。该害虫喜温，对高温适应性强，在高温干旱年份易猖獗成灾；降水量大则不利于其存活、繁殖和发生。</data><data key="d3">chunk-ce8ce757d0c4c5e0d3389af1fd809ffd&lt;SEP&gt;chunk-0f80ba997fa22a606c08224fef24a3e1&lt;SEP&gt;chunk-06c4679ebf4de0a8d8224fbb2924294f&lt;SEP&gt;chunk-53e6356230579174bc1646371ab0629d&lt;SEP&gt;chunk-0062a028e9dff340fab151943ea14834&lt;SEP&gt;chunk-01866903c222f0a86217a8be58eb9aca&lt;SEP&gt;chunk-44d22c6da1c507c187f71b1b576524ac&lt;SEP&gt;chunk-91fb27c7119bdb8a5271e5ea86d39c2b&lt;SEP&gt;chunk-53c5eb4f63fef104b52ef1aa30f38af6&lt;SEP&gt;chunk-c487d47e9d94b77bc6c6185d19a45849&lt;SEP&gt;chunk-fa81a0bde62d00db67e3f78217464e36&lt;SEP&gt;chunk-912985f5ad6ba6992e74bb91994a8a28&lt;SEP&gt;chunk-6c09e84d110894b31d0ca1a2351c3eae&lt;SEP&gt;chunk-6c9c5c1a89394df08c4521777314cc90&lt;SEP&gt;chunk-0c2ee414820ec7b040f63b99feb057e2&lt;SEP&gt;chunk-f5668c202430163cc5097604a98058ed&lt;SEP&gt;chunk-f750ab36b2f3c4736f4d211c305b36aa&lt;SEP&gt;chunk-3b4748e1b515b1d16d492a54b7db5d2c&lt;SEP&gt;chunk-1c5a12d22cf1665308291c146f152537</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461196</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["N/A", "菜苗死亡", "缺苗断垄", "幼虫危害甜椒果实", "幼虫危害番茄果实", "幼虫危害蔬菜叶片", "幼虫钻蛀甜椒、番茄果实", "幼虫取食叶肉留下表皮形成透明小孔", "严重危害可致使菜苗死亡", "严重危害可造成缺苗断垄", "严重危害时导致叶片仅余叶脉和叶柄", "幼虫取食叶片", "幼虫取食叶肉", "初孵幼虫群集叶背取食叶肉", "幼虫取食导致", "三龄后幼虫导致", "幼虫取食叶肉及导致缺刻", "幼虫钻蛀果实。", "甜菜夜蛾幼虫危害叶片", "甜菜夜蛾严重危害时仅剩叶脉", "甜菜夜蛾严重危害时仅剩叶柄", "甜菜夜蛾幼虫取食叶片产生危害", "幼虫危害作物的叶片，早期形成透明小孔，后期吃成缺刻", "幼虫钻蛀甜椒的果实", "幼虫钻蛀番茄的果实", "严重时可导致菜苗死亡或毁种", "取食叶片导致缺刻、孔洞", "幼虫期钻蛀果实", "主要危害甘蓝", "主要危害白菜", "主要危害萝卜", "主要危害辣椒", "主要危害番茄", "钻蛀果实", "叶片被取食后形成的痕迹", "叶片被取食后形成的孔洞", "叶片被取食后形成的缺刻", "甜菜夜蛾幼虫排出的废弃物", "甜菜夜蛾幼虫在叶片上取食，造成损害。"], "发病诱因": ["N/A", "不利于其存活、繁殖和发生", "高温干旱年份易猖獗"], "发生时期": ["在北方全年发生严重", "N/A", "8月中旬至9月中旬", "北方地区发生盛期。"], "形态特征": ["黄褐色，体长圆筒状，表面具有光泽，腹部各节清晰可见", "绿色、暗绿色或黑褐色，体侧具明显黄白色纵带", "甜菜夜蛾幼虫具有咀嚼式口器", "甜菜夜蛾的蛹期形态", "圆馒头形，白色，表面具放射状隆起线，覆盖棕黄色绒毛"], "生活习性": ["甜菜夜蛾是杂食性害虫", "甜菜夜蛾高龄幼虫具有更强的取食能力", "生活习性之一", "N/A", "受震后即落地", "数量大时成群迁移", "食料缺乏时发生", "对高温适应性强"], "防治要点": ["卵孵盛期可使用此药剂防治", "人工摘除卵块"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-53e6356230579174bc1646371ab0629d", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-01866903c222f0a86217a8be58eb9aca", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-44d22c6da1c507c187f71b1b576524ac", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-91fb27c7119bdb8a5271e5ea86d39c2b", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-53c5eb4f63fef104b52ef1aa30f38af6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-c487d47e9d94b77bc6c6185d19a45849", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-fa81a0bde62d00db67e3f78217464e36", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-6c09e84d110894b31d0ca1a2351c3eae", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-f5668c202430163cc5097604a98058ed", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-f750ab36b2f3c4736f4d211c305b36aa", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-1c5a12d22cf1665308291c146f152537", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发病诱因": [{"chunk": "chunk-53e6356230579174bc1646371ab0629d", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-6c09e84d110894b31d0ca1a2351c3eae", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-53e6356230579174bc1646371ab0629d", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-91fb27c7119bdb8a5271e5ea86d39c2b", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-0062a028e9dff340fab151943ea14834", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-53c5eb4f63fef104b52ef1aa30f38af6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-fa81a0bde62d00db67e3f78217464e36", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-0c2ee414820ec7b040f63b99feb057e2", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-53c5eb4f63fef104b52ef1aa30f38af6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-6c09e84d110894b31d0ca1a2351c3eae", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-f750ab36b2f3c4736f4d211c305b36aa", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "防治要点": [{"chunk": "chunk-6c09e84d110894b31d0ca1a2351c3eae", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-0c2ee414820ec7b040f63b99feb057e2", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="甜菜夜蛾严重危害状"><data key="d0">甜菜夜蛾严重危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">本图展示了甜菜夜蛾对蔬菜叶片的严重危害状。图片中可见叶片上布满不规则的孔洞、缺刻状食痕，并伴有黑色虫粪，同时能观察到淡绿色的甜菜夜蛾幼虫在取食。结合上下文，甜菜夜蛾幼虫主要危害叶片，造成叶片被吃成透明小孔、缺刻甚至仅剩叶脉，严重时可致菜苗死亡。</data><data key="d3">chunk-1c5a12d22cf1665308291c146f152537</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甜菜夜蛾危害状及幼虫"><data key="d0">甜菜夜蛾危害状及幼虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甜菜夜蛾低龄幼虫在蔬菜叶片上的取食情况。甜菜夜蛾为杂食性害虫，幼虫群集于叶背取食叶肉形成透明小孔（窗孔），随龄期增长造成叶片严重缺刻甚至毁苗。防治应抓住低龄幼虫盛发期（三龄前）施药。</data><data key="d3">chunk-912985f5ad6ba6992e74bb91994a8a28</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甜菜夜蛾卵块"><data key="d0">甜菜夜蛾卵块</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甜菜夜蛾的卵块。甜菜夜蛾属鳞翅目夜蛾科，是危害甘蓝、白菜等多种蔬菜的杂食性害虫。卵块通常产于叶片背面，呈圆馒头形，表面覆盖绒毛，生产中可通过人工摘除卵块进行防治。</data><data key="d3">chunk-0c2ee414820ec7b040f63b99feb057e2</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甜菜夜蛾幼虫"><data key="d0">甜菜夜蛾幼虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甜菜夜蛾的老熟幼虫。该虫属于鳞翅目夜蛾科，是多种蔬菜的重要害虫。幼虫具有多食性，主要危害叶片及果实，喜高温干旱环境，在夏季及初秋（7-10月）危害严重，防治需抓住卵孵盛期，可结合物理防治与生物农药如核型多角体病毒进行治理。</data><data key="d3">chunk-6c09e84d110894b31d0ca1a2351c3eae</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甜菜夜蛾幼虫危害十字花科蔬菜叶片"><data key="d0">甜菜夜蛾幼虫危害十字花科蔬菜叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">此图片展示了甜菜夜蛾幼虫在十字花科蔬菜叶片上造成的危害症状，包括叶片上的孔洞、缺刻以及一只幼虫。上下文补充了甜菜夜蛾幼虫会取食叶肉，并能导致菜苗死亡、缺苗断垄甚至毁种。</data><data key="d3">chunk-01866903c222f0a86217a8be58eb9aca</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甜菜夜蛾幼虫危害状"><data key="d0">甜菜夜蛾幼虫危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甜菜夜蛾高龄幼虫在蔬菜叶片上的取食危害状。甜菜夜蛾为鳞翅目夜蛾科杂食性害虫，幼虫取食叶片产生缺刻，严重时可致使菜苗死亡，甚至毁种。该害虫广泛危害甘蓝、白菜等十字花科蔬菜及茄子、辣椒等多种作物。</data><data key="d3">chunk-53c5eb4f63fef104b52ef1aa30f38af6</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甜菜夜蛾成虫"><data key="d0">甜菜夜蛾成虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甜菜夜蛾的成虫形态，其体色灰褐色，前翅具有典型的肾形斑和圆形斑特征。该害虫属鳞翅目夜蛾科，为杂食性害虫，对十字花科蔬菜及多种茄果类作物具有较强的危害性。</data><data key="d3">chunk-f5668c202430163cc5097604a98058ed</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甜菜夜蛾核型多角体病毒悬浮剂"><data key="d0">甜菜夜蛾核型多角体病毒悬浮剂</data><data key="d1">药剂</data><data key="d10" /><data key="d2">10亿PIB/克&lt;SEP&gt;用于防治甜菜夜蛾的生物农药。&lt;SEP&gt;N/A&lt;SEP&gt;10亿PIB/克制剂&lt;SEP&gt;防治甜菜夜蛾的药剂&lt;SEP&gt;10亿PIB*/克</data><data key="d3">chunk-0f80ba997fa22a606c08224fef24a3e1&lt;SEP&gt;chunk-53e6356230579174bc1646371ab0629d&lt;SEP&gt;chunk-91fb27c7119bdb8a5271e5ea86d39c2b&lt;SEP&gt;chunk-fa81a0bde62d00db67e3f78217464e36&lt;SEP&gt;chunk-6c09e84d110894b31d0ca1a2351c3eae&lt;SEP&gt;chunk-f750ab36b2f3c4736f4d211c305b36aa</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461349</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甜菜夜蛾蛹"><data key="d0">甜菜夜蛾蛹</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了甜菜夜蛾的蛹，呈暗褐色。甜菜夜蛾蛹通常为黄褐色，并在土壤中越冬。当土温升至10°C以上时，蛹会羽化成虫。其幼虫可危害甜椒、番茄果实及各类蔬菜叶片，导致严重损失。防治可选用甜菜夜蛾核型多角体病毒悬浮剂。</data><data key="d3">chunk-53e6356230579174bc1646371ab0629d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甜菜夜蛾蛹（化蛹初期"><data key="d0">甜菜夜蛾蛹（化蛹初期</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了甜菜夜蛾化蛹初期的形态，呈绿褐色。甜菜夜蛾幼虫危害多种作物叶片及果实，导致缺刻、死亡、落果烂果。其蛹期在土壤中越冬，幼虫老熟后入土化蛹，可使用核型多角体病毒悬浮剂防治。</data><data key="d3">chunk-fa81a0bde62d00db67e3f78217464e36</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="甜菜夜蛾预蛹图像"><data key="d0">甜菜夜蛾预蛹图像</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了甜菜夜蛾的预蛹形态，结合上下文，甜菜夜蛾幼虫体色多为绿色，主要危害作物叶片及甜椒、番茄果实，在高温干旱年份易暴发，可使用甜菜夜蛾核型多角体病毒悬浮剂防治。</data><data key="d3">chunk-f750ab36b2f3c4736f4d211c305b36aa</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="生石灰"><data key="d0">生石灰</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;用于防治蜗牛。</data><data key="d3">chunk-64d7ba16672b09ea0136eba5fdbd5a11&lt;SEP&gt;chunk-2183dd5d018c45af93c88653910c0ba1</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461261</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="生菜"><data key="d0">生菜</data><data key="d1">作物</data><data key="d10" /><data key="d2">叶用莴苣。</data><data key="d3">chunk-64dbbfe6815b715aaf473f142dcecc73</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461470</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="生长点"><data key="d0">生长点</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-cdc75a846424d224be95bef5e748659b&lt;SEP&gt;chunk-80be34d2e662ee0076c2d8809df4d115&lt;SEP&gt;chunk-1fbfc726dd296f1ec43ce2aa9f0d0895&lt;SEP&gt;chunk-058bfcb505d4110825b3930b6eb972e2&lt;SEP&gt;chunk-dee1c0cb2d3ac680561c4257ac355a14</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461277</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key=