a><data key="d5">1777461422</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="结球期"><data key="d0">结球期</data><data key="d1">生长期</data><data key="d10" /><data key="d2">甘蓝的生长期之一&lt;SEP&gt;甘蓝等作物生长发育的一个阶段。&lt;SEP&gt;N/A</data><data key="d3">chunk-8d64d27c40d5e2c0a3a5de38821420bd&lt;SEP&gt;chunk-0a5a383f7804eaab55ca250a8c04eac7&lt;SEP&gt;chunk-6a566dac6682579a8b7ab6c46552d839&lt;SEP&gt;chunk-c3cc3c96f11412119dd352621bc75a4a&lt;SEP&gt;chunk-1fbfc726dd296f1ec43ce2aa9f0d0895&lt;SEP&gt;chunk-dee1c0cb2d3ac680561c4257ac355a14&lt;SEP&gt;chunk-3a78e3281e5a0bbc179d412851f35c67</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461172</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="维管束"><data key="d0">维管束</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-072d30697d058f37fa4825ec390d9508</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461405</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="缺硼"><data key="d0">缺硼</data><data key="d1">病害</data><data key="d10" /><data key="d2">一种生理性病害，表现为植株发育不良及组织坏死。&lt;SEP&gt;一种生理性病害，由植物体内硼元素缺乏引起。</data><data key="d3">chunk-371895d9884598c227a071fa676687e0&lt;SEP&gt;chunk-80be34d2e662ee0076c2d8809df4d115</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461332</data><data key="d6" /><data key="d7" /><data key="d8">{"防治要点": ["增施有机肥是防治缺硼的方法", "平衡氮磷钾肥是防治缺硼的方法", "合理施用硼肥是防治缺硼的方法", "控制氮肥是防治缺硼的方法", "防止土壤干裂有助于防治缺硼", "不可一次性灌水过多有助于防治缺硼"], "发病诱因": ["氮肥特别是铵态氮过多会抑制蔬菜对硼的吸收，导致缺硼", "土壤干裂会影响硼的吸收，导致缺硼", "一次性灌水过多会导致土壤水溶性硼淋失，从而导致缺硼"]}</data><data key="d9">{"防治要点": [{"chunk": "chunk-80be34d2e662ee0076c2d8809df4d115", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发病诱因": [{"chunk": "chunk-80be34d2e662ee0076c2d8809df4d115", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="缺硼症"><data key="d0">缺硼症</data><data key="d1">病害</data><data key="d10" /><data key="d2">由硼元素缺乏引起的生理性病害&lt;SEP&gt;萝卜的一种生理性病害，由缺硼引起。&lt;SEP&gt;N/A</data><data key="d3">chunk-60cb92949480597cbb7128e491470f18&lt;SEP&gt;chunk-3804e6899c46d9421cdbc913901d17a2&lt;SEP&gt;chunk-27f4d26b6bcac38bc856a64138d3baf7</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461403</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["缺硼症会导致小白菜茎部出现褐变、坏死及空洞现象", "茎部及花球的肥短花枝心部呈水渍状", "继而变为锈褐色湿腐", "内部组织横裂成孔洞", "裂面褐色", "表现为器官组织的湿腐与开裂", "萝卜缺硼时肉质茎内部组织表现出的症状之一。", "萝卜缺硼导致肉质茎横裂形成的内部结构。", "萝卜缺硼后裂面呈现的颜色。", "萝卜缺硼导致肉质茎内部出现的病变。", "萝卜缺硼导致肉质茎内部组织横向破裂。", "萝卜缺硼导致其生长发育受到影响。", "萝卜缺硼导致肉质茎内部细胞和组织受到损害。", "缺硼症直接导致萝卜肉质茎出现生理性病变。"], "防治要点": ["通过叶面喷施硼肥进行防治", "通过增施有机肥进行防治"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-60cb92949480597cbb7128e491470f18", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-3804e6899c46d9421cdbc913901d17a2", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-27f4d26b6bcac38bc856a64138d3baf7", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "防治要点": [{"chunk": "chunk-60cb92949480597cbb7128e491470f18", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="美洲斑潜蝇"><data key="d0">美洲斑潜蝇</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-e1ffc4d7126b3916ef88c8c7f5b1a921&lt;SEP&gt;chunk-bf76767393a4c9d7f894571646f86f0b</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461387</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["美洲斑潜蝇雌成虫刺伤叶片取食和产卵形成", "幼虫潜入叶片危害形成先细后宽的蛇形弯曲盘绕虫道", "美洲斑潜蝇危害十字花科蔬菜"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-bf76767393a4c9d7f894571646f86f0b", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="美洲斑潜蝇危害状"><data key="d0">美洲斑潜蝇危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了美洲斑潜蝇对十字花科蔬菜叶片的危害。美洲斑潜蝇成虫取食产卵导致褪绿斑点，幼虫在叶片组织内钻蛀形成蛇形弯曲虫道，严重时可导致叶片枯萎干斑，影响光合作用。</data><data key="d3">chunk-bf76767393a4c9d7f894571646f86f0b</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1