, "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="病菌"><data key="d0">病菌</data><data key="d1">病原菌</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;引起甘蓝软腐病的病原菌&lt;SEP&gt;导致芥菜白锈病的病原生物</data><data key="d3">chunk-c3cc3c96f11412119dd352621bc75a4a&lt;SEP&gt;chunk-70c3dabe8d1badadfef137a716a043ff&lt;SEP&gt;chunk-3a78e3281e5a0bbc179d412851f35c67</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461351</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="病部组织"><data key="d0">病部组织</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-8d64d27c40d5e2c0a3a5de38821420bd</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461173</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白茎"><data key="d0">白茎</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-42b55ba8453375fed74e005cd3cc43ab</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461417</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="白菜"><data key="d0">白菜</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2711af80087a36171089b13436581425&lt;SEP&gt;chunk-2de1784a101a3d8331d829acf538c9e1&lt;SEP&gt;chunk-3511fba3b1d9eaeca88fc9aca1dc1364&lt;SEP&gt;chunk-3e38741d2bfbf032bfe7da65cf5c9302&lt;SEP&gt;chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-c60631811c47de4ce2c79aee52951117&lt;SEP&gt;chunk-eb8e40732cd0b5a7f534922a7ccb9a6e&lt;SEP&gt;chunk-6853819bd6c24f5f2236d760b9ce81b1&lt;SEP&gt;chunk-38bab4e2c085cbd981e991eb6f9a8e92&lt;SEP&gt;chunk-2102c4977ee2662531b474addbf76d25&lt;SEP&gt;chunk-e1ffc4d7126b3916ef88c8c7f5b1a921&lt;SEP&gt;chunk-ce8ce757d0c4c5e0d3389af1fd809ffd&lt;SEP&gt;chunk-089405484f7cef39ff9ff4354d1da054&lt;SEP&gt;chunk-039c414821a18ac99777ef473c4c3eeb&lt;SEP&gt;chunk-0f80ba997fa22a6