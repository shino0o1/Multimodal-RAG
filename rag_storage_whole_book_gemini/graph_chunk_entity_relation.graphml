d0">金针虫</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2102c4977ee2662531b474addbf76d25</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777459253</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="钾肥"><data key="d0">钾肥</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-80be34d2e662ee0076c2d8809df4d115</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461340</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="铵态氮"><data key="d0">铵态氮</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-80be34d2e662ee0076c2d8809df4d115</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461342</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="银纹夜蛾"><data key="d0">银纹夜蛾</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;鳞翅目夜蛾科害虫，成虫前翅具显著U形银纹。&lt;SEP&gt;一种鳞翅目夜蛾科害虫</data><data key="d3">chunk-0f80ba997fa22a606c08224fef24a3e1&lt;SEP&gt;chunk-4fab5ac32aa4dad18361b99b22fbb787&lt;SEP&gt;chunk-25a870883e30ca4e4e260db153e16de6&lt;SEP&gt;chunk-508961555c467e211aad7fa4b893e675&lt;SEP&gt;chunk-4f0db3eb8e47b1168869ce73699eacd2&lt;SEP&gt;chunk-1b21560a97097ef8c782850de81e35aa</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461466</data><data key="d6" /><data key="d7">豆尺蠖&lt;SEP&gt;菜步曲&lt;SEP&gt;黑点银纹夜蛾&lt;SEP&gt;豆青虫&lt;SEP&gt;大豆造桥虫&lt;SEP&gt;豆银纹夜蛾</data><data key="d8">{"别名": ["菜步曲", "豆青虫", "大豆造桥虫", "黑点银纹夜蛾", "豆银纹夜蛾", "豆尺蠖", "N/A"], "形态特征": ["银纹夜蛾的生命阶段之一", "成虫体色黑褐色，前翅中央具有显著的U形银纹及近三角形银斑，后翅呈暗褐色且具金属光泽。"], "危害症状": ["N/A", "幼虫取食叶片"], "生活习性": ["幼虫的假死习性", "成虫的夜间活动习性", "成虫的趋光习性"], "发生时期": ["N/A", "主要发生时期"], "防治要点": ["可供参考的防治方法"]}</data><data key="d9">{"别名": [{"chunk": "", "file": "", "page": ""}, {"chunk": "chunk-0f80ba997fa22a606c08224fef24a3e1", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-4fab5ac32aa4dad18361b99b22fbb787", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-1b21560a97097ef8c782850de81e35aa", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "危害症状": [{"chunk": "chunk-4fab5ac32aa4dad18361b99b22fbb787", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-25a870883e30ca4e4e260db153e16de6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-4f0db3eb8e47b1168869ce73699eacd2", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-1b21560a97097ef8c782850de81e35aa", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-25a870883e30ca4e4e260db153e16de6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-25a870883e30ca4e4e260db153e16de6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-4f0db3eb8e47b1168869ce73699eacd2", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "防治要点": [{"chunk": "chunk-25a870883e30ca4e4e260db153e16de6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="银纹夜蛾幼虫"><data key="d0">银纹夜蛾幼虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了银纹夜蛾幼虫。银纹夜蛾属鳞翅目夜蛾科，主要危害白菜、甘蓝等十字花科蔬菜。幼虫取食叶片导致孔洞或缺刻，每年7-9月为危害盛期，可通过参考斜纹夜蛾的防治措施进行管理。</data><data key="d3">chunk-4f0db3eb8e47b1168869ce73699eacd2</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="银纹夜蛾成虫"><data key="d0">银纹夜蛾成虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图示为鳞翅目夜蛾科害虫银纹夜蛾的成虫。其主要特征为前翅中央有显著的U形银纹和三角形银斑。该虫是白菜、甘蓝、萝卜等十字花科蔬菜的重要害虫，主要通过幼虫取食叶片造成孔洞或缺刻。</data><data key="d3">chunk-1b21560a97097ef8c782850de81e35aa</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="银纹夜蛾茧"><data key="d0">银纹夜蛾茧</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了银纹夜蛾（鳞翅目夜蛾科）的茧，该害虫常危害十字花科蔬菜。其幼虫老熟后多在寄主植物叶片背面吐丝结茧化蛹，是该虫害生命周期中的重要阶段。</data><data key="d3">chunk-508961555c467e211aad7fa4b893e675</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="银纹夜蛾蛹"><data key="d0">银纹夜蛾蛹</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了害虫银纹夜蛾的蛹，其主体呈黄绿色，部分节段呈深色。根据上下文描述，银纹夜蛾蛹初期腹面呈绿色，末期整体黑褐色，幼虫老熟后多在叶背吐丝结茧化蛹。银纹夜蛾属鳞翅目夜蛾科，危害十字花科蔬菜等多种作物。</data><data key="d3">chunk-4fab5ac32aa4dad18361b99b22fbb787</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="银纹夜蛾蛹背面"><data key="d0">银纹夜蛾蛹背面</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示银纹夜蛾的蛹，呈黑褐色，位于植物叶片上。银纹夜蛾属鳞翅目夜蛾科，危害十字花科蔬菜、豆类、瓜类等多种作物。其以蛹越冬，每年发生多代，危害盛期为7-9月。幼虫老熟后多在叶背吐丝结茧化蛹，成虫夜间活动并趋光。防治可参考斜纹夜蛾方法。</data><data key="d3">chunk-25a870883e30ca4e4e260db153e16de6</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="锦葵科植物"><data key="d0">锦葵科植物</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-4f81aa7efe24d8dc3a429c05163875d9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461447</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="防虫网"><data key="d0">防虫网</data><data key="d1">药剂</data><data key="d10" /><data key="d2">用于育苗阶段，防止害虫产卵。&lt;SEP&gt;物理防治器材</data><data key="d3">chunk-c60631811c47de4ce2c79aee52951117&lt;SEP&gt;chunk-89fd1a92fac060bd5bcd453db48be5bb</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461291</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="阿维菌素"><data key="d0">阿维菌素</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-ca8792ea559d74a7290ea6ef526fb64f&lt;SEP&gt;chunk-1af2b19abb0b704d0d3c588002b68add&lt;SEP&gt;chunk-0ed5436bf3fb965fbbc7838cf37929b3</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461396</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="阿维菌素乳油"><data key="d0">阿维菌素乳油</data><data key="d1">药剂</data><data key="d10" /><data key="d2">0.2%乳油&lt;SEP&gt;N/A</data><data key="d3">chunk-32ddbaf2dc6854d70cd0231ee3b7b30f&lt;SEP&gt;chunk-36a0d55340470c41badc3ab815a48b11&lt;SEP&gt;chunk-e4deaf546dd3ce6cf9f4d4298a30c16c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461469</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="霜脲·锰锌"><data key="d0">霜脲·锰锌</data><data key="d1">药剂</data><data key="d10" /><data key="d2">72%霜脲·锰锌可湿性粉剂&lt;SEP&gt;N/A</data><data key="d3">chunk-6853819bd6c24f5f2236d760b9ce81b1&lt;SEP&gt;chunk-b3b74e94cd9e673214401f1d7e211970&lt;SEP&gt;chunk-157bd3addbb38750d6dff95f3d5a9e7d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461373</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="霜脲·锰锌可湿性粉剂"><data key="d0">霜脲·锰锌可湿性粉剂</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-28f88298e7316c3aca7aa7d3f9c8e8ea&lt;SEP&gt;chunk-2d0a0e1a2ae281c246d32fd566f9339f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461212</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="霜霉威"><data key="d0">霜霉威</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-3e38741d2bfbf032bfe7da65cf5c9302&lt;SEP&gt;chunk-b3b74e94cd9e673214401f1d7e211970&lt;SEP&gt;chunk-157bd3addbb38750d6dff95f3d5a9e7d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461371</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="霜霉威水剂"><data key="d0">霜霉威水剂</data><data key="d1">药剂</data><data key="d10" /><data key="d2">72.2%霜霉威水剂&lt;SEP&gt;N/A</data><data key="d3">chunk-6853819bd6c24f5f2236d760b9ce81b1&lt;SEP&gt;chunk-28f88298e7316c3aca7aa7d3f9c8e8ea&lt;SEP&gt;chunk-2d0a0e1a2ae281c246d32fd566f9339f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461210</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="霜霉病"><data key="d0">霜霉病</data><data key="d1">病害</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-3e38741d2bfbf032bfe7da65cf5c9302&lt;SEP&gt;chunk-a2c2df663a5b98f657d14e99fafd7203&lt;SEP&gt;chunk-ff618f26eaddc530ed912c48956812ad&lt;SEP&gt;chunk-2d0a0e1a2ae281c246d32fd566f9339f&lt;SEP&gt;chunk-b3b74e94cd9e673214401f1d7e211970&lt;SEP&gt;chunk-d1acbb47c0219e0636a09159f5abd319&lt;SEP&gt;chunk-ea3ad9de087ca853f6d9c25a2d2681c9&lt;SEP&gt;chunk-b519def7c9178c12ba0037aaa6c70926&lt;SEP&gt;chunk-157bd3addbb38750d6dff95f3d5a9e7d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461265</data><data key="d6" /><data key="d7" /><data key="d8">{"发病诱因": ["喜温暖高湿环境", "霜霉病常在高湿环境下高发", "最适发病温度为20-24℃，空气相对湿度90%以上。", "多年连作会加重霜霉病的发生。", "播种过早会加重霜霉病的发生。", "氮肥偏多会加重霜霉病的发生。", "种植过密会加重霜霉病的发生。", "通风透光差会加重霜霉病的发生。", "多雨多雾会加重霜霉病的发生。", "地势低洼积水会加重霜霉病的发生。"], "危害症状": ["N/A", "水渍状褪绿", "不均匀的枯黄斑", "多角形斑块", "边缘不明晰", "霜霉病危害小白菜", "霜霉病主要危害作物叶片", "主要危害部位", "霜霉病在叶片背面产生霉层", "受叶脉限制呈多角形，初期褪绿，后期变黄褐色", "霜霉病主要在叶片背面产生症状", "初期出现边缘不明晰的水渍状褪绿斑点", "病叶表面出现的黄化斑点", "受叶脉限制形成的淡褐色多角形斑块", "受叶脉限制形成的黄褐色斑块", "霜霉病初期表现为边缘不明晰的水渍状褪绿黄化斑", "霜霉病病斑随病程发展，受叶脉限制呈多角形淡褐色或黄褐色", "霜霉病严重时导致叶片干枯、卷缩", "大白菜霜霉病典型病叶正面症状表现为叶片退绿、枯黄斑连片及叶脉间多角形病变", "大白菜霜霉病主要危害叶片", "小白菜霜霉病症状表现为叶片背面形成灰白色霉层。", "霜霉病病叶初期症状包括水渍状褪绿。", "霜霉病病斑扩展后呈多角形淡褐色或黄褐色。", "霜霉病危害小白菜。", "霜霉病危害大白菜。", "霜霉病危害菜薹。", "霜霉病危害萝卜。", "霜霉病危害甘蓝。", "霜霉病主要危害叶片。", "霜霉病主要危害茎。", "霜霉病主要危害花。", "霜霉病主要危害花梗。", "霜霉病主要危害种荚。"], "发生时期": ["N/A", "4月中旬至5月上中旬", "秋季发病高峰期", "大白菜生长期", "霜霉病可发生于苗期", "霜霉病可发生于成株期", "霜霉病常在春秋两季高发", "该病主要发生在春季，长江中下游地区春季发生高峰期为4月中旬至5月上中旬。", "该病主要发生在秋季，长江中下游地区秋季发生高峰期为9月初至11月。", "长江中下游地区春季发生高峰期为4月中旬。", "长江中下游地区春季发生高峰期为5月上中旬。", "长江中下游地区秋季发生高峰期为9月初。", "长江中下游地区秋季发生高峰期为11月。"], "防治要点": ["丙森锌可用于防治霜霉病", "代森锰锌可用于防治霜霉病", "甲霜·锰锌可用于防治霜霉病", "清除病苗是防治霜霉病的方法。", "N/A", "深沟高畦栽培是防治霜霉病的方法。", "清沟排水是防治霜霉病的方法。", "咯菌腈可作为拌种包衣剂用于防治霜霉病。", "咯菌腈可有效防治霜霉病。", "丙森锌可用于霜霉病发病前预防。", "代森锰锌可用于霜霉病发病前预防。", "嗅酮·锰锌可用于霜霉病发病前预防。", "霜霉威可用于霜霉病发病后治疗。", "甲霜·锰锌可用于霜霉病发病后治疗。", "霜脲·锰锌可用于霜霉病发病后治疗。", "氰霜唑可用于霜霉病发病后治疗。", "唑醚·代森联可用于霜霉病发病后治疗。", "嗅霜·锰锌可用于霜霉病发病后治疗。", "嗅酮·霜脲氰可用于霜霉病发病后治疗。"]}</data><data key="d9">{"发病诱因": [{"chunk": "chunk-a2c2df663a5b98f657d14e99fafd7203", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-b519def7c9178c12ba0037aaa6c70926", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-157bd3addbb38750d6dff95f3d5a9e7d", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "危害症状": [{"chunk": "chunk-a2c2df663a5b98f657d14e99fafd7203", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-ff618f26eaddc530ed912c48956812ad", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-2d0a0e1a2ae281c246d32fd566f9339f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-b3b74e94cd9e673214401f1d7e211970", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-d1acbb47c0219e0636a09159f5abd319", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-ea3ad9de087ca853f6d9c25a2d2681c9", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-b519def7c9178c12ba0037aaa6c70926", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-157bd3addbb38750d6dff95f3d5a9e7d", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-a2c2df663a5b98f657d14e99fafd7203", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-b3b74e94cd9e673214401f1d7e211970", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-b519def7c9178c12ba0037aaa6c70926", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-157bd3addbb38750d6dff95f3d5a9e7d", 