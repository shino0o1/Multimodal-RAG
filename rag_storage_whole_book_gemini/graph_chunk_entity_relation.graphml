7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大猿叶甲"><data key="d0">大猿叶甲</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;呈黑色，具有金属光泽，成虫和幼虫均能通过群聚食叶造成损伤。&lt;SEP&gt;寡食性害虫</data><data key="d3">chunk-e1ffc4d7126b3916ef88c8c7f5b1a921&lt;SEP&gt;chunk-681e040359f2c6112ca35860a588dd88&lt;SEP&gt;chunk-8192d6faa31a6aed18c83a92fd0d4cf8&lt;SEP&gt;chunk-bcba7bdeba2b73eee2708a05dfc354f1&lt;SEP&gt;chunk-eb63d9a76b5e16b54b440b97c0ede0f6&lt;SEP&gt;chunk-1e49bf5ab12c0677321337f83c38fe0a&lt;SEP&gt;chunk-ca8792ea559d74a7290ea6ef526fb64f&lt;SEP&gt;chunk-32ddbaf2dc6854d70cd0231ee3b7b30f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461167</data><data key="d6" /><data key="d7" /><data key="d8">{"危害症状": ["N/A", "嗜食十字花科蔬菜，包括白菜", "嗜食十字花科蔬菜，包括萝卜", "嗜食十字花科蔬菜，包括花椰菜", "嗜食十字花科蔬菜，包括芥菜", "成虫和幼虫群聚食叶，造成圆孔或网状叶脉。", "幼虫取食造成", "严重时幼虫取食造成", "虫粪污染叶片", "幼虫群聚取食白菜叶片", "幼虫群聚取食造成孔洞、网状缺刻", "严重危害白菜", "将叶片吃成圆孔、网状，仅留叶脉", "幼虫喜在心叶取食"], "防治要点": ["采取从田四周向中央喷药的包围式作业。", "可利用假死习性辅助进行"], "生活习性": ["假死习性", "受惊即缩足落地"], "发生时期": ["药剂防治关键期"]}</data><data key="d9">{"危害症状": [{"chunk": "chunk-681e040359f2c6112ca35860a588dd88", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-8192d6faa31a6aed18c83a92fd0d4cf8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-bcba7bdeba2b73eee2708a05dfc354f1", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-eb63d9a76b5e16b54b440b97c0ede0f6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-1e49bf5ab12c0677321337f83c38fe0a", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-ca8792ea559d74a7290ea6ef526fb64f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-32ddbaf2dc6854d70cd0231ee3b7b30f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "防治要点": [{"chunk": "chunk-eb63d9a76b5e16b54b440b97c0ede0f6", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-ca8792ea559d74a7290ea6ef526fb64f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-ca8792ea559d74a7290ea6ef526fb64f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-32ddbaf2dc6854d70cd0231ee3b7b30f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-ca8792ea559d74a7290ea6ef526fb64f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="大猿叶甲危害白菜"><data key="d0">大猿叶甲危害白菜</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了大猿叶甲幼虫对白菜叶片的危害症状，主要表现为叶片被取食形成大量圆孔、网状缺刻及残留叶脉，严重影响白菜品质。防治需在春秋两季幼虫盛发期结合假死性捕杀，并使用敌百虫、辛硫磷等药剂进行化学防治。</data><data key="d3">chunk-ca8792ea559d74a7290ea6ef526fb64f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大猿叶甲幼虫危害白菜叶片"><data key="d0">大猿叶甲幼虫危害白菜叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示大猿叶甲幼虫在十字花科蔬菜叶片上取食，叶片呈现被咬食的孔洞。大猿叶甲和小猿叶甲均属鞘翅目叶甲科，是十字花科蔬菜的寡食性害虫，幼虫和成虫均可群聚危害叶片。</data><data key="d3">chunk-bcba7bdeba2b73eee2708a05dfc354f1</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大猿叶甲幼虫危害白菜叶片图"><data key="d0">大猿叶甲幼虫危害白菜叶片图</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示白菜叶片被大猿叶甲幼虫严重啃食，形成大量孔洞。结合上下文，大猿叶甲幼虫和成虫群聚危害白菜叶片，造成千疮百孔、网状，仅留叶脉，虫粪污染叶片。其幼虫喜食心叶，昼夜活动。危害高峰期在每年4-5月和9-10月，秋季对大白菜危害较重。防治方法包括清除残株、人工捕杀、冬翻夏翻和药剂防治。</data><data key="d3">chunk-32ddbaf2dc6854d70cd0231ee3b7b30f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大猿叶甲成虫形态及危害"><data key="d0">大猿叶甲成虫形态及危害</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了大猿叶甲成虫在十字花科蔬菜叶片上的形态特征。大猿叶甲属于鞘翅目叶甲科，成虫与幼虫群聚危害，通过食叶导致叶片出现圆孔、网状及扫把状损伤。防治建议采用包围式喷药法以防成虫逃逸。</data><data key="d3">chunk-eb63d9a76b5e16b54b440b97c0ede0f6</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜"><data key="d0">大白菜</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;十字花科代表作物&lt;SEP&gt;代表十字花科蔬菜&lt;SEP&gt;代表十字花科蔬菜的具体作物&lt;SEP&gt;属于十字花科蔬菜</data><data key="d3">chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-e1ffc4d7126b3916ef88c8c7f5b1a921&lt;SEP&gt;chunk-0b5f294b1c97f35cb02b8c5e97a080e9&lt;SEP&gt;chunk-6fad4f22632131c47ac7fa6e017c1365&lt;SEP&gt;chunk-08be44a18d80d033d6d8c6eb79a3a64f&lt;SEP&gt;chunk-b0bc9c961a2342cc54041938ca465560&lt;SEP&gt;chunk-6a566dac6682579a8b7ab6c46552d839&lt;SEP&gt;chunk-e1a25ad91df4056b23309ce4d87d098e&lt;SEP&gt;chunk-80be34d2e662ee0076c2d8809df4d115&lt;SEP&gt;chunk-2d0a0e1a2ae281c246d32fd566f9339f&lt;SEP&gt;chunk-1fbfc726dd296f1ec43ce2aa9f0d0895&lt;SEP&gt;chunk-b3b74e94cd9e673214401f1d7e211970&lt;SEP&gt;chunk-e124f728736920798021720adc02a59e&lt;SEP&gt;chunk-310884df7e9f7ec7abc03ff78374fddd&lt;SEP&gt;chunk-bf76767393a4c9d7f894571646f86f0b&lt;SEP&gt;chunk-bf35b6fe615bb837008bfcf5197afb12&lt;SEP&gt;chunk-9d28819c3c65f9923e36642ce9a3523a&lt;SEP&gt;chunk-9418342574b2792109b681e7c44601ba&lt;SEP&gt;chunk-ce89c7a24c968edc3b8daaa4ee7e44ed&lt;SEP&gt;chunk-1af2b19abb0b704d0d3c588002b68add&lt;SEP&gt;chunk-43efc3959ca8fe33258e06a2eb799ab5&lt;SEP&gt;chunk-2dfd14c48b4b4598d0c8ffa221c1df81&lt;SEP&gt;chunk-a21ba0d0d4ddb7ede46cade93c561764&lt;SEP&gt;chunk-26c3f4922827d7e185440701e7ced24a&lt;SEP&gt;chunk-bff12f56d0df62b0fd2dbb213026b0d6&lt;SEP&gt;chunk-b468b01feae03bbeb095bda274f22463&lt;SEP&gt;chunk-27d0171243706f7c20a06c9a73190c96&lt;SEP&gt;chunk-b519def7c9178c12ba0037aaa6c70926&lt;SEP&gt;chunk-61e246e90bcaaf9ad1308e02f330b201&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e&lt;SEP&gt;chunk-7ad50e2d4da052bc9fee4ea624a8528f&lt;SEP&gt;chunk-3f372dacdfcadb29be98d37273f433fd&lt;SEP&gt;chunk-c2c46152db5ff07cdb1d6f5561cce0dc&lt;SEP&gt;chunk-749648f3569db2742acde22e0ccdc771&lt;SEP&gt;chunk-6502c650bcc919b4a37d340e72611559&lt;SEP&gt;chunk-17ab0a21718627faacbccb7c8da47bef&lt;SEP&gt;chunk-157bd3addbb38750d6dff95f3d5a9e7d&lt;SEP&gt;chunk-36a0d55340470c41badc3ab815a48b11&lt;SEP&gt;chunk-e4deaf546dd3ce6cf9f4d4298a30c16c&lt;SEP&gt;chunk-3420d79a9e5621d0c5a78a59239be5b5&lt;SEP&gt;chunk-eb133807de2ff915d9cd628148148023&lt;SEP&gt;chunk-fa54432d372186232c5c9c4f49b861e9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461256</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜缺硼症状"><data key="d0">大白菜缺硼症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示大白菜缺硼症状，茎部出现开裂和锈褐色。结合上下文，缺硼是十字花科蔬菜常见的生理性病害，会引起花椰菜、青花菜、萝卜等多种蔬菜的茎部、花球、根部和叶片出现水渍状、腐烂、开裂、畸形等症状。防治方法包括增施有机肥、平衡施肥、合理施用硼肥。</data><data key="d3">chunk-80be34d2e662ee0076c2d8809df4d115</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461330</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜菌核病"><data key="d0">大白菜菌核病</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示了大白菜菌核病的典型症状，病害主要侵染大白菜茎基部，导致组织出现水渍状腐烂、白色棉絮状菌丝及特有的黑色鼠粪状菌核，最终引起整株腐烂。</data><data key="d3">chunk-61e246e90bcaaf9ad1308e02f330b201</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜菌核病严重发病状"><data key="d0">大白菜菌核病严重发病状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了大白菜感染菌核病的严重发病症状，可见植株茎基部和叶片大面积腐烂、枯萎，呈现灰褐色。菌核病是一种真菌性病害，主要危害大白菜等十字花科蔬菜的茎基部、叶片和叶球，在苗期和成株期均可发生，特征是病部出现水渍状病斑、组织腐烂并产生菌丝和黑色菌核。</data><data key="d3">chunk-a21ba0d0d4ddb7ede46cade93c561764</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜菌核病大田发病状"><data key="d0">大白菜菌核病大田发病状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了大白菜感染菌核病后的典型田间症状。病害主要危害大白菜的茎基部和叶片，表现为水渍状病斑、组织腐烂，严重时导致全株枯死，是十字花科蔬菜常见的重要真菌性病害。</data><data key="d3">chunk-c2c46152db5ff07cdb1d6f5561cce0dc</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜菌核病病征"><data key="d0">大白菜菌核病病征</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示了大白菜患菌核病后的茎基部症状，特征为组织腐烂并伴有白色菌丝和黑色鼠粪状菌核，与周围文档中关于十字花科蔬菜菌核病的病理描述一致。</data><data key="d3">chunk-e124f728736920798021720adc02a59e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜蚜虫危害症状"><data key="d0">大白菜蚜虫危害症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示了大白菜受蚜虫侵害后的病理表现。蚜虫通过取食导致大白菜叶片萎缩、变形，分泌的蜜露诱发煤污病（叶面黑色污染），并传播病毒病，最终严重影响植株结球能力。</data><data key="d3">chunk-bf35b6fe615bb837008bfcf5197afb12</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜软腐病"><data key="d0">大白菜软腐病</data><data key="d1">病害</data><data key="d10" /><data key="d2">软腐病在大白菜上的特指表现。</data><data key="d3">chunk-6a566dac6682579a8b7ab6c46552d839</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461313</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜软腐病严重发病症状"><data key="d0">大白菜软腐病严重发病症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了大白菜感染软腐病后的严重发病状态。病害主要危害叶柄基部与根茎部，导致组织软腐溃烂、产生黄色黏稠物并伴有恶臭，植株最终发生萎蔫倒伏。</data><data key="d3">chunk-6fad4f22632131c47ac7fa6e017c1365</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜软腐病典型症状"><data key="d0">大白菜软腐病典型症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了大白菜软腐病的典型危害症状，主要表现为包心期植株叶柄及根茎部位发生软腐、腐烂，并伴随水渍状斑块和组织液化，是十字花科蔬菜生产中的主要毁灭性病害之一。</data><data key="d3">chunk-310884df7e9f7ec7abc03ff78374fddd</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜软腐病发病症状"><data key="d0">大白菜软腐病发病症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了大白菜软腐病的典型田间危害症状。该病主要在包心期发生，病部初期呈水渍状，后期叶柄及茎基部组织腐烂、产生恶臭，与上下文描述的软腐病症状高度吻合。</data><data key="d3">chunk-e1a25ad91df4056b23309ce4d87d098e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜软腐病干腐症状图片"><data key="d0">大白菜软腐病干腐症状图片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示大白菜软腐病干腐症状。上下文描述了软腐病危害十字花科植物大白菜，在包心期发病，天气干燥时出现病叶失水呈薄纸状的干腐症状，并伴随腐烂和恶臭。</data><data key="d3">chunk-6a566dac6682579a8b7ab6c46552d839</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜软腐病心腐症状"><data key="d0">大白菜软腐病心腐症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片呈现了大白菜感染软腐病后的典型心腐症状。该病主要在包心期发生，病原菌侵害大白菜叶柄基部及心髓组织，导致其产生水渍状病斑并迅速腐烂，散发恶臭，严重时可导致植株整株溃烂。</data><data key="d3">chunk-ce89c7a24c968edc3b8daaa4ee7e44ed</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜霜霉病病叶"><data key="d0">大白菜霜霉病病叶</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图展示了大白菜霜霉病的典型叶片正面症状。大白菜霜霉病由霜霉菌引起，病叶正面可见由叶脉限制的黄褐色多角形病斑，严重影响大白菜的生长与品质。防治上需采取轮作、排水降湿及化学药剂（如甲霜·锰锌等）喷施相结合的措施。</data><data key="d3">chunk-b519def7c9178c12ba0037aaa6c70926</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜霜霉病病叶背面霉层"><data key="d0">大白菜霜霉病病叶背面霉层</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示大白菜叶片感染霜霉病后，叶背面出现的灰色霉层症状。霜霉病由霜霉菌引起，主要危害十字花科蔬菜的叶片，多发生于春秋两季的大白菜莲座期至包心期。可使用咯菌腈进行拌种预防，发病前后可选用多种杀菌剂进行防治。</data><data key="d3">chunk-b3b74e94cd9e673214401f1d7e211970</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461367</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜黑腐病危害症状"><data key="d0">大白菜黑腐病危害症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示大白菜叶片染病症状，叶缘出现典型的V形黄褐色病斑，是由野油菜黄单胞菌野油菜致病变种引起的黑腐病。该病常在高温多雨环境下发生，严重时导致叶片枯死。</data><data key="d3">chunk-17ab0a21718627faacbccb7c8da47bef</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大白菜黑腐病症状图"><data key="d0">大白菜黑腐病症状图</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了大白菜黑腐病的典型田间危害症状，表现为叶片边缘出现V形黄褐色坏死斑及黄色晕圈。该病由野油菜黄单胞菌野油菜致病变种引起，是十字花科蔬菜的重要病害，常在高温多雨条件下发生。</data><data key="d3">chunk-3f372dacdfcadb29be98d37273f433fd</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大豆"><data key="d0">大豆</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-dd1cedc8d65b907a2104d9a71428b3be</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461487</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="大龄"><data key="d0">大龄</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-aff554a7fea2b0174a3638024d446a56</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461420</data><data key="d6" /><data key="d7">大龄幼虫</data><data key="d8">{"别名": ["大龄幼虫"], "危害症状": ["取食叶片造成孔洞、缺刻", "取食嫩茎造成伤害"]}</data><data key="d9">{"别名": [{"chunk": "", "file": "", "page": ""}], "危害症状": [{"chunk": "chunk-aff554a7fea2b0174a3638024d446a56", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="头部"><data key="d0">头部</data><data key="d1">部位</data><data key="d10" /><data key="d2">小菜蛾幼虫的身体部位。</data><data key="d3">chunk-b64d931a1bdfddeeb19bd5ec9fcbfae8</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461462</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="嫩叶"><data key="d0">嫩叶</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-b0bc9c961a2342cc54041938ca465560&lt;SEP&gt;chunk-d14744286afe2dc35a5324b596629f4a&lt;SEP&gt;chunk-16e53f221a8aaf862ba107b114abcab2&lt;SEP&gt;chunk-27d0171243706f7c20a06c9a73190c96&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e&lt;SEP&gt;chunk-fa7d45e646da9c39534669c3a730863e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461273</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="嫩芽"><data key="d0">嫩芽</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-ca141699f53529c2e47d2d719892c294</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777459261</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="嫩茎"><data key="d0">嫩茎</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-ce8ce757d0c4c5e0d3389af1fd809ffd&lt;SEP&gt;chunk-0a5a383f7804eaab55ca250a8c04eac7&lt;SEP&gt;chunk-b0bc9c961a2342cc54041938ca465560&lt;SEP&gt;chunk-5a2a424d35c8371bfe822398161732dd&lt;SEP&gt;chunk-5225b33b17e8ce25a168f6df8d8215e5&lt;SEP&gt;chunk-bf35b6fe615bb837008bfcf5197afb12&lt;SEP&gt;chunk-1af2b19abb0b704d0d3c588002b68add&lt;SEP&gt;chunk-22ec2d63c5447f009f8e14f909cb3d39&lt;SEP&gt;chunk-aff554a7fea2b0174a3638024d446a56&lt;SEP&gt;chunk-bff12f56d0df62b0fd2dbb213026b0d6&lt;SEP&gt;chunk-16e53f221a8aaf862ba107b114abcab2&lt;SEP&gt;chunk-27d0171243706f7c20a06c9a73190c96&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e&lt;SEP&gt;chunk-dee1c0cb2d3ac680561c4257ac355a14&lt;SEP&gt;chunk-7a5b263454d8b182750b31dbe14dcdab&lt;SEP&gt;chunk-fa54432d372186232c5c9c4f49b861e9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461229</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="嫩茎部位"><data key="d0">嫩茎部位</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-80aef901199e2ace7583bc4503b58d78</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461416</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="嫩荚"><data key="d0">嫩荚</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-bf35b6fe615bb837008bfcf5197afb12&lt;SEP&gt;chunk-1af2b19abb0b704d0d3c588002b68add&lt;SEP&gt;chunk-bff12f56d0df62b0fd2dbb213026b0d6</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461401</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="子叶"><data key="d0">子叶</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-75c79c36d93e57136b72ac0107291bc6&lt;SEP&gt;chunk-9e4557a3ad0dc9e0886fbcbc5cafce0b&lt;SEP&gt;chunk-e65169eeb2407bedfb7e356dc1bbf1f8</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461376</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="孢子囊"><data key="d0">孢子囊</data><data key="d1">病原菌</data><data key="d10" /><data key="d2">病害繁殖与扩散的病原体。</data><data key="d3">chunk-1253e4088f4e8d0960f2a2d0bb84f70d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461261</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="定虫隆"><data key="d0">定虫隆</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-cdc75a846424d224be95bef5e748659b&lt;SEP&gt;chunk-f9ebb1ddbe117603cd2ffff1b870e9ae</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461284</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="定虫隆乳油"><data key="d0">定虫隆乳油</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-844030a4d8a6de0ccf527992172d7166&lt;SEP&gt;chunk-16950d1361b65e692bd4c9c79222ad0e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461411</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小猿叶甲"><data key="d0">小猿叶甲</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;一种鞘翅目叶甲科害虫，主要危害十字花科蔬菜。&lt;SEP&gt;一种寡食性害虫&lt;SEP&gt;是寡食性害虫。&lt;SEP&gt;寡食性害虫</data><data key="d3">chunk-e1ffc4d7126b3916ef88c8c7f5b1a921&lt;SEP&gt;chunk-681e040359f2c6112ca35860a588dd88&lt;SEP&gt;chunk-8192d6faa31a6aed18c83a92fd0d4cf8&lt;SEP&gt;chunk-bcba7bdeba2b73eee2708a05dfc354f1&lt;SEP&gt;chunk-08be44a18d80d033d6d8c6eb79a3a64f&lt;SEP&gt;chunk-d6e6792e62bbd9174e8ddc2dce3c4772&lt;SEP&gt;chunk-e822b0b36bac4b88d32cca85f26cc962&lt;SEP&gt;chunk-188d592ff3cff56c600d114b41953556&lt;SEP&gt;chunk-1e49bf5ab12c0677321337f83c38fe0a&lt;SEP&gt;chunk-ad92b8e85bbcae6b658a4192d32c4bf3&lt;SEP&gt;chunk-0ed5436bf3fb965fbbc7838cf37929b3</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461167</data><data key="d6" /><data key="d7" /><data key="d8">{"防治要点": ["从田四周向中央喷", "深翻土壤"], "危害症状": ["取食叶片", "N/A", "叶片上出现许多圆孔", "叶片被吃成千疮百孔", "叶片被严重啃食成网状", "严重时叶片仅留叶脉呈扫把状", "虫粪污染叶片", "因虫粪污染导致叶片品质降低", "幼虫危害萝卜叶片，成虫和幼虫均食叶片", "幼虫和成虫均取食叶片，且群聚危害", "嗜食十字花科蔬菜，包括白菜", "嗜食十字花科蔬菜，包括花椰菜", "嗜食十字花科蔬菜，包括芥菜", "将叶片吃成圆孔或网状", "主要危害十字花科蔬菜", "通过啃食叶片造成网状或孔洞状损伤", "网状缺刻", "取食白菜叶片", "取食萝卜叶片", "取食导致穿孔和网状缺刻", "叶片被啃食后仅留叶脉", "叶片被啃食后残留叶脉呈扫把状", "成虫和幼虫均群聚危害", "小猿叶甲危害十字花科蔬菜，白菜是其中一种", "小猿叶甲危害十字花科蔬菜，萝卜是其中一种", "成虫取食叶片。", "造成叶片孔洞和网状损伤。", "叶片被咬食后形成的圆孔", "叶片仅残留叶脉呈网状", "小猿叶甲幼虫取食白菜叶片", "小猿叶甲成虫和幼虫均食白菜叶片", "被害叶片呈千疮百孔状"], "形态特征": ["N/A"], "生活习性": ["幼虫具有群聚危害习性", "受惊后有假死行为", "假死习性"], "发生时期": ["N/A"]}</data><data key="d9">{"防治要点": [{"chunk": "chunk-681e040359f2c6112ca35860a588dd88", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-0ed5436bf3fb965fbbc7838cf37929b3", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "危害症状": [{"chunk": "chunk-681e040359f2c6112ca35860a588dd88", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-8192d6faa31a6aed18c83a92fd0d4cf8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-bcba7bdeba2b73eee2708a05dfc354f1", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-08be44a18d80d033d6d8c6eb79a3a64f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-d6e6792e62bbd9174e8ddc2dce3c4772", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-e822b0b36bac4b88d32cca85f26cc962", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-188d592ff3cff56c600d114b41953556", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-1e49bf5ab12c0677321337f83c38fe0a", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-ad92b8e85bbcae6b658a4192d32c4bf3", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-0ed5436bf3fb965fbbc7838cf37929b3", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-08be44a18d80d033d6d8c6eb79a3a64f", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-d6e6792e62bbd9174e8ddc2dce3c4772", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-ad92b8e85bbcae6b658a4192d32c4bf3", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-0ed5436bf3fb965fbbc7838cf37929b3", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-e822b0b36bac4b88d32cca85f26cc962", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="小猿叶甲与大猿叶甲形态特征比较"><data key="d0">小猿叶甲与大猿叶甲形态特征比较</data><data key="d1">多模态元素</data><data key="d10">table</data><data key="d2">本文档对比了十字花科蔬菜害虫小猿叶甲与大猿叶甲在成虫、卵、幼虫、蛹四个阶段的形态特征，明确了两者在体型、光泽、后翅发育及肉瘤数量上的差异，为田间准确识别提供生物学依据。</data><data key="d3">chunk-1e49bf5ab12c0677321337f83c38fe0a</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小猿叶甲低龄幼虫"><data key="d0">小猿叶甲低龄幼虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了小猿叶甲的低龄幼虫及其在十字花科蔬菜叶片上的取食危害。该害虫属于鞘翅目叶甲科，成虫与幼虫均具群聚性，主要通过啃食叶片造成穿孔或网状叶脉，严重影响植株品质。</data><data key="d3">chunk-e822b0b36bac4b88d32cca85f26cc962</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小猿叶甲低龄幼虫危害白菜叶片症状"><data key="d0">小猿叶甲低龄幼虫危害白菜叶片症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示小猿叶甲低龄幼虫危害白菜叶片的症状，叶片呈穿孔状。结合上下文，小猿叶甲与大猿叶甲同属鞘翅目叶甲科，是十字花科蔬菜的寡食性害虫。其成虫和幼虫均群聚取食叶片，造成圆孔、千疮百孔，严重时仅留叶脉，虫粪污染叶片。其年发生代次因地域而异，成虫在长江流域表土越冬。防治上可采用包围式喷药。</data><data key="d3">chunk-681e040359f2c6112ca35860a588dd88</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小猿叶甲危害白菜"><data key="d0">小猿叶甲危害白菜</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了白菜受小猿叶甲严重危害的症状。小猿叶甲成虫和幼虫群聚取食白菜叶片，造成千疮百孔或网状残留叶脉，严重影响品质。防治需结合农艺措施（清理田园、深翻）与药剂防治（如敌百虫、辛硫磷等），重点在春秋两季幼虫期。</data><data key="d3">chunk-0ed5436bf3fb965fbbc7838cf37929b3</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小猿叶甲幼虫危害萝卜叶片"><data key="d0">小猿叶甲幼虫危害萝卜叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示小猿叶甲幼虫危害萝卜的叶片，造成大量穿孔和网状损伤，叶片品质降低。小猿叶甲属鞘翅目叶甲科，是十字花科蔬菜的寡食性害虫，成虫和幼虫均取食叶片。</data><data key="d3">chunk-8192d6faa31a6aed18c83a92fd0d4cf8</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小猿叶甲幼虫及危害状"><data key="d0">小猿叶甲幼虫及危害状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了十字花科蔬菜受小猿叶甲幼虫危害后的症状。幼虫群聚取食，使叶片出现大量圆孔及网状残缺，仅留叶脉，同时虫粪污染严重，影响作物外观与品质。</data><data key="d3">chunk-d6e6792e62bbd9174e8ddc2dce3c4772</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小猿叶甲成虫"><data key="d0">小猿叶甲成虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图示为危害十字花科蔬菜的害虫小猿叶甲成虫。该虫属鞘翅目叶甲科，具有趋光趋色性，群聚食叶，会导致叶片呈孔洞或网状受损，是蔬菜生产中的重要害虫。</data><data key="d3">chunk-188d592ff3cff56c600d114b41953556</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小猿叶甲高龄幼虫"><data key="d0">小猿叶甲高龄幼虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了小猿叶甲的高龄幼虫在十字花科蔬菜叶片上的群聚取食状态。小猿叶甲属叶甲科，是十字花科蔬菜的重要害虫，其幼虫与成虫通过啃食叶片造成千疮百孔或网状损害，严重影响蔬菜品质。</data><data key="d3">chunk-08be44a18d80d033d6d8c6eb79a3a64f</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜"><data key="d0">小白菜</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-2f12138e59db2f07225a36a367d035a7&lt;SEP&gt;chunk-1253e4088f4e8d0960f2a2d0bb84f70d&lt;SEP&gt;chunk-ff618f26eaddc530ed912c48956812ad&lt;SEP&gt;chunk-7607a348b8d39b8ae825c84727752791&lt;SEP&gt;chunk-11c7ba1acb88a6dd394244a5be34557e&lt;SEP&gt;chunk-e6025ee82f5cd704cdad4f40096c55dc&lt;SEP&gt;chunk-60cb92949480597cbb7128e491470f18&lt;SEP&gt;chunk-3432b8633ea0fc698665ef94d1ee6d37&lt;SEP&gt;chunk-fd340e54e36fe920be68c4ac34586210&lt;SEP&gt;chunk-de1c9cadad9dd3d2754b4b1f782866a0&lt;SEP&gt;chunk-634971419f68bfb00f83f83d9668f2fc&lt;SEP&gt;chunk-ea3ad9de087ca853f6d9c25a2d2681c9&lt;SEP&gt;chunk-157bd3addbb38750d6dff95f3d5a9e7d&lt;SEP&gt;chunk-a5dd5082aa7c0708134d0e024eeb5f52&lt;SEP&gt;chunk-132e8f455d2d417f60b885555af0141d&lt;SEP&gt;chunk-075bb3ace2dfb45f097400200194fa09</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461175</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜病毒病叶片症状图"><data key="d0">小白菜病毒病叶片症状图</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示小白菜病毒病在叶片上的典型症状，表现为淡绿与浓绿相间的花叶斑驳和叶面皱缩。结合上下文，病毒病主要危害十字花科蔬菜，通过蚜虫等传播，多发于苗期，长江中下游地区春季4-6月、秋季9-12月是盛发期，可选用盐酸吗啉呱等药剂防治。</data><data key="d3">chunk-2f12138e59db2f07225a36a367d035a7</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜白锈病"><data key="d0">小白菜白锈病</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了小白菜叶片遭受白锈病侵害后的典型症状。叶片黄化、枯萎，且表面可见明显的病斑及病原菌孢子堆，是十字花科蔬菜常见的真菌性病害表现。</data><data key="d3">chunk-634971419f68bfb00f83f83d9668f2fc</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜白锈病叶片症状"><data key="d0">小白菜白锈病叶片症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图示为小白菜叶片感染白锈病后的典型症状，表现为叶片背面产生白色、隆起的疱斑，即病原菌的孢子堆，是诊断十字花科蔬菜白锈病的关键依据。</data><data key="d3">chunk-075bb3ace2dfb45f097400200194fa09</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜白锈病病叶"><data key="d0">小白菜白锈病病叶</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了十字花科蔬菜小白菜感染白锈病的典型症状。病害主要危害叶片，表现为叶面产生暗褐绿色小斑，随后组织隆起并形成疱斑，最终破裂散出白色孢子囊，导致叶片枯黄。</data><data key="d3">chunk-1253e4088f4e8d0960f2a2d0bb84f70d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜缺硼症状"><data key="d0">小白菜缺硼症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了十字花科蔬菜小白菜缺硼引发的典型症状：茎部内部组织坏死、褐变并形成空洞，属于生理性缺素病害，可通过增施有机肥及补施硼肥进行防治。</data><data key="d3">chunk-60cb92949480597cbb7128e491470f18</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜菌核病"><data key="d0">小白菜菌核病</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了十字花科蔬菜（小白菜）感染菌核病的典型症状，病害主要造成植株茎基部和叶柄出现水渍状腐烂，表面可见白色菌丝体，属于典型的真菌性病害。</data><data key="d3">chunk-3432b8633ea0fc698665ef94d1ee6d37</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜菌核病根颈危害症状"><data key="d0">小白菜菌核病根颈危害症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">展示了十字花科蔬菜（小白菜）感染菌核病的典型症状，病原菌侵害根颈部，导致组织腐烂，表面产生白色棉絮状菌丝，这是该病害在苗期和成株期的重要诊断特征。</data><data key="d3">chunk-de1c9cadad9dd3d2754b4b1f782866a0</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜软腐病严重发病症状"><data key="d0">小白菜软腐病严重发病症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了十字花科蔬菜小白菜感染软腐病后的严重发病状态。受害植株呈现叶片萎蔫下垂、植株基部组织软腐坏死、呈黏滑稀泥状并伴有恶臭的典型症状，是诊断该病害的关键识别特征。</data><data key="d3">chunk-132e8f455d2d417f60b885555af0141d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜软腐病危害症状"><data key="d0">小白菜软腐病危害症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了小白菜软腐病的典型发病症状，可见植株叶柄基部出现水渍状腐烂，这是该病害在十字花科蔬菜上常见的受害形态，易造成植株组织软化并伴有恶臭。</data><data key="d3">chunk-fd340e54e36fe920be68c4ac34586210</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜软腐病心腐症状"><data key="d0">小白菜软腐病心腐症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图展示了小白菜感染软腐病后的典型心腐症状，表现为心叶处组织发黑、腐烂成黏滑泥状，严重影响作物正常生长，符合软腐病在十字花科蔬菜上的典型病理表现。</data><data key="d3">chunk-7607a348b8d39b8ae825c84727752791</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜霜霉病前期叶片症状"><data key="d0">小白菜霜霉病前期叶片症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示小白菜叶片受霜霉病危害的前期症状，可见叶片出现褪绿、黄化和黄褐色斑块。霜霉病是十字花科蔬菜常见病害，主要危害叶片，发生在苗期和成株期。</data><data key="d3">chunk-ff618f26eaddc530ed912c48956812ad</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜霜霉病叶片正面症状图"><data key="d0">小白菜霜霉病叶片正面症状图</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了小白菜叶片感染霜霉病的正面症状，表现为叶片表面出现褪绿、黄化斑以及多角形淡褐色或黄褐色斑块，符合十字花科蔬菜霜霉病的典型危害特征。</data><data key="d3">chunk-ea3ad9de087ca853f6d9c25a2d2681c9</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜霜霉病症状图"><data key="d0">小白菜霜霉病症状图</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图示小白菜叶片背面可见霜霉病特有的灰白色霉层，由霜霉菌侵染，是十字花科蔬菜霜霉病的典型症状，常发生于温暖高湿环境。</data><data key="d3">chunk-157bd3addbb38750d6dff95f3d5a9e7d</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜黑腐病叶部症状"><data key="d0">小白菜黑腐病叶部症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图展示了小白菜感染黑腐病的叶片特征，表现为叶缘起始的V形黄褐色病斑，属于十字花科蔬菜黑腐病的典型症状。由野油菜黄单胞菌野油菜致病变种引起，常见于高温多雨季节。</data><data key="d3">chunk-e6025ee82f5cd704cdad4f40096c55dc</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小白菜黑腐病症状"><data key="d0">小白菜黑腐病症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图示为小白菜感染黑腐病后的典型叶片症状，表现为叶缘出现V形黄褐色坏死斑。该病由野油菜黄单胞菌野油菜致病变种引起，属于十字花科蔬菜重要细菌性病害，常在高温多雨条件下发生。</data><data key="d3">chunk-11c7ba1acb88a6dd394244a5be34557e</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小菜蛾"><data key="d0">小菜蛾</data><data key="d1">虫害</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;又称吊丝虫，十字花科蔬菜重要害虫。&lt;SEP&gt;又名小青虫、两头尖、吊丝虫，鳞翅目菜蛾科害虫。&lt;SEP&gt;十字花科蔬菜的主要害虫&lt;SEP&gt;十字花科蔬菜的重要害虫，幼虫取食叶片导致孔洞或网状结构。&lt;SEP&gt;学名为Plutella xylostella，俗称吊丝虫，幼虫阶段对多种十字花科蔬菜造成危害。</data><data key="d3">chunk-2711af80087a36171089b13436581425&lt;SEP&gt;chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-eb8e40732cd0b5a7f534922a7ccb9a6e&lt;SEP&gt;chunk-2102c4977ee2662531b474addbf76d25&lt;SEP&gt;chunk-371895d9884598c227a071fa676687e0&lt;SEP&gt;chunk-06c4679ebf4de0a8d8224fbb2924294f&lt;SEP&gt;chunk-0a5a383f7804eaab55ca250a8c04eac7&lt;SEP&gt;chunk-bf5f3b0e979a7287d55994f336876320&lt;SEP&gt;chunk-18a956ecf95a9b8ddabc1b9fe91aa320&lt;SEP&gt;chunk-1fbfc726dd296f1ec43ce2aa9f0d0895&lt;SEP&gt;chunk-6c9c5c1a89394df08c4521777314cc90&lt;SEP&gt;chunk-bff12f56d0df62b0fd2dbb213026b0d6&lt;SEP&gt;chunk-b9e2160f338aa7aa8806102dd36fea49&lt;SEP&gt;chunk-b64d931a1bdfddeeb19bd5ec9fcbfae8&lt;SEP&gt;chunk-058bfcb505d4110825b3930b6eb972e2&lt;SEP&gt;chunk-dee1c0cb2d3ac680561c4257ac355a14&lt;SEP&gt;chunk-25a870883e30ca4e4e260db153e16de6&lt;SEP&gt;chunk-3b4748e1b515b1d16d492a54b7db5d2c&lt;SEP&gt;chunk-c41e49bf19f4a71064df3d77eebfb411</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461186</data><data key="d6" /><data key="d7">小青虫&lt;SEP&gt;两头尖&lt;SEP&gt;吊丝虫</data><data key="d8">{"别名": ["小青虫", "两头尖", "吊丝虫", "N/A"], "形态特征": ["小菜蛾的越冬阶段。", "小菜蛾成虫的整体颜色特征", "头部黄白色", "触角丝状", "两翅覆盖于体背呈屋脊状", "呈椭圆形，稍扁平，初产时乳白色，后变淡黄色", "描述小菜蛾幼虫的体型。", "描述小菜蛾幼虫的体色。", "描述小菜蛾幼虫头部的颜色。"], "防治要点": ["避免十字花科蔬菜周年连作。", "用于防治小菜蛾"], "危害症状": ["取食叶肉，形成透明斑、孔洞和缺刻。", "低龄幼虫取食叶肉留下一层透明表皮", "幼龄虫群集心叶危害生长点造成", "N/A", "幼虫取食叶肉后留下的透明表皮。", "幼虫危害初期形成的透明斑。", "幼虫取食叶片形成的穿孔。", "幼虫取食叶片边缘形成的缺口。", "严重危害时叶片呈现的网格状。", "叶片布满的透明区域。", "小菜蛾幼虫危害甘蓝叶片", "小菜蛾幼虫危害白菜叶片", "小菜蛾幼虫危害叶片", "小菜蛾幼虫群集危害心叶", "低龄幼虫取食叶肉形成", "取食叶片及内部组织", "幼虫主要危害部位", "小菜蛾幼虫取食白菜叶片及生长点", "小菜蛾幼虫取食甘蓝叶片及生长点", "幼虫取食后导致的机械损伤。", "心叶和生长点受损导致的现象。"], "生活习性": ["昼伏夜出", "N/A", "小菜蛾幼虫的一种取食方式。", "小菜蛾幼虫的一种危害习性。"], "发生时期": ["易发生时期"]}</data><data key="d9">{"别名": [{"chunk": "", "file": "", "page": ""}, {"chunk": "chunk-0a5a383f7804eaab55ca250a8c04eac7", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "形态特征": [{"chunk": "chunk-0a5a383f7804eaab55ca250a8c04eac7", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-bf5f3b0e979a7287d55994f336876320", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-b9e2160f338aa7aa8806102dd36fea49", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-b64d931a1bdfddeeb19bd5ec9fcbfae8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "防治要点": [{"chunk": "chunk-0a5a383f7804eaab55ca250a8c04eac7", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-058bfcb505d4110825b3930b6eb972e2", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "危害症状": [{"chunk": "chunk-0a5a383f7804eaab55ca250a8c04eac7", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-1fbfc726dd296f1ec43ce2aa9f0d0895", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-b64d931a1bdfddeeb19bd5ec9fcbfae8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-058bfcb505d4110825b3930b6eb972e2", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-dee1c0cb2d3ac680561c4257ac355a14", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-c41e49bf19f4a71064df3d77eebfb411", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "生活习性": [{"chunk": "chunk-bf5f3b0e979a7287d55994f336876320", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}, {"chunk": "chunk-b64d931a1bdfddeeb19bd5ec9fcbfae8", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}], "发生时期": [{"chunk": "chunk-dee1c0cb2d3ac680561c4257ac355a14", "file": "十字花科蔬菜病虫害_3.pdf", "page": ""}]}</data></node><node id="小菜蛾危害十字花科蔬菜叶片症状"><data key="d0">小菜蛾危害十字花科蔬菜叶片症状</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了小菜蛾幼虫对十字花科蔬菜叶片的危害症状。幼虫呈绿色纺锤形，取食叶肉形成透明斑（开天窗）及叶片孔洞、缺刻，最终导致叶片呈网状，是该害虫在苗期和生长期的典型危害表现。</data><data key="d3">chunk-b64d931a1bdfddeeb19bd5ec9fcbfae8</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小菜蛾卵在十字花科蔬菜叶片上的形态"><data key="d0">小菜蛾卵在十字花科蔬菜叶片上的形态</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了小菜蛾卵在十字花科蔬菜叶片上的形态特征，卵呈淡黄色、椭圆形、稍扁平，表面有细密纹路。小菜蛾卵通常单粒产于叶背叶脉凹陷处，是小菜蛾危害十字花科蔬菜的一个重要生命阶段。</data><data key="d3">chunk-18a956ecf95a9b8ddabc1b9fe91aa320</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小菜蛾卵（十字花科蔬菜"><data key="d0">小菜蛾卵（十字花科蔬菜</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了小菜蛾（鳞翅目菜蛾科）在十字花科蔬菜叶片背面的产卵情况。卵呈淡黄色椭圆形，多单粒散产于叶脉凹陷处。这是小菜蛾发育周期的第一阶段，是识别该害虫的重要依据。</data><data key="d3">chunk-b9e2160f338aa7aa8806102dd36fea49</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小菜蛾幼虫危害十字花科蔬菜叶片"><data key="d0">小菜蛾幼虫危害十字花科蔬菜叶片</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">该图片展示了小菜蛾低龄幼虫在十字花科蔬菜叶片上造成的危害症状，表现为叶片上的孔洞和缺刻。结合上下文，可提取小菜蛾的形态特征、危害表现、发生时期及防治方法等知识。</data><data key="d3">chunk-1fbfc726dd296f1ec43ce2aa9f0d0895</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小菜蛾成虫"><data key="d0">小菜蛾成虫</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">小菜蛾（Plutella xylostella）是十字花科蔬菜的重要害虫，属鳞翅目菜蛾科。该图片展示了小菜蛾成虫的形态特征，其体灰褐色，静息时两翅呈屋脊状，有菱形斑纹。小菜蛾幼虫主要危害叶片、心叶、叶球等部位，造成透明斑、孔洞和“秃顶苗”，严重影响蔬菜产量。它以蛹越冬，在不同地区和时期发生代数及危害程度各异。防治方法包括合理种植布局和避免十字花科蔬菜连作。</data><data key="d3">chunk-0a5a383f7804eaab55ca250a8c04eac7</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小菜蛾茧及其危害"><data key="d0">小菜蛾茧及其危害</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示小菜蛾的茧附着在受损的十字花科蔬菜叶片上。小菜蛾幼虫对甘蓝、花椰菜等蔬菜造成孔洞和缺刻，严重时叶片呈网状。可使用多种化学或生物药剂防治该害虫。</data><data key="d3">chunk-c41e49bf19f4a71064df3d77eebfb411</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小菜蛾蛹"><data key="d0">小菜蛾蛹</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片展示了小菜蛾的蛹，其形态特征为纺锤形、灰白色丝质茧。小菜蛾作为十字花科蔬菜的重要害虫，幼虫阶段取食叶肉、心叶，导致开天窗、秃顶苗等症状，越冬以蛹态进行。防治方法多样，包括农业、生物和化学防治，最佳时期为幼虫期。</data><data key="d3">chunk-058bfcb505d4110825b3930b6eb972e2</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小菜蛾高龄幼虫危害十字花科蔬菜"><data key="d0">小菜蛾高龄幼虫危害十字花科蔬菜</data><data key="d1">多模态元素</data><data key="d10">image</data><data key="d2">图片显示小菜蛾高龄幼虫，体呈绿色，头黄褐色，正在危害十字花科蔬菜叶片。结合上下文，该幼虫可造成叶片“开天窗”、孔洞、缺刻、网状化，并在苗期形成“秃顶苗”，结球期钻蛀叶球。</data><data key="d3">chunk-dee1c0cb2d3ac680561c4257ac355a14</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777460192</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="小麦"><data key="d0">小麦</data><data key="d1">作物</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-039c414821a18ac99777ef473c4c3eeb</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777459274</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="巴蜗牛科"><data key="d0">巴蜗牛科</data><data key="d1">生物分类</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-039c414821a18ac99777ef473c4c3eeb&lt;SEP&gt;chunk-ae6ade12d6e6964fb85422f4cc485bee&lt;SEP&gt;chunk-b16cd651cdc5569a6a819323b4bebdf3&lt;SEP&gt;chunk-a6d0c51243ca209ed10575700d7d6fcb&lt;SEP&gt;chunk-2183dd5d018c45af93c88653910c0ba1&lt;SEP&gt;chunk-dd1cedc8d65b907a2104d9a71428b3be</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461199</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="幼叶"><data key="d0">幼叶</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-80be34d2e662ee0076c2d8809df4d115</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461336</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="幼芽"><data key="d0">幼芽</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-b0bc9c961a2342cc54041938ca465560</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461271</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="幼苗"><data key="d0">幼苗</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;白菜灰霉病主要危害的部位之一</data><data key="d3">chunk-2732eb6195df6f6255819cca0b42029f&lt;SEP&gt;chunk-a6d0c51243ca209ed10575700d7d6fcb&lt;SEP&gt;chunk-026760796995a178eb1fdad1452f8328&lt;SEP&gt;chunk-16e53f221a8aaf862ba107b114abcab2&lt;SEP&gt;chunk-27d0171243706f7c20a06c9a73190c96&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e&lt;SEP&gt;chunk-c31283d50d160b1f299e0a202450ac31</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461254</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="幼苗期"><data key="d0">幼苗期</data><data key="d1">生长期</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;病毒病防治关键时期</data><data key="d3">chunk-2102c4977ee2662531b474addbf76d25&lt;SEP&gt;chunk-2f12138e59db2f07225a36a367d035a7&lt;SEP&gt;chunk-ba83ee149a2e9cfe2bb3186d3d9ab242&lt;SEP&gt;chunk-cdc75a846424d224be95bef5e748659b&lt;SEP&gt;chunk-75c79c36d93e57136b72ac0107291bc6&lt;SEP&gt;chunk-dc8f89ad08f02a366bb1855964931b0b&lt;SEP&gt;chunk-e65169eeb2407bedfb7e356dc1bbf1f8&lt;SEP&gt;chunk-844030a4d8a6de0ccf527992172d7166&lt;SEP&gt;chunk-ea9349cf234838116d54e1a5e31192ff</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461179</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="幼荚"><data key="d0">幼荚</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-0a5a383f7804eaab55ca250a8c04eac7&lt;SEP&gt;chunk-16e53f221a8aaf862ba107b114abcab2&lt;SEP&gt;chunk-27d0171243706f7c20a06c9a73190c96&lt;SEP&gt;chunk-86fe0a0dce4f7819d35523a45e7fd62e&lt;SEP&gt;chunk-dee1c0cb2d3ac680561c4257ac355a14</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461230</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="幼虫"><data key="d0">幼虫</data><data key="d1">生长期</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;老熟后钻入4-9厘米的土内吐丝筑室化蛹。</data><data key="d3">chunk-53e6356230579174bc1646371ab0629d&lt;SEP&gt;chunk-912985f5ad6ba6992e74bb91994a8a28&lt;SEP&gt;chunk-25a870883e30ca4e4e260db153e16de6</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461346</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="异菌脲"><data key="d0">异菌脲</data><data key="d1">药剂</data><data key="d10" /><data key="d2">N/A</data><data key="d3">chunk-0b5f294b1c97f35cb02b8c5e97a080e9&lt;SEP&gt;chunk-06c4679ebf4de0a8d8224fbb2924294f&lt;SEP&gt;chunk-eaa13fa62c2f2a3e426c1cbdefca4345&lt;SEP&gt;chunk-8fcdba800e6f311738dd69c3bb11fcc6&lt;SEP&gt;chunk-3b4748e1b515b1d16d492a54b7db5d2c</data><data key="d4">十字花科蔬菜病虫害_3.pdf</data><data key="d5">1777461191</data><data key="d6" /><data key="d7" /><data key="d8">{}</data><data key="d9">{}</data></node><node id="心叶"><data key="d0">心叶</data><data key="d1">部位</data><data key="d10" /><data key="d2">N/A&lt;SEP&gt;植株中心新生的叶片。</data><data key="d3">chunk-2de1784a101a3d8331d829acf538c9e1&lt;SEP&gt;chunk-c60631811c47de4ce2c79aee52951117&lt;SEP&gt;chunk-eb8e40732cd0b5a7f534922a7ccb9a6e&lt;SEP&gt;chunk-2102c4977ee2662531b474addbf76d25&lt;SEP&gt;chunk-e1ffc4d7126b3916ef88c8c7f5b1a921&lt;SEP&gt;chunk-ca141699f53529c2e47d2d719892c294&lt;SEP&gt;chunk-371895d9884598c227a071fa676687e0&lt;SEP&gt;chunk-2f12138e59db2f07225a36a367d035a7&lt;SEP&gt;chunk-0a5a383f7804eaab55ca250a8c04eac7&lt;SEP&gt;chunk-aa89e13f2be5973d8335d6cc12cf7a4e&lt;SEP&gt;chunk-ba83ee149a2e9cfe2bb3186d3d9ab242&lt;SEP&gt;chunk-7607a348b8d39b8ae825c84727752791&lt;SEP&gt;chunk-cdc75a846424d224be95bef5e748659b&lt;SEP&gt;chunk-89fd1a92fac060bd5bcd453db48be5bb&lt;SEP&gt;chunk-cef0a38360a3e2500cb25e1f6f777a8f&lt;SEP&gt;chunk-adaeb6ba455cbb00a27118e9da2ccaca&lt;SEP&gt;chunk-1fbfc726dd296f1ec43ce2aa9f0d0895&lt;SEP&gt;chunk-dc8f89ad08f02a366bb1855964931b0b&lt;SEP&gt;chunk-ad92b8e85bbcae6b658a4192d32c4bf3&lt;SEP&gt;chunk-d14744286afe2dc35a5324b596629f4a&lt;SEP&gt;chunk-844030a4d8a6de0ccf527992172d7166&lt;SEP&gt;chunk-2dfd14c48b4b4598d0c8ffa221c1df81&lt;SEP&gt;chunk-7847dba0e850b38d58d9919ba3f5cced&lt;SEP&gt;chunk-26c3f4922827d7e185440701e7ced24a&lt;SEP&gt;chunk-ea9349cf234838116d54e1a5e31192ff&lt;SEP&gt;chunk-16950d1361b65e692bd4c9c79222ad0e&lt;SEP&gt;chunk-d19d7e947c23393542da83f9bbf10b07&lt;SEP&gt;chunk-b64d931a1bdfddeeb19bd5ec9fc